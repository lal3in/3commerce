ASPNETCORE_ENVIRONMENT=Development

# Verbose dev logging so failures carry their own diagnosis (compose-smoke / live debugging).
# Default=Debug surfaces app + EF SQL (logged at Information) + MassTransit. Override per-deploy if noisy.
Logging__LogLevel__Default=Debug
Logging__LogLevel__Microsoft.AspNetCore=Information
Logging__LogLevel__MassTransit=Debug

# ── Optional knobs (containerized dev). Uncomment to activate; ASP.NET maps `__` to `:`.
# Observability (mt6_13): push OTLP to the compose observability profile's collector.
#OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# Payments (ADR-0039): Development defaults to Mode=LocalMock + AllowMockEmail=true via
# appsettings.Development.json — no env needed here. Outside Development, PaymentModeGuard
# refuses LocalMock/AllowMockEmail at boot; set Sandbox/Production + provider creds per
# docs/ops/secrets.md instead.
#Payments__MockEmailTo=dev-payments@localhost
# Quartz schedulers (Payments daily-journal, Marketing scheduled-publish sweep): on by default.
#Scheduling__Enabled=false
# Identity MFA floor (0=None): raise to require MFA for platform operators.
#Mfa__PlatformMinimum=0
