{
  "name": "3commerce-storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "start:standalone": "cp -R public .next/standalone/ 2>/dev/null; cp -R .next/static .next/standalone/.next/ 2>/dev/null; PORT=${PORT:-3000} HOSTNAME=127.0.0.1 node .next/standalone/server.js"
  },
  "dependencies": {
    "next": "15.5.19",
    "next-intl": "^4.13.2",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.1.14",
    "@types/node": "24.6.2",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "4.1.14",
    "typescript": "5.9.3"
  }
}
