{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/identity/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/identity" },
          { "RequestHeaderRemove": "X-Internal-Claims" }
        ]
      },
      "catalog": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/catalog/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/catalog" },
          { "RequestHeaderRemove": "X-Internal-Claims" }
        ]
      },
      "ordering": {
        "ClusterId": "ordering",
        "Match": { "Path": "/api/ordering/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/ordering" },
          { "RequestHeaderRemove": "X-Internal-Claims" }
        ]
      },
      "payments": {
        "ClusterId": "payments",
        "Match": { "Path": "/api/payments/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/payments" },
          { "RequestHeaderRemove": "X-Internal-Claims" }
        ]
      },
      "fulfillment": {
        "ClusterId": "fulfillment",
        "Match": { "Path": "/api/fulfillment/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/fulfillment" },
          { "RequestHeaderRemove": "X-Internal-Claims" }
        ]
      },
      "support": {
        "ClusterId": "support",
        "Match": { "Path": "/api/support/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/support" },
          { "RequestHeaderRemove": "X-Internal-Claims" }
        ]
      }
    },
    "Clusters": {
      "identity":    { "Destinations": { "d1": { "Address": "http://localhost:5101/" } } },
      "catalog":     { "Destinations": { "d1": { "Address": "http://localhost:5102/" } } },
      "ordering":    { "Destinations": { "d1": { "Address": "http://localhost:5103/" } } },
      "payments":    { "Destinations": { "d1": { "Address": "http://localhost:5104/" } } },
      "fulfillment": { "Destinations": { "d1": { "Address": "http://localhost:5105/" } } },
      "support":     { "Destinations": { "d1": { "Address": "http://localhost:5106/" } } }
    }
  }
}
