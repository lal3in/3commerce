@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<div style="display:flex; min-height:100vh;">
    <nav style="width:220px; background:#0f172a; color:#fff; padding:1rem;">
        <h2 style="font-size:1.1rem;">@L["Nav_Brand"]</h2>
        <p style="color:#94a3b8; font-size:.85rem;">@L["Nav_Subtitle"]</p>
        <ul style="list-style:none; padding:0; line-height:2;">
            <li><NavLink href="/" Match="NavLinkMatch.All" style="color:#cbd5e1;" title="@L["Nav_Overview_Tooltip"]">@L["Nav_Overview"]</NavLink></li>
            <li><NavLink href="/stock" style="color:#cbd5e1;" title="@L["Nav_Stock_Tooltip"]">@L["Nav_Stock"]</NavLink></li>
            <li><NavLink href="/requests" style="color:#cbd5e1;" title="@L["Nav_Requests_Tooltip"]">@L["Nav_Requests"]</NavLink></li>
        </ul>
        <div style="margin-top:2rem;">
            <CultureSelector LabelColor="#94a3b8" />
        </div>
        <form action="/auth/logout" method="post" style="margin-top:1.5rem;">
            <AntiforgeryToken />
            <button type="submit" title="@L["Nav_Logout_Tooltip"]" style="background:#334155;color:#fff;border:0;padding:.4rem .8rem;border-radius:4px;">@L["Nav_Logout"]</button>
        </form>
    </nav>
    <main style="flex:1; padding:2rem; background:#f8fafc;">@Body</main>
</div>
