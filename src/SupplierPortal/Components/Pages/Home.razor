@page "/"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L
@inject SupplierGatewayClient Gateway
@rendermode InteractiveServer

<PageTitle>@L["Home_Title"] — @L["App_Title"]</PageTitle>

<h1>@L["Home_Title"]</h1>
<p>@L["Home_Intro"]</p>

<div style="margin:1rem 0;padding:1rem;background:#fff;border:1px solid #e5e7eb;border-radius:8px;">
    <label title="@L["Common_EntityId_Tooltip"]">
        @L["Common_EntityId"]
        <input @bind="entityId" title="@L["Common_EntityId_Tooltip"]" style="width:28rem;margin-left:.5rem;" />
    </label>
    <button @onclick="LoadReadinessAsync" title="@L["Home_CheckReadiness_Tooltip"]" style="margin-left:.5rem;">@L["Home_CheckReadiness"]</button>
</div>

@if (readiness is not null)
{
    <section style="padding:1rem;background:#fff;border:1px solid #e5e7eb;border-radius:8px;">
        <h2>@L["Home_Readiness"]</h2>
        @if (readiness.IsReady)
        {
            <p style="color:#047857;">@L["Home_Ready"]</p>
        }
        else
        {
            <p style="color:#b45309;">@L["Home_Missing"]</p>
            <ul>
                @foreach (var item in readiness.MissingRequirements)
                {
                    <li>@item</li>
                }
            </ul>
        }
    </section>
}

@code {
    private string entityId = string.Empty;
    private SupplierReadinessResponse? readiness;

    private async Task LoadReadinessAsync()
    {
        readiness = null;
        if (!Guid.TryParse(entityId, out _))
        {
            readiness = new SupplierReadinessResponse(false, [L["Validation_EntityId_Guid"]]);
            return;
        }

        // Requirement text inside a successful response is produced by the Entity service and is
        // rendered as-is; only the portal's own messages are localized here.
        readiness = await Gateway.GetAsync<SupplierReadinessResponse>($"/api/entity/entities/{entityId}/suppliers/readiness")
            ?? new SupplierReadinessResponse(false, [L["Home_LoadFailed"]]);
    }

    private sealed record SupplierReadinessResponse(bool IsReady, IReadOnlyList<string> MissingRequirements);
}
