@* lang reflects the session culture; the page <title> comes from each page's localized
   <PageTitle> via HeadOutlet (a static <title> here would win over it and never localize). *@
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <HeadOutlet />
</head>
<body style="font-family: system-ui, sans-serif; margin: 0;">
    <Routes />
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
