@page "/entities"
@attribute [Authorize(Roles = "admin")]
@using System.Text.Json
@using System.Net.Http.Json
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["Entities.Title"]</h1>
<p style="color:#6b7280;">@((MarkupString)L["Entities.Intro"].Value)</p>

<div style="display:flex; gap:.5rem; align-items:center; margin-bottom:1rem;">
    <label style="font-size:.85rem;">@L["Entities.Tenant"] <input @bind="_tenantId" style="width:24rem; padding:.3rem; margin-left:.3rem;" title="@L["Entities.Tenant.Tip"]" /></label>
    <button @onclick="LoadAsync" title="@L["Common.Load.Tip"]" style="padding:.35rem .8rem;">@L["Common.Load"]</button>
</div>

@if (_error is not null) { <p style="color:#b91c1c;">@_error</p> }
@if (_info is not null) { <p style="color:#15803d;">@_info</p> }

@if (_editing is not null)
{
    <h2>@L["Entities.EditHeading"]</h2>
    <div style="display:flex; flex-direction:column; gap:.5rem; max-width:30rem;">
        <label>@L["Entities.Field.LegalName"] <input @bind="_editing.LegalName" style="width:100%; padding:.4rem;" title="@L["Entities.Field.LegalName.Tip"]" /></label>
        <label>@L["Entities.Field.TradingName"] <input @bind="_editing.TradingName" style="width:100%; padding:.4rem;" title="@L["Entities.Field.TradingName.Tip"]" /></label>
        <label>@L["Common.Type"] <input value="@TypeName(_editing.Type)" disabled style="width:100%; padding:.4rem; background:#f9fafb;" title="@L["Entities.Field.Type.Tip"]" /></label>
        <div style="display:flex; gap:.5rem;">
            <button @onclick="SaveEntity" disabled="@_saving" title="@L["Common.Save.Tip"]" style="padding:.4rem 1rem; background:#111827; color:#fff; border:0; border-radius:5px;">@(_saving ? L["Common.Saving"] : L["Common.Save"])</button>
            <button @onclick="() => _editing = null" title="@L["Common.Cancel.Tip"]" style="padding:.4rem 1rem;">@L["Common.Cancel"]</button>
        </div>
    </div>
}
else if (_details is not null)
{
    <div style="display:flex; align-items:baseline; gap:1rem;">
        <h2 style="margin:0;">@L["Entities.Details.Heading", _details.DisplayName]</h2>
        <button @onclick="CloseDetails" title="@L["Common.Back.Tip"]">@L["Common.Back"]</button>
    </div>
    <p style="color:#6b7280; font-size:.9rem;">@L["Entities.Details.Intro", TypeName(_details.Type)]</p>

    @* Onboarding readiness: shows exactly which required fields are still missing for this entity's
       supplier onboarding, so the operator can fill them in below rather than hitting a wall on Verify. *@
    <div style="border:1px solid #e5e7eb; border-radius:8px; padding:.8rem; margin:.6rem 0; max-width:60rem; background:@(_detailMissing.Count == 0 ? "#f0fdf4" : "#fffbeb");">
        @if (_detailMissing.Count == 0)
        {
            <strong style="color:#047857;">@L["Entities.Details.Ready"]</strong>
        }
        else
        {
            <strong style="color:#b45309;">@L["Entities.Details.Missing"]</strong>
            <ul style="margin:.3rem 0 0;">
                @foreach (var m in _detailMissing) { <li style="font-size:.85rem;">@m</li> }
            </ul>
        }
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; max-width:60rem;">
        <section style="border:1px solid #e5e7eb; border-radius:8px; padding:1rem;">
            <h3 style="margin-top:0;">@L["Entities.Ident.Heading"]</h3>
            @if (_details.Identifiers.Count == 0) { <p style="color:#9ca3af; font-size:.85rem;">@L["Entities.Ident.None"]</p> }
            else
            {
                <ul style="padding-left:1rem;">
                    @foreach (var i in _details.Identifiers)
                    {
                        <li style="margin:.3rem 0; font-size:.88rem;">
                            <strong>@IdTypeName(i.Type)</strong> <code>@i.Value</code>
                            @if (i.VerificationStatus == VerifiedStatus) { <span style="color:#047857;">✓ @VStatusName(i.VerificationStatus)</span> }
                            else
                            {
                                <span style="color:#b45309;">@VStatusName(i.VerificationStatus)</span>
                                <button @onclick="() => VerifyIdentifier(i.Id)" title="@L["Entities.Ident.Verify.Tip"]" style="font-size:.72rem; margin-left:.3rem;">@L["Entities.Ident.Verify"]</button>
                            }
                        </li>
                    }
                </ul>
            }
            <div style="display:flex; gap:.4rem; margin-top:.5rem;">
                <select @bind="_newIdentType" title="@L["Entities.Ident.Type.Tip"]">
                    <option value="1">@L["Entities.IdType.Abn"]</option>
                    <option value="2">@L["Entities.IdType.Acn"]</option>
                    <option value="3">@L["Entities.IdType.Gst"]</option>
                    <option value="4">@L["Entities.IdType.Other"]</option>
                </select>
                <input @bind="_newIdentValue" placeholder="@L["Entities.Ident.Value"]" title="@L["Entities.Ident.Value.Tip"]" style="flex:1;" />
                <button @onclick="AddIdentifier" title="@L["Entities.Ident.Add.Tip"]">@L["Common.Add"]</button>
            </div>
        </section>

        <section style="border:1px solid #e5e7eb; border-radius:8px; padding:1rem;">
            <h3 style="margin-top:0;">@L["Entities.Contact.Heading"]</h3>
            @if (_details.Contacts.Count == 0) { <p style="color:#9ca3af; font-size:.85rem;">@L["Entities.Contact.None"]</p> }
            else
            {
                <ul style="padding-left:1rem;">
                    @foreach (var c in _details.Contacts)
                    {
                        <li style="margin:.3rem 0; font-size:.88rem;"><strong>@CPurposeName(c.Purpose)</strong> · @CKindName(c.Kind) · @c.Value</li>
                    }
                </ul>
            }
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:.4rem; margin-top:.5rem;">
                <select @bind="_newContactPurpose" title="@L["Entities.Contact.Purpose.Tip"]">
                    <option value="1">@L["Entities.CPurpose.Primary"]</option>
                    <option value="2">@L["Entities.CPurpose.Accounts"]</option>
                    <option value="3">@L["Entities.CPurpose.Operations"]</option>
                    <option value="4">@L["Entities.CPurpose.Support"]</option>
                    <option value="5">@L["Entities.CPurpose.Legal"]</option>
                </select>
                <select @bind="_newContactKind" title="@L["Entities.Contact.Kind.Tip"]">
                    <option value="1">@L["Entities.CKind.Email"]</option>
                    <option value="2">@L["Entities.CKind.Phone"]</option>
                    <option value="3">@L["Entities.CKind.Website"]</option>
                </select>
            </div>
            <div style="display:flex; gap:.4rem; margin-top:.4rem;">
                <input @bind="_newContactValue" placeholder="@L["Entities.Contact.Value"]" title="@L["Entities.Contact.Value.Tip"]" style="flex:1;" />
                <button @onclick="AddContact" title="@L["Entities.Contact.Add.Tip"]">@L["Common.Add"]</button>
            </div>
        </section>
    </div>

    <section style="border:1px solid #e5e7eb; border-radius:8px; padding:1rem; margin-top:1.2rem; max-width:60rem;">
        <h3 style="margin-top:0;">@L["Entities.Addr.Heading"]</h3>
        @if (_details.Addresses.Count == 0) { <p style="color:#9ca3af; font-size:.85rem;">@L["Entities.Addr.None"]</p> }
        else
        {
            <ul style="padding-left:1rem;">
                @foreach (var a in _details.Addresses)
                {
                    <li style="margin:.3rem 0; font-size:.88rem;"><strong>@AddrPurposeName(a.Purpose)</strong> · @a.Line1@(string.IsNullOrEmpty(a.Line2) ? "" : $", {a.Line2}"), @a.City @a.Region @a.Postcode @a.CountryCode</li>
                }
            </ul>
        }
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(9rem,1fr)); gap:.4rem; margin-top:.5rem;">
            <select @bind="_newAddrPurpose" title="@L["Entities.Addr.Purpose.Tip"]">
                <option value="1">@L["Entities.AddrPurpose.RegisteredOffice"]</option>
                <option value="4">@L["Entities.AddrPurpose.Warehouse"]</option>
                <option value="2">@L["Entities.AddrPurpose.Billing"]</option>
                <option value="3">@L["Entities.AddrPurpose.Shipping"]</option>
                <option value="5">@L["Entities.AddrPurpose.Returns"]</option>
                <option value="6">@L["Entities.AddrPurpose.Mailing"]</option>
            </select>
            <input @bind="_newAddr.Line1" placeholder="@L["Entities.Addr.Line1"]" title="@L["Entities.Addr.Line1.Tip"]" />
            <input @bind="_newAddr.Line2" placeholder="@L["Entities.Addr.Line2"]" title="@L["Entities.Addr.Line2.Tip"]" />
            <input @bind="_newAddr.City" placeholder="@L["Entities.Addr.City"]" title="@L["Entities.Addr.City.Tip"]" />
            <input @bind="_newAddr.Region" placeholder="@L["Entities.Addr.Region"]" title="@L["Entities.Addr.Region.Tip"]" />
            <input @bind="_newAddr.Postcode" placeholder="@L["Entities.Addr.Postcode"]" title="@L["Entities.Addr.Postcode.Tip"]" />
            <input @bind="_newAddr.CountryCode" maxlength="2" placeholder="@L["Entities.Addr.Country"]" title="@L["Entities.Addr.Country.Tip"]" />
            <button @onclick="AddAddress" title="@L["Entities.Addr.Add.Tip"]">@L["Common.Add"]</button>
        </div>
    </section>
}
else
{
    <section style="display:grid; grid-template-columns:1.3fr 1fr; gap:2rem;">
        <div>
            <h2>@L["Entities.List"]</h2>
            <label style="font-size:.85rem; display:block; margin-bottom:.5rem;">@L["Entities.SuspendReason"] <input @bind="_suspendReason" style="width:100%; padding:.3rem;" title="@L["Entities.SuspendReason.Tip"]" /></label>
            @if (_entities.Count == 0) { <p style="color:#9ca3af;">@L["Entities.Empty"]</p> }
            else
            {
                <table style="border-collapse:collapse; width:100%; font-size:.9rem;">
                    <thead><tr><th style="text-align:left;">@L["Common.Name"]</th><th>@L["Common.Type"]</th><th>@L["Common.Status"]</th><th>@L["Entities.Col.SupplierActions"]</th></tr></thead>
                    <tbody>
                    @foreach (var e in _entities)
                    {
                        <tr style="border-top:1px solid #e5e7eb;">
                            <td>@e.DisplayName
                                <button @onclick="() => EditEntity(e)" title="@L["Entities.EditSmall.Tip"]" style="font-size:.75rem; margin-left:.3rem;">@L["Entities.EditSmall"]</button>
                                <button @onclick="() => OpenDetails(e.Id)" title="@L["Entities.Details.Tip"]" style="font-size:.75rem; margin-left:.2rem;">@L["Entities.Details"]</button>
                            </td>
                            <td style="text-align:center;">@TypeName(e.Type)</td>
                            <td style="text-align:center;">@StatusName(e.Status)</td>
                            <td style="text-align:right; white-space:nowrap;">
                                <button @onclick='() => Supplier(e.Id, "suppliers")' style="font-size:.75rem;" title="@L["Entities.Action.Onboard.Tip"]">@L["Entities.Action.Onboard"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/submit-verification")' style="font-size:.75rem;" title="@L["Entities.Action.Verify.Tip"]">@L["Entities.Action.Verify"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/verification-complete")' style="font-size:.75rem;" title="@L["Entities.Action.Verified.Tip"]">@L["Entities.Action.Verified"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/activate")' style="font-size:.75rem;" title="@L["Entities.Action.Activate.Tip"]">@L["Entities.Action.Activate"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/suspend")' style="font-size:.75rem;" title="@L["Entities.Action.Suspend.Tip"]">@L["Entities.Action.Suspend"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/archive")' style="font-size:.75rem; color:#b91c1c;" title="@L["Entities.Action.Archive.Tip"]">@L["Entities.Action.Archive"]</button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }

            <h3>@L["Entities.Create"]</h3>
            <div style="display:grid; gap:.4rem; max-width:30rem;">
                <input @bind="_newLegalName" placeholder="@L["Entities.New.LegalName"]" title="@L["Entities.New.LegalName.Tip"]" />
                <input @bind="_newTradingName" placeholder="@L["Entities.New.TradingName"]" title="@L["Entities.New.TradingName.Tip"]" />
                <select @bind="_newType" title="@L["Entities.New.Type.Tip"]">
                    <option value="2">@L["Entities.Type.Company"]</option><option value="1">@L["Entities.Type.NaturalPerson"]</option>
                    <option value="3">@L["Entities.Type.Trust"]</option><option value="4">@L["Entities.Type.Partnership"]</option>
                    <option value="5">@L["Entities.Type.SoleTrader"]</option><option value="6">@L["Entities.Type.GovernmentBody"]</option>
                    <option value="7">@L["Entities.Type.NonProfit"]</option><option value="99">@L["Entities.Type.Other"]</option>
                </select>

                @* Type-aware onboarding prerequisites: filling these creates a supplier-READY entity (a
                   verified ABN/ACN, a primary email, and a registered-office/warehouse address are exactly
                   what verification checks). Left blank, they can still be added later via Details. *@
                @if (_newType != OtherType)
                {
                    <div style="border:1px solid #e5e7eb; border-radius:8px; padding:.7rem; background:#f9fafb;">
                        <div style="font-weight:600; font-size:.85rem;">@L["Entities.Onboard.Heading", TypeName(_newType)]</div>
                        <p style="color:#6b7280; font-size:.78rem; margin:.2rem 0 .5rem;">@L["Entities.Onboard.Note"]</p>
                        <div style="display:flex; gap:.4rem;">
                            <select @bind="_createIdentType" title="@L["Entities.Ident.Type.Tip"]" style="width:9rem;">
                                <option value="1">@L["Entities.IdType.Abn"]</option>
                                <option value="2">@L["Entities.IdType.Acn"]</option>
                                <option value="3">@L["Entities.IdType.Gst"]</option>
                                <option value="4">@L["Entities.IdType.Other"]</option>
                            </select>
                            <input @bind="_createIdentValue" placeholder="@L["Entities.Ident.Value"]" title="@L["Entities.Ident.Value.Tip"]" style="flex:1;" />
                        </div>
                        <input @bind="_createEmail" type="email" placeholder="@L["Entities.Onboard.Email"]" title="@L["Entities.Onboard.Email.Tip"]" style="margin-top:.4rem; width:100%;" />
                        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(8rem,1fr)); gap:.4rem; margin-top:.4rem;">
                            <input @bind="_createAddr.Line1" placeholder="@L["Entities.Addr.Line1"]" title="@L["Entities.Addr.Line1.Tip"]" />
                            <input @bind="_createAddr.City" placeholder="@L["Entities.Addr.City"]" title="@L["Entities.Addr.City.Tip"]" />
                            <input @bind="_createAddr.Postcode" placeholder="@L["Entities.Addr.Postcode"]" title="@L["Entities.Addr.Postcode.Tip"]" />
                            <input @bind="_createAddr.CountryCode" maxlength="2" placeholder="@L["Entities.Addr.Country"]" title="@L["Entities.Addr.Country.Tip"]" />
                        </div>
                    </div>
                }

                <button @onclick="CreateAsync" title="@L["Entities.Create.Tip"]" style="padding:.4rem; background:#111827; color:#fff; border:0; border-radius:5px;">@L["Common.Create"]</button>
            </div>
        </div>

        <div>
            <h2>@L["Entities.Requests"]</h2>
            <label style="font-size:.85rem;">@L["Entities.DecisionReason"] <input @bind="_decisionReason" style="width:100%; padding:.3rem;" placeholder="@L["Entities.DecisionReason.Placeholder"]" title="@L["Entities.DecisionReason.Tip"]" /></label>
            @if (_requests.Count == 0) { <p style="color:#9ca3af; margin-top:.5rem;">@L["Entities.NoRequests"]</p> }
            else
            {
                @foreach (var r in _requests)
                {
                    <div style="border:1px solid #e5e7eb; border-radius:8px; padding:.7rem; margin-top:.6rem;">
                        <div style="display:flex; justify-content:space-between;">
                            <strong>@ChangeTypeName(r.Type)</strong>
                            <span style="font-size:.75rem; color:#6b7280;">@r.CreatedAt.LocalDateTime.ToString("dd MMM HH:mm")</span>
                        </div>
                        <div style="font-size:.9rem; margin:.2rem 0;">@r.Summary</div>
                        @if (!string.IsNullOrWhiteSpace(r.Detail)) { <div style="font-size:.82rem; color:#4b5563;">@r.Detail</div> }
                        <div style="font-size:.75rem; color:#9ca3af;">@L["Entities.RequestedBy", r.RequestedByPrincipalId.ToString()[..8]]</div>
                        @{ var mine = _myPrincipalId is not null && r.RequestedByPrincipalId == _myPrincipalId; }
                        @if (mine)
                        {
                            <div style="font-size:.78rem; color:#92400e; margin-top:.3rem;">@L["Entities.MakerChecker"]</div>
                        }
                        <div style="margin-top:.4rem; display:flex; gap:.4rem;">
                            <button @onclick='() => DecideAsync(r.Id, "approve")' disabled="@mine" title="@(mine ? L["Entities.Approve.OwnTip"] : L["Entities.Approve.Tip"])" style="padding:.25rem .7rem; background:@(mine ? "#9ca3af" : "#047857"); color:#fff; border:0; border-radius:4px;">@L["Entities.Approve"]</button>
                            <button @onclick='() => DecideAsync(r.Id, "reject")' disabled="@mine" title="@(mine ? L["Entities.Reject.OwnTip"] : L["Entities.Reject.Tip"])" style="padding:.25rem .7rem; background:@(mine ? "#9ca3af" : "#b91c1c"); color:#fff; border:0; border-radius:4px;">@L["Entities.Reject"]</button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
}

@code {
    private string _tenantId = "00000000-0000-0000-0000-000000000001";
    private string? _error;
    private string? _info;
    private bool _saving;
    private List<EntitySummary> _entities = [];
    private List<ChangeRequest> _requests = [];
    private string _newLegalName = string.Empty;
    private string _newTradingName = string.Empty;
    private int _newType = 2;
    private const int OtherType = 99; // EntityType.Other — not supplier-capable, so no onboarding fields
    // Inline onboarding prerequisites captured on the create form (added to the entity right after create).
    private int _createIdentType = 1; // ABN
    private string _createIdentValue = string.Empty;
    private string _createEmail = string.Empty;
    private readonly AddressForm _createAddr = new();
    private string _decisionReason = string.Empty;
    private string _suspendReason = "Suspended by operator via admin.";
    private EntityEditor? _editing;
    private Guid? _myPrincipalId;

    // Details / onboarding-fields editor (identifiers, contacts, addresses) for the selected entity.
    private const int VerifiedStatus = 3; // EntityVerificationStatus.Verified
    private EntityDetail? _details;
    private List<string> _detailMissing = [];
    private int _newIdentType = 1;
    private string _newIdentValue = string.Empty;
    private int _newContactPurpose = 1;
    private int _newContactKind = 1;
    private string _newContactValue = string.Empty;
    private int _newAddrPurpose = 1;
    private readonly AddressForm _newAddr = new();

    protected override async Task OnInitializedAsync()
    {
        // Who am I? Needed to pre-empt maker-checker: the requester of a change request
        // cannot also decide it, so their own requests render with disabled decision buttons.
        var me = await Gateway.GetAsync<MeResponse>("/api/identity/me");
        _myPrincipalId = me?.Id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        // NB: does not clear _error/_info — mutation handlers set their result right before
        // calling LoadAsync to refresh, and clearing here would wipe that feedback.
        if (!Guid.TryParse(_tenantId, out _))
        {
            _error = L["Entities.Error.TenantGuid"];
            return;
        }

        _entities = await Gateway.GetListAsync<EntitySummary>($"/api/entity/entities?tenantId={_tenantId}");
        _requests = await Gateway.GetListAsync<ChangeRequest>($"/api/entity/entities/suppliers/change-requests?tenantId={_tenantId}&status=Pending");
    }

    private void EditEntity(EntitySummary e) => _editing = new EntityEditor { Id = e.Id, LegalName = e.LegalName, TradingName = e.TradingName, Type = e.Type };

    private async Task SaveEntity()
    {
        _error = _info = null;
        _saving = true;
        try
        {
            var response = await Gateway.PutAsync($"/api/entity/entities/{_editing!.Id}",
                new { legalName = _editing.LegalName, tradingName = string.IsNullOrWhiteSpace(_editing.TradingName) ? null : _editing.TradingName });
            if (response.IsSuccessStatusCode)
            {
                _info = L["Entities.Info.Updated"];
                _editing = null;
                await LoadAsync();
            }
            else
            {
                _error = L["Entities.Error.UpdateFailed", await GatewayError.ReadAsync(response)];
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CreateAsync()
    {
        _error = _info = null;
        if (!Guid.TryParse(_tenantId, out var tid))
        {
            _error = L["Entities.Error.TenantGuid"];
            return;
        }

        var legalName = _newLegalName;
        var response = await Gateway.PostAsync("/api/entity/entities",
            new { tenantId = tid, type = _newType, legalName = _newLegalName, tradingName = string.IsNullOrWhiteSpace(_newTradingName) ? null : _newTradingName });
        if (!response.IsSuccessStatusCode)
        {
            _error = L["Entities.Error.CreateFailed", (int)response.StatusCode];
            return;
        }

        var created = await response.Content.ReadFromJsonAsync<EntitySummary>();
        // Attach the onboarding prerequisites the operator supplied, so a supplier-capable entity is
        // created verification-ready in one step (identifier is auto-verified — operator attestation).
        if (created is not null && _newType != OtherType)
        {
            await AttachOnboardingDetailsAsync(created.Id);
        }

        _info = L["Entities.Info.Created", legalName];
        _newLegalName = _newTradingName = _createIdentValue = _createEmail = string.Empty;
        _createIdentType = 1;
        _createAddr.Reset();
        await LoadAsync();
    }

    private async Task AttachOnboardingDetailsAsync(Guid entityId)
    {
        if (!string.IsNullOrWhiteSpace(_createIdentValue))
        {
            var idResp = await Gateway.PostAsync($"/api/entity/entities/{entityId}/identifiers",
                new { type = _createIdentType, value = _createIdentValue.Trim() });
            if (idResp.IsSuccessStatusCode)
            {
                var detail = await idResp.Content.ReadFromJsonAsync<EntityDetail>();
                var added = detail?.Identifiers.FirstOrDefault(i => i.Type == _createIdentType);
                if (added is not null)
                {
                    await Gateway.PostAsync($"/api/entity/entities/{entityId}/identifiers/{added.Id}/verify", new { });
                }
            }
        }

        if (!string.IsNullOrWhiteSpace(_createEmail))
        {
            await Gateway.PostAsync($"/api/entity/entities/{entityId}/contacts",
                new { purpose = 1, kind = 1, value = _createEmail.Trim() }); // Primary / Email
        }

        if (!string.IsNullOrWhiteSpace(_createAddr.Line1) && !string.IsNullOrWhiteSpace(_createAddr.City))
        {
            await Gateway.PostAsync($"/api/entity/entities/{entityId}/addresses", new
            {
                purpose = 1, // RegisteredOffice
                line1 = _createAddr.Line1.Trim(),
                line2 = string.IsNullOrWhiteSpace(_createAddr.Line2) ? null : _createAddr.Line2!.Trim(),
                city = _createAddr.City.Trim(),
                region = string.IsNullOrWhiteSpace(_createAddr.Region) ? null : _createAddr.Region!.Trim(),
                postcode = _createAddr.Postcode.Trim(),
                countryCode = _createAddr.CountryCode.Trim(),
            });
        }
    }

    private async Task Supplier(Guid entityId, string action)
    {
        _error = _info = null;
        // The suspend endpoint requires a SuspendSupplierRequest body (Reason, 8-500 chars);
        // the other transitions take no body. Sending an empty body to suspend 500s.
        object? body = null;
        if (action.EndsWith("suspend", StringComparison.Ordinal))
        {
            var reason = string.IsNullOrWhiteSpace(_suspendReason) ? "Suspended by operator via admin." : _suspendReason.Trim();
            if (reason.Length < 8)
            {
                _error = L["Entities.Error.SuspendReason"];
                return;
            }

            body = new { reason };
        }

        var response = await Gateway.PostAsync($"/api/entity/entities/{entityId}/{action}", body);
        if (response.IsSuccessStatusCode) { _info = L["Entities.Info.SupplierOk", action.Split('/').Last()]; }
        else { _error = L["Entities.Error.ActionFailed", await ReadFailureAsync(response)]; }
        await LoadAsync();
    }

    // Unwrap a ValidationProblem's `errors` values (the actual reason, e.g. "Only active suppliers
    // can be suspended.") — the envelope's generic title makes by-design refusals look like dead buttons.
    private static async Task<string> ReadFailureAsync(HttpResponseMessage response)
    {
        var raw = await response.Content.ReadAsStringAsync();
        try
        {
            using var doc = JsonDocument.Parse(raw);
            if (doc.RootElement.ValueKind == JsonValueKind.Object
                && doc.RootElement.TryGetProperty("errors", out var errors)
                && errors.ValueKind == JsonValueKind.Object)
            {
                var messages = errors.EnumerateObject()
                    .Where(p => p.Value.ValueKind == JsonValueKind.Array)
                    .SelectMany(p => p.Value.EnumerateArray())
                    .Where(v => v.ValueKind == JsonValueKind.String)
                    .Select(v => v.GetString()!)
                    .Where(m => !string.IsNullOrWhiteSpace(m))
                    .ToList();
                if (messages.Count > 0)
                {
                    return string.Join(" ", messages);
                }
            }
        }
        catch (JsonException)
        {
            // Not JSON — fall through to the shared humanizer.
        }

        return GatewayError.Humanize(raw);
    }

    private async Task DecideAsync(Guid requestId, string decision)
    {
        _error = _info = null;
        var reason = string.IsNullOrWhiteSpace(_decisionReason) ? null : _decisionReason.Trim();

        // The reject contract (RejectSupplierChangeRequestBody) requires a Reason of 8–500 chars;
        // approve takes an optional reason. Validate up-front so the operator gets a local hint
        // instead of a 400 from the service.
        if (decision == "reject" && (reason is null || reason.Length < 8))
        {
            _error = L["Entities.Error.RejectReason"];
            return;
        }

        if (reason is { Length: > 500 })
        {
            _error = L["Entities.Error.ReasonTooLong"];
            return;
        }

        var response = await Gateway.PostAsync($"/api/entity/entities/suppliers/change-requests/{requestId}/{decision}?tenantId={_tenantId}",
            new { reason });
        if (response.IsSuccessStatusCode)
        {
            _info = decision == "approve" ? L["Entities.Info.Approved"] : L["Entities.Info.Rejected"];
            _decisionReason = string.Empty;
            await LoadAsync();
        }
        else
        {
            _error = L["Entities.Error.DecisionFailed", decision, await ReadFailureAsync(response)];
        }
    }

    private async Task OpenDetails(Guid id)
    {
        _error = _info = null;
        _editing = null;
        _details = await Gateway.GetAsync<EntityDetail>($"/api/entity/entities/{id}");
        await RefreshReadiness(id);
    }

    private void CloseDetails() { _details = null; _detailMissing = []; }

    private async Task RefreshReadiness(Guid id)
    {
        var readiness = await Gateway.GetAsync<ReadinessDto>($"/api/entity/entities/{id}/suppliers/readiness");
        _detailMissing = readiness?.MissingRequirements ?? [];
    }

    private async Task ReloadDetails()
    {
        if (_details is null) { return; }
        var id = _details.Id;
        _details = await Gateway.GetAsync<EntityDetail>($"/api/entity/entities/{id}");
        await RefreshReadiness(id);
    }

    private async Task PostDetail(string path, object body, string okKey)
    {
        _error = _info = null;
        var response = await Gateway.PostAsync(path, body);
        if (response.IsSuccessStatusCode) { _info = L[okKey]; await ReloadDetails(); }
        else { _error = L["Entities.Error.ActionFailed", await ReadFailureAsync(response)]; }
    }

    private async Task AddIdentifier()
    {
        if (_details is null || string.IsNullOrWhiteSpace(_newIdentValue)) { return; }
        await PostDetail($"/api/entity/entities/{_details.Id}/identifiers", new { type = _newIdentType, value = _newIdentValue.Trim() }, "Entities.Info.IdentifierAdded");
        _newIdentValue = string.Empty;
    }

    private Task VerifyIdentifier(Guid identifierId) =>
        _details is null ? Task.CompletedTask
            : PostDetail($"/api/entity/entities/{_details.Id}/identifiers/{identifierId}/verify", new { }, "Entities.Info.IdentifierVerified");

    private async Task AddContact()
    {
        if (_details is null || string.IsNullOrWhiteSpace(_newContactValue)) { return; }
        await PostDetail($"/api/entity/entities/{_details.Id}/contacts", new { purpose = _newContactPurpose, kind = _newContactKind, value = _newContactValue.Trim() }, "Entities.Info.ContactAdded");
        _newContactValue = string.Empty;
    }

    private async Task AddAddress()
    {
        if (_details is null) { return; }
        var body = new
        {
            purpose = _newAddrPurpose,
            line1 = _newAddr.Line1.Trim(),
            line2 = string.IsNullOrWhiteSpace(_newAddr.Line2) ? null : _newAddr.Line2.Trim(),
            city = _newAddr.City.Trim(),
            region = string.IsNullOrWhiteSpace(_newAddr.Region) ? null : _newAddr.Region.Trim(),
            postcode = _newAddr.Postcode.Trim(),
            countryCode = _newAddr.CountryCode.Trim(),
        };
        await PostDetail($"/api/entity/entities/{_details.Id}/addresses", body, "Entities.Info.AddressAdded");
        _newAddr.Reset();
    }

    private string IdTypeName(int t) => t switch { 1 => L["Entities.IdType.Abn"], 2 => L["Entities.IdType.Acn"], 3 => L["Entities.IdType.Gst"], _ => L["Entities.IdType.Other"] };
    private string VStatusName(int s) => s switch { 3 => L["Entities.VStatus.Verified"], 2 => L["Entities.VStatus.Pending"], 4 => L["Entities.VStatus.Failed"], _ => L["Entities.VStatus.Unverified"] };
    private string CPurposeName(int p) => p switch { 1 => L["Entities.CPurpose.Primary"], 2 => L["Entities.CPurpose.Accounts"], 3 => L["Entities.CPurpose.Operations"], 4 => L["Entities.CPurpose.Support"], _ => L["Entities.CPurpose.Legal"] };
    private string CKindName(int k) => k switch { 1 => L["Entities.CKind.Email"], 2 => L["Entities.CKind.Phone"], _ => L["Entities.CKind.Website"] };
    private string AddrPurposeName(int p) => p switch { 1 => L["Entities.AddrPurpose.RegisteredOffice"], 2 => L["Entities.AddrPurpose.Billing"], 3 => L["Entities.AddrPurpose.Shipping"], 4 => L["Entities.AddrPurpose.Warehouse"], 5 => L["Entities.AddrPurpose.Returns"], _ => L["Entities.AddrPurpose.Mailing"] };

    private string TypeName(int t) => t switch { 1 => L["Entities.Type.NaturalPerson"], 2 => L["Entities.Type.Company"], 3 => L["Entities.Type.Trust"], 4 => L["Entities.Type.Partnership"], 5 => L["Entities.Type.SoleTrader"], 6 => L["Entities.Type.GovernmentBody"], 7 => L["Entities.Type.NonProfit"], _ => L["Entities.Type.Other"] };
    private string StatusName(int s) => s switch { 1 => L["Entities.Status.Active"], 2 => L["Entities.Status.Inactive"], 3 => L["Entities.Status.Archived"], _ => s.ToString() };
    private string ChangeTypeName(int t) => t switch { 1 => L["Entities.ChangeType.UserAccess"], 2 => L["Entities.ChangeType.Contact"], 3 => L["Entities.ChangeType.BankAccount"], _ => L["Entities.ChangeType.Other", t] };

