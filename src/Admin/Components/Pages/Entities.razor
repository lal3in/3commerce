    }

    // Enums arrive numeric on the wire (platform invariant), so the detail DTOs type them as int.
    private sealed record EntityDetail(Guid Id, Guid TenantId, int Type, string LegalName, string? TradingName, string DisplayName, int Status,
        List<IdentifierDto> Identifiers, List<ContactDto> Contacts, List<AddressDto> Addresses);
