@page "/entities"
@attribute [Authorize(Roles = "admin")]
@using System.Text.Json
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["Entities.Title"]</h1>
<p style="color:#6b7280;">@((MarkupString)L["Entities.Intro"].Value)</p>

<div style="display:flex; gap:.5rem; align-items:center; margin-bottom:1rem;">
    <label style="font-size:.85rem;">@L["Entities.Tenant"] <input @bind="_tenantId" style="width:24rem; padding:.3rem; margin-left:.3rem;" title="@L["Entities.Tenant.Tip"]" /></label>
    <button @onclick="LoadAsync" title="@L["Common.Load.Tip"]" style="padding:.35rem .8rem;">@L["Common.Load"]</button>
</div>

@if (_error is not null) { <p style="color:#b91c1c;">@_error</p> }
@if (_info is not null) { <p style="color:#15803d;">@_info</p> }

@if (_editing is not null)
{
    <h2>@L["Entities.EditHeading"]</h2>
    <div style="display:flex; flex-direction:column; gap:.5rem; max-width:30rem;">
        <label>@L["Entities.Field.LegalName"] <input @bind="_editing.LegalName" style="width:100%; padding:.4rem;" title="@L["Entities.Field.LegalName.Tip"]" /></label>
        <label>@L["Entities.Field.TradingName"] <input @bind="_editing.TradingName" style="width:100%; padding:.4rem;" title="@L["Entities.Field.TradingName.Tip"]" /></label>
        <label>@L["Common.Type"] <input value="@TypeName(_editing.Type)" disabled style="width:100%; padding:.4rem; background:#f9fafb;" title="@L["Entities.Field.Type.Tip"]" /></label>
        <div style="display:flex; gap:.5rem;">
            <button @onclick="SaveEntity" disabled="@_saving" title="@L["Common.Save.Tip"]" style="padding:.4rem 1rem; background:#111827; color:#fff; border:0; border-radius:5px;">@(_saving ? L["Common.Saving"] : L["Common.Save"])</button>
            <button @onclick="() => _editing = null" title="@L["Common.Cancel.Tip"]" style="padding:.4rem 1rem;">@L["Common.Cancel"]</button>
        </div>
    </div>
}
else
{
    <section style="display:grid; grid-template-columns:1.3fr 1fr; gap:2rem;">
        <div>
            <h2>@L["Entities.List"]</h2>
            <label style="font-size:.85rem; display:block; margin-bottom:.5rem;">@L["Entities.SuspendReason"] <input @bind="_suspendReason" style="width:100%; padding:.3rem;" title="@L["Entities.SuspendReason.Tip"]" /></label>
            @if (_entities.Count == 0) { <p style="color:#9ca3af;">@L["Entities.Empty"]</p> }
            else
            {
                <table style="border-collapse:collapse; width:100%; font-size:.9rem;">
                    <thead><tr><th style="text-align:left;">@L["Common.Name"]</th><th>@L["Common.Type"]</th><th>@L["Common.Status"]</th><th>@L["Entities.Col.SupplierActions"]</th></tr></thead>
                    <tbody>
                    @foreach (var e in _entities)
                    {
                        <tr style="border-top:1px solid #e5e7eb;">
                            <td>@e.DisplayName <button @onclick="() => EditEntity(e)" title="@L["Entities.EditSmall.Tip"]" style="font-size:.75rem; margin-left:.3rem;">@L["Entities.EditSmall"]</button></td>
                            <td style="text-align:center;">@TypeName(e.Type)</td>
                            <td style="text-align:center;">@StatusName(e.Status)</td>
                            <td style="text-align:right; white-space:nowrap;">
                                <button @onclick='() => Supplier(e.Id, "suppliers")' style="font-size:.75rem;" title="@L["Entities.Action.Onboard.Tip"]">@L["Entities.Action.Onboard"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/submit-verification")' style="font-size:.75rem;" title="@L["Entities.Action.Verify.Tip"]">@L["Entities.Action.Verify"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/verification-complete")' style="font-size:.75rem;" title="@L["Entities.Action.Verified.Tip"]">@L["Entities.Action.Verified"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/activate")' style="font-size:.75rem;" title="@L["Entities.Action.Activate.Tip"]">@L["Entities.Action.Activate"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/suspend")' style="font-size:.75rem;" title="@L["Entities.Action.Suspend.Tip"]">@L["Entities.Action.Suspend"]</button>
                                <button @onclick='() => Supplier(e.Id, "suppliers/archive")' style="font-size:.75rem; color:#b91c1c;" title="@L["Entities.Action.Archive.Tip"]">@L["Entities.Action.Archive"]</button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }

            <h3>@L["Entities.Create"]</h3>
            <div style="display:grid; gap:.4rem; max-width:28rem;">
                <input @bind="_newLegalName" placeholder="@L["Entities.New.LegalName"]" title="@L["Entities.New.LegalName.Tip"]" />
                <input @bind="_newTradingName" placeholder="@L["Entities.New.TradingName"]" title="@L["Entities.New.TradingName.Tip"]" />
                <select @bind="_newType" title="@L["Entities.New.Type.Tip"]">
                    <option value="2">@L["Entities.Type.Company"]</option><option value="1">@L["Entities.Type.NaturalPerson"]</option>
                    <option value="3">@L["Entities.Type.Trust"]</option><option value="4">@L["Entities.Type.Partnership"]</option>
                    <option value="5">@L["Entities.Type.SoleTrader"]</option><option value="6">@L["Entities.Type.GovernmentBody"]</option>
                    <option value="7">@L["Entities.Type.NonProfit"]</option><option value="99">@L["Entities.Type.Other"]</option>
                </select>
                <button @onclick="CreateAsync" title="@L["Entities.Create.Tip"]" style="padding:.4rem; background:#111827; color:#fff; border:0; border-radius:5px;">@L["Common.Create"]</button>
            </div>
        </div>

        <div>
            <h2>@L["Entities.Requests"]</h2>
            <label style="font-size:.85rem;">@L["Entities.DecisionReason"] <input @bind="_decisionReason" style="width:100%; padding:.3rem;" placeholder="@L["Entities.DecisionReason.Placeholder"]" title="@L["Entities.DecisionReason.Tip"]" /></label>
            @if (_requests.Count == 0) { <p style="color:#9ca3af; margin-top:.5rem;">@L["Entities.NoRequests"]</p> }
            else
            {
                @foreach (var r in _requests)
                {
                    <div style="border:1px solid #e5e7eb; border-radius:8px; padding:.7rem; margin-top:.6rem;">
                        <div style="display:flex; justify-content:space-between;">
                            <strong>@ChangeTypeName(r.Type)</strong>
                            <span style="font-size:.75rem; color:#6b7280;">@r.CreatedAt.LocalDateTime.ToString("dd MMM HH:mm")</span>
                        </div>
                        <div style="font-size:.9rem; margin:.2rem 0;">@r.Summary</div>
                        @if (!string.IsNullOrWhiteSpace(r.Detail)) { <div style="font-size:.82rem; color:#4b5563;">@r.Detail</div> }
                        <div style="font-size:.75rem; color:#9ca3af;">@L["Entities.RequestedBy", r.RequestedByPrincipalId.ToString()[..8]]</div>
                        @{ var mine = _myPrincipalId is not null && r.RequestedByPrincipalId == _myPrincipalId; }
                        @if (mine)
                        {
                            <div style="font-size:.78rem; color:#92400e; margin-top:.3rem;">@L["Entities.MakerChecker"]</div>
                        }
                        <div style="margin-top:.4rem; display:flex; gap:.4rem;">
                            <button @onclick='() => DecideAsync(r.Id, "approve")' disabled="@mine" title="@(mine ? L["Entities.Approve.OwnTip"] : L["Entities.Approve.Tip"])" style="padding:.25rem .7rem; background:@(mine ? "#9ca3af" : "#047857"); color:#fff; border:0; border-radius:4px;">@L["Entities.Approve"]</button>
                            <button @onclick='() => DecideAsync(r.Id, "reject")' disabled="@mine" title="@(mine ? L["Entities.Reject.OwnTip"] : L["Entities.Reject.Tip"])" style="padding:.25rem .7rem; background:@(mine ? "#9ca3af" : "#b91c1c"); color:#fff; border:0; border-radius:4px;">@L["Entities.Reject"]</button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
}

@code {
    private string _tenantId = "00000000-0000-0000-0000-000000000001";
    private string? _error;
    private string? _info;
    private bool _saving;
    private List<EntitySummary> _entities = [];
    private List<ChangeRequest> _requests = [];
    private string _newLegalName = string.Empty;
    private string _newTradingName = string.Empty;
    private int _newType = 2;
    private string _decisionReason = string.Empty;
    private string _suspendReason = "Suspended by operator via admin.";
    private EntityEditor? _editing;
    private Guid? _myPrincipalId;

    protected override async Task OnInitializedAsync()
    {
        // Who am I? Needed to pre-empt maker-checker: the requester of a change request
        // cannot also decide it, so their own requests render with disabled decision buttons.
        var me = await Gateway.GetAsync<MeResponse>("/api/identity/me");
        _myPrincipalId = me?.Id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        // NB: does not clear _error/_info — mutation handlers set their result right before
        // calling LoadAsync to refresh, and clearing here would wipe that feedback.
        if (!Guid.TryParse(_tenantId, out _))
        {
            _error = L["Entities.Error.TenantGuid"];
            return;
        }

        _entities = await Gateway.GetListAsync<EntitySummary>($"/api/entity/entities?tenantId={_tenantId}");
        _requests = await Gateway.GetListAsync<ChangeRequest>($"/api/entity/entities/suppliers/change-requests?tenantId={_tenantId}&status=Pending");
    }

    private void EditEntity(EntitySummary e) => _editing = new EntityEditor { Id = e.Id, LegalName = e.LegalName, TradingName = e.TradingName, Type = e.Type };

    private async Task SaveEntity()
    {
        _error = _info = null;
        _saving = true;
        try
        {
            var response = await Gateway.PutAsync($"/api/entity/entities/{_editing!.Id}",
                new { legalName = _editing.LegalName, tradingName = string.IsNullOrWhiteSpace(_editing.TradingName) ? null : _editing.TradingName });
            if (response.IsSuccessStatusCode)
            {
                _info = L["Entities.Info.Updated"];
                _editing = null;
                await LoadAsync();
            }
            else
            {
                _error = L["Entities.Error.UpdateFailed", await GatewayError.ReadAsync(response)];
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CreateAsync()
    {
        _error = _info = null;
        if (!Guid.TryParse(_tenantId, out var tid))
        {
            _error = L["Entities.Error.TenantGuid"];
            return;
        }

        var response = await Gateway.PostAsync("/api/entity/entities",
            new { tenantId = tid, type = _newType, legalName = _newLegalName, tradingName = string.IsNullOrWhiteSpace(_newTradingName) ? null : _newTradingName });
        if (response.IsSuccessStatusCode)
        {
            _info = L["Entities.Info.Created", _newLegalName];
            _newLegalName = _newTradingName = string.Empty;
            await LoadAsync();
        }
        else
        {
            _error = L["Entities.Error.CreateFailed", (int)response.StatusCode];
        }
    }

    private async Task Supplier(Guid entityId, string action)
    {
        _error = _info = null;
        // The suspend endpoint requires a SuspendSupplierRequest body (Reason, 8-500 chars);
        // the other transitions take no body. Sending an empty body to suspend 500s.
        object? body = null;
        if (action.EndsWith("suspend", StringComparison.Ordinal))
        {
            var reason = string.IsNullOrWhiteSpace(_suspendReason) ? "Suspended by operator via admin." : _suspendReason.Trim();
            if (reason.Length < 8)
            {
                _error = L["Entities.Error.SuspendReason"];
                return;
            }

            body = new { reason };
        }

        var response = await Gateway.PostAsync($"/api/entity/entities/{entityId}/{action}", body);
        if (response.IsSuccessStatusCode) { _info = L["Entities.Info.SupplierOk", action.Split('/').Last()]; }
        else { _error = L["Entities.Error.ActionFailed", await ReadFailureAsync(response)]; }
        await LoadAsync();
    }

    // Unwrap a ValidationProblem's `errors` values (the actual reason, e.g. "Only active suppliers
    // can be suspended.") — the envelope's generic title makes by-design refusals look like dead buttons.
    private static async Task<string> ReadFailureAsync(HttpResponseMessage response)
    {
        var raw = await response.Content.ReadAsStringAsync();
        try
        {
            using var doc = JsonDocument.Parse(raw);
            if (doc.RootElement.ValueKind == JsonValueKind.Object
                && doc.RootElement.TryGetProperty("errors", out var errors)
                && errors.ValueKind == JsonValueKind.Object)
            {
                var messages = errors.EnumerateObject()
                    .Where(p => p.Value.ValueKind == JsonValueKind.Array)
                    .SelectMany(p => p.Value.EnumerateArray())
                    .Where(v => v.ValueKind == JsonValueKind.String)
                    .Select(v => v.GetString()!)
                    .Where(m => !string.IsNullOrWhiteSpace(m))
                    .ToList();
                if (messages.Count > 0)
                {
                    return string.Join(" ", messages);
                }
            }
        }
        catch (JsonException)
        {
            // Not JSON — fall through to the shared humanizer.
        }

        return GatewayError.Humanize(raw);
    }

    private async Task DecideAsync(Guid requestId, string decision)
    {
        _error = _info = null;
        var reason = string.IsNullOrWhiteSpace(_decisionReason) ? null : _decisionReason.Trim();

        // The reject contract (RejectSupplierChangeRequestBody) requires a Reason of 8–500 chars;
        // approve takes an optional reason. Validate up-front so the operator gets a local hint
        // instead of a 400 from the service.
        if (decision == "reject" && (reason is null || reason.Length < 8))
        {
            _error = L["Entities.Error.RejectReason"];
            return;
        }

        if (reason is { Length: > 500 })
        {
            _error = L["Entities.Error.ReasonTooLong"];
            return;
        }

        var response = await Gateway.PostAsync($"/api/entity/entities/suppliers/change-requests/{requestId}/{decision}?tenantId={_tenantId}",
            new { reason });
        if (response.IsSuccessStatusCode)
        {
            _info = decision == "approve" ? L["Entities.Info.Approved"] : L["Entities.Info.Rejected"];
            _decisionReason = string.Empty;
            await LoadAsync();
        }
        else
        {
            _error = L["Entities.Error.DecisionFailed", decision, await ReadFailureAsync(response)];
        }
    }

    private string TypeName(int t) => t switch { 1 => L["Entities.Type.NaturalPerson"], 2 => L["Entities.Type.Company"], 3 => L["Entities.Type.Trust"], 4 => L["Entities.Type.Partnership"], 5 => L["Entities.Type.SoleTrader"], 6 => L["Entities.Type.GovernmentBody"], 7 => L["Entities.Type.NonProfit"], _ => L["Entities.Type.Other"] };
    private string StatusName(int s) => s switch { 1 => L["Entities.Status.Active"], 2 => L["Entities.Status.Inactive"], 3 => L["Entities.Status.Archived"], _ => s.ToString() };
    private string ChangeTypeName(int t) => t switch { 1 => L["Entities.ChangeType.UserAccess"], 2 => L["Entities.ChangeType.Contact"], 3 => L["Entities.ChangeType.BankAccount"], _ => L["Entities.ChangeType.Other", t] };

    private sealed record EntitySummary(Guid Id, Guid TenantId, int Type, string LegalName, string? TradingName, string DisplayName, int Status, DateTimeOffset CreatedAt, DateTimeOffset UpdatedAt);
    private sealed record MeResponse(Guid Id, string Email);
    private sealed record ChangeRequest(Guid Id, Guid TenantId, Guid EntityId, int Type, string Summary, string? Detail, int Status, Guid RequestedByPrincipalId, DateTimeOffset CreatedAt, Guid? DecidedByPrincipalId, string? DecisionReason, DateTimeOffset? DecidedAt);

    private sealed class EntityEditor
    {
        public Guid Id { get; set; }
        public string LegalName { get; set; } = string.Empty;
        public string? TradingName { get; set; }
        public int Type { get; set; }
    }
}
