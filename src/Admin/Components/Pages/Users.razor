@page "/users"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender
@using System.Net.Http.Json

<div style="display:flex; align-items:baseline; gap:1rem;">
    <h1 style="margin:0;">@L["Users.Title"]</h1>
    <span style="color:#6b7280; font-size:.85rem;">@L["Users.Subtitle"]</span>
</div>
<p style="color:#6b7280;">@L["Users.Intro"]</p>

<div style="display:flex; gap:.6rem; align-items:end; margin:1rem 0;">
    <label>@L["Common.TenantId"]
        <input @bind="_tenantId" title="@L["Users.TenantId.Tip"]" style="width:23rem; display:block;" />
    </label>
    <button @onclick="LoadAsync" title="@L["Users.Load.Tip"]" style="padding:.45rem .8rem;">@L["Users.Load"]</button>
</div>

@if (_error is not null)
{
    <p style="color:#b91c1c;">@_error</p>
}
@if (_status is not null)
{
    <p style="color:#047857;">@_status</p>
}

@if (_users is not null)
{
    <table style="width:100%; border-collapse:collapse; font-size:.9rem;">
        <thead>
            <tr style="text-align:left; border-bottom:2px solid #e5e7eb;">
                <th style="padding:.4rem;">@L["Users.Col.Email"]</th><th>@L["Users.Col.Role"]</th><th>@L["Users.Col.Verified"]</th><th>@L["Users.Col.Created"]</th><th>@L["Common.Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in _users)
        {
            <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:.4rem;">@u.Email</td>
                <td><code style="font-size:.8rem;">@u.Role</code></td>
                <td style="text-align:center;">@(u.EmailVerified ? "✓" : "—")</td>
                <td>@u.CreatedAt.LocalDateTime.ToString("dd MMM yyyy")</td>
                <td>
                    <button @onclick="() => ResetPassword(u.Id)" title="@L["Users.Reset.Tip"]" style="margin-right:.4rem;">@L["Users.Reset"]</button>
                    <button @onclick="() => ToggleEmail(u.Id)" title="@L["Users.ChangeEmail.Tip"]">@L["Users.ChangeEmail"]</button>
                    @if (_resetFor == u.Id && _tempPassword is not null)
                    {
                        <div style="margin-top:.4rem; padding:.4rem .6rem; background:#fef9c3; border:1px solid #fde047; border-radius:6px;">
                            @L["Users.TempPassword"] <code style="user-select:all; font-weight:700;">@_tempPassword</code>
                        </div>
                    }
                    @if (_emailFor == u.Id)
                    {
                        <div style="margin-top:.4rem; display:flex; gap:.4rem; align-items:center;">
                            <input @bind="_newEmail" placeholder="@L["Users.NewEmail"]" title="@L["Users.NewEmail.Tip"]" />
                            <button @onclick="() => ChangeEmail(u.Id)" title="@L["Users.SaveEmail.Tip"]">@L["Common.Save"]</button>
                            <button @onclick="() => _emailFor = null" title="@L["Users.CancelEmail.Tip"]">@L["Common.Cancel"]</button>
                        </div>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
    @if (_users.Count == 0)
    {
        <p style="color:#9ca3af;">@L["Users.Empty"]</p>
    }
}

@code {
    private string _tenantId = "00000000-0000-0000-0000-000000000001";
    private List<AdminUserDto>? _users;
    private string? _error;
    private string? _status;
    private Guid? _resetFor;
    private string? _tempPassword;
    private Guid? _emailFor;
    private string _newEmail = string.Empty;

    private async Task LoadAsync()
    {
        _error = _status = _tempPassword = null;
        _resetFor = _emailFor = null;
        try
        {
            _users = await Gateway.GetListAsync<AdminUserDto>($"/api/identity/admin/users?tenantId={Uri.EscapeDataString(_tenantId)}");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ResetPassword(Guid id)
    {
        _error = _status = _tempPassword = null;
        _emailFor = null;
        var response = await Gateway.PostAsync($"/api/identity/admin/users/{id}/reset-password?tenantId={Uri.EscapeDataString(_tenantId)}");
        if (response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadFromJsonAsync<ResetPasswordResponse>();
            _resetFor = id;
            _tempPassword = body?.TemporaryPassword;
        }
        else { _error = L["Users.Error.ResetFailed", (int)response.StatusCode]; }
    }

    private void ToggleEmail(Guid id)
    {
        _emailFor = _emailFor == id ? null : id;
        _newEmail = string.Empty;
        _tempPassword = null;
    }

    private async Task ChangeEmail(Guid id)
    {
        _error = _status = null;
        var response = await Gateway.PutAsync($"/api/identity/admin/users/{id}/email?tenantId={Uri.EscapeDataString(_tenantId)}", new { email = _newEmail });
        if (response.IsSuccessStatusCode)
        {
            _emailFor = null;
            await LoadAsync(); // LoadAsync clears _status/_error, so set the confirmation AFTER the reload
            _status = L["Users.Status.EmailChanged"];
        }
        else
        {
            _error = await response.Content.ReadAsStringAsync();
        }
    }

    private record AdminUserDto(Guid Id, string Email, string Role, bool EmailVerified, string? GivenName, string? FamilyName, DateTimeOffset CreatedAt);
    private record ResetPasswordResponse(string TemporaryPassword);
}
