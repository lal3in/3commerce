@page "/security"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["Sec.Title"]</h1>
<p style="color:#6b7280;">@L["Sec.Intro"]</p>

@if (_error is not null) { <p style="color:#b91c1c;">@_error</p> }
@if (_status is not null) { <p style="color:#047857;">@_status</p> }

<section style="background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:1rem;max-width:640px;">
    <h2 style="margin-top:0;font-size:1.05rem;">@L["Sec.Totp"]</h2>
    @if (_mfa is null)
    {
        <p>@L["Common.Loading"]</p>
    }
    else if (_mfa.Enrolled)
    {
        <p>@((MarkupString)L["Sec.Enabled"].Value)</p>
    }
    else
    {
        @if (_mfa.Required)
        {
            <p style="color:#b45309;">@((MarkupString)L["Sec.Required"].Value)</p>
        }
        @if (_enrollStart is null)
        {
            <button @onclick="BeginEnroll" disabled="@_busy" style="padding:.4rem .8rem;"
                    title="@L["Sec.EnableMfa.Tip"]">
                @L["Sec.EnableMfa"]
            </button>
        }
        else
        {
            <p>@L["Sec.SecretPrompt"]</p>
            <p><code style="background:#f3f4f6;padding:.3rem .5rem;border-radius:4px;word-break:break-all;">@_enrollStart.SecretBase32</code></p>
            <p style="color:#6b7280;font-size:.85rem;word-break:break-all;">@L["Sec.SecretUri"] <code>@_enrollStart.OtpauthUri</code></p>
            <label>@L["Sec.Code"]
                <input @bind="_confirmCode" inputmode="numeric" autocomplete="one-time-code" style="width:10rem;padding:.4rem;margin-left:.5rem;"
                       title="@L["Sec.Code.Tip"]" />
            </label>
            <button @onclick="ConfirmEnroll" disabled="@_busy" title="@L["Sec.Confirm.Tip"]" style="padding:.4rem .8rem;margin-left:.5rem;">@L["Sec.Confirm"]</button>
        }
        @if (_recoveryCodes is not null)
        {
            <div style="background:#fefce8;border:1px solid #fde68a;border-radius:6px;padding:.8rem;margin-top:.8rem;">
                <strong>@L["Sec.RecoveryCodes"]</strong>
                <ul style="margin:.5rem 0 0;">
                    @foreach (var recoveryCode in _recoveryCodes) { <li><code>@recoveryCode</code></li> }
                </ul>
            </div>
        }
    }
</section>

<section style="background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:1rem;max-width:640px;margin-top:1rem;">
    <h2 style="margin-top:0;font-size:1.05rem;">@L["Sec.Policy"]</h2>
    @if (_policy is null)
    {
        <p>@L["Common.Loading"]</p>
    }
    else
    {
        <p style="color:#6b7280;font-size:.9rem;">
            @((MarkupString)L["Sec.Policy.Summary", Describe(_policy.PlatformMinimum), Describe(_policy.Effective)].Value)
        </p>
        <select @bind="_selectedPolicy" title="@L["Sec.Policy.Tip"]">
            <option value="0">@L["Sec.Policy.Option.Disabled"]</option>
            <option value="1">@L["Sec.Policy.Option.Optional"]</option>
            <option value="2">@L["Sec.Policy.Option.Privileged"]</option>
            <option value="3">@L["Sec.Policy.Option.All"]</option>
        </select>
        <button @onclick="SavePolicy" disabled="@_busy" title="@L["Sec.Policy.Save.Tip"]" style="padding:.4rem .8rem;margin-left:.5rem;">@L["Sec.Policy.Save"]</button>
    }
</section>

<section style="background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:1rem;max-width:640px;margin-top:1rem;">
    <h2 style="margin-top:0;font-size:1.05rem;">@L["Sec.Webhooks"]</h2>
    <p style="color:#6b7280;font-size:.9rem;">
        @((MarkupString)L["Sec.Webhooks.Intro"].Value)
    </p>
    @if (_secrets is null)
    {
        <p>@L["Common.Loading"]</p>
    }
    else
    {
        <table style="border-collapse:collapse;width:100%;font-size:.9rem;">
            <thead><tr style="text-align:left;color:#6b7280;"><th>@L["Sec.Col.Provider"]</th><th>@L["Sec.Col.Secret"]</th><th>@L["Sec.Col.Label"]</th><th>@L["Common.Status"]</th><th></th></tr></thead>
            <tbody>
            @foreach (var s in _secrets)
            {
                <tr style="border-top:1px solid #f3f4f6;">
                    <td>@s.Provider</td>
                    <td><code>@s.Masked</code></td>
                    <td>@s.Label</td>
                    <td>@(s.Active ? L["Sec.Secret.Active"] : L["Sec.Secret.Deactivated"])</td>
                    <td>
                        @if (s.Active)
                        {
                            <button @onclick="() => DeactivateSecret(s.Id)" disabled="@_busy" style="padding:.2rem .5rem;"
                                    title="@L["Sec.Deactivate.Tip"]">
                                @L["Sec.Deactivate"]
                            </button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        <div style="display:flex;gap:.5rem;margin-top:.8rem;flex-wrap:wrap;">
            <select @bind="_newSecretProvider" title="@L["Sec.NewSecret.Provider.Tip"]">
                <option value="stripe">stripe</option>
            </select>
            <input @bind="_newSecretValue" placeholder="@L["Sec.NewSecret.Value"]" style="flex:1;min-width:12rem;padding:.4rem;"
                   title="@L["Sec.NewSecret.Value.Tip"]" />
            <input @bind="_newSecretLabel" placeholder="@L["Sec.NewSecret.Label"]" style="width:10rem;padding:.4rem;"
                   title="@L["Sec.NewSecret.Label.Tip"]" />
            <button @onclick="AddSecret" disabled="@_busy" title="@L["Sec.AddSecret.Tip"]" style="padding:.4rem .8rem;">@L["Sec.AddSecret"]</button>
        </div>
    }
</section>

@code {
    private MfaStatusDto? _mfa;
    private MfaPolicyDto? _policy;
    private List<WebhookSecretDto>? _secrets;
    private string _newSecretProvider = "stripe";
    private string _newSecretValue = "";
    private string _newSecretLabel = "";
    private EnrollStartDto? _enrollStart;
    private List<string>? _recoveryCodes;
    private string _confirmCode = "";
    private int _selectedPolicy;
    private bool _busy;
    private string? _error;
    private string? _status;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _mfa = await Gateway.GetAsync<MfaStatusDto>("/api/identity/mfa/status");
        _policy = await Gateway.GetAsync<MfaPolicyDto>("/api/identity/mfa/policy");
        _selectedPolicy = _policy is null ? 0 : (int)_policy.TenantPolicy;
        _secrets = await Gateway.GetListAsync<WebhookSecretDto>("/api/payments/admin/webhook-secrets");
    }

    private async Task AddSecret()
    {
        _busy = true; _error = null; _status = null;
        var response = await Gateway.PostAsync("/api/payments/admin/webhook-secrets",
            new { provider = _newSecretProvider, secret = _newSecretValue, label = _newSecretLabel });
        if (response.IsSuccessStatusCode)
        {
            _status = L["Sec.Status.SecretAdded"];
            _newSecretValue = ""; _newSecretLabel = "";
            _secrets = await Gateway.GetListAsync<WebhookSecretDto>("/api/payments/admin/webhook-secrets");
        }
        else
        {
            _error = L["Sec.Error.SecretAdd"];
        }

        _busy = false;
    }

    private async Task DeactivateSecret(Guid id)
    {
        _busy = true; _error = null; _status = null;
        var response = await Gateway.PostAsync($"/api/payments/admin/webhook-secrets/{id}/deactivate");
        if (response.IsSuccessStatusCode)
        {
            _status = L["Sec.Status.SecretDeactivated"];
            _secrets = await Gateway.GetListAsync<WebhookSecretDto>("/api/payments/admin/webhook-secrets");
        }
        else
        {
            _error = L["Sec.Error.SecretDeactivate"];
        }

        _busy = false;
    }

    private async Task BeginEnroll()
    {
        _busy = true; _error = null; _status = null;
        var response = await Gateway.PostAsync("/api/identity/mfa/enroll/begin");
        _enrollStart = response.IsSuccessStatusCode
            ? await response.Content.ReadFromJsonAsync<EnrollStartDto>()
            : null;
        if (_enrollStart is null) { _error = L["Sec.Error.EnrollStart"]; }
        _busy = false;
    }

    private async Task ConfirmEnroll()
    {
        _busy = true; _error = null; _status = null;
        var response = await Gateway.PostAsync("/api/identity/mfa/enroll/confirm", new { code = _confirmCode.Trim() });
        if (response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadFromJsonAsync<RecoveryCodesDto>();
            _recoveryCodes = body?.RecoveryCodes ?? [];
            _status = L["Sec.Status.MfaEnabled"];
            _enrollStart = null;
            _mfa = await Gateway.GetAsync<MfaStatusDto>("/api/identity/mfa/status");
        }
        else
        {
            _error = L["Sec.Error.CodeRejected"];
        }

        _busy = false;
    }

    private async Task SavePolicy()
    {
        _busy = true; _error = null; _status = null;
        var response = await Gateway.PutAsync("/api/identity/mfa/policy", new { policy = _selectedPolicy });
        if (response.IsSuccessStatusCode)
        {
            _policy = await response.Content.ReadFromJsonAsync<MfaPolicyDto>();
            _status = L["Sec.Status.PolicySaved"];
        }
        else
        {
            _error = L["Sec.Error.PolicySave"];
        }

        _busy = false;
    }

    private string Describe(int value) => value switch
    {
        1 => L["Sec.Policy.Name.Optional"],
        2 => L["Sec.Policy.Name.Privileged"],
        3 => L["Sec.Policy.Name.All"],
        _ => L["Sec.Policy.Name.Disabled"],
    };

    private sealed record MfaStatusDto(bool Enrolled, bool Pending, bool Required);
    private sealed record MfaPolicyDto(int PlatformMinimum, int TenantPolicy, int Effective);
    private sealed record EnrollStartDto(string SecretBase32, string OtpauthUri);
    private sealed record RecoveryCodesDto(string Message, List<string> RecoveryCodes);
    private sealed record WebhookSecretDto(Guid Id, string Provider, string Masked, string? Label, bool Active, DateTimeOffset CreatedAt, DateTimeOffset? DeactivatedAt);
}
