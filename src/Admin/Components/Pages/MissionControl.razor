@page "/mission-control"
@attribute [Authorize(Roles = "admin")]
@inject IConfiguration Config
@inject GatewayClient Gateway
@inject BusStatsService BusStats
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<div style="display:flex; align-items:baseline; gap:1rem;">
    <h1 style="margin:0;">Mission control</h1>
    <span style="color:#6b7280; font-size:.85rem;">cross-service ops · read-only</span>
    <span style="flex:1;"></span>
    <button @onclick="LoadAsync" style="padding:.35rem .8rem;">↻ Refresh</button>
</div>
<p style="color:#6b7280;">Activity comes from the central Audit projection; jobs from the Workflow service. Data is via owning-service APIs only — never by reading service DBs directly (mt6_14).</p>

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(170px,1fr)); gap:1rem; margin:1rem 0;">
    @KpiCard("Activity (24h)", _audit.Count(a => a.OccurredAt > DateTimeOffset.UtcNow.AddDays(-1)).ToString(), "#4f46e5")
    @KpiCard("Audit events", _audit.Count.ToString(), "#0891b2")
    @KpiCard("Job runs", _runs.Count.ToString(), "#059669")
    @KpiCard("Failed jobs", _runs.Count(r => r.Status is "Failed").ToString(), _runs.Any(r => r.Status is "Failed") ? "#dc2626" : "#059669")
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.2rem;">
    <section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem;">
        <h2 style="margin-top:0;">Activity timeline</h2>
        @if (_audit.Count == 0)
        {
            <p style="color:#9ca3af;">No audit activity yet. It appears as operators act (RBAC, supplier, entity changes…).</p>
        }
        else
        {
            <table style="width:100%; border-collapse:collapse; font-size:.85rem;">
                <thead><tr><th style="text-align:left;">When</th><th style="text-align:left;">Actor</th><th style="text-align:left;">Action</th><th>Outcome</th></tr></thead>
                <tbody>
                @foreach (var a in _audit.Take(12))
                {
                    <tr style="border-top:1px solid #f3f4f6;">
                        <td>@a.OccurredAt.LocalDateTime.ToString("dd MMM HH:mm")</td>
                        <td>@(a.ActorRole ?? "—")</td>
                        <td><code style="font-size:.78rem;">@a.Action</code> <span style="color:#9ca3af;">@a.ResourceType</span></td>
                        <td style="text-align:center; @(a.Outcome == "Success" ? "color:#047857;" : "color:#b45309;")">@a.Outcome</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem;">
        <h2 style="margin-top:0;">Scheduled jobs</h2>
        @if (_runs.Count == 0)
        {
            <p style="color:#9ca3af;">No job runs recorded yet (the Payments daily-journal job reports here).</p>
        }
        else
        {
            <table style="width:100%; border-collapse:collapse; font-size:.85rem;">
                <thead><tr><th style="text-align:left;">Job</th><th style="text-align:left;">Status</th><th style="text-align:left;">Started</th></tr></thead>
                <tbody>
                @foreach (var r in _runs.Take(12))
                {
                    <tr style="border-top:1px solid #f3f4f6;">
                        <td><code style="font-size:.78rem;">@r.JobName</code></td>
                        <td style="@(r.Status == "Failed" ? "color:#b91c1c;" : r.Status == "Succeeded" ? "color:#047857;" : "")">@r.Status @if (r.Error is not null) { <span title="@r.Error">⚠</span> }</td>
                        <td>@r.StartedAt.LocalDateTime.ToString("dd MMM HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
</div>

<section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; margin-top:1.2rem;">
    <h2 style="margin-top:0;">Message bus <span style="color:#6b7280; font-size:.75rem; font-weight:400;">live · RabbitMQ management API · read-only</span></h2>
    @if (_bus is null)
    {
        <p style="color:#9ca3af;">Management API unreachable (config <code>MessageBus:ManagementUrl</code>, dev default <code>http://localhost:15672</code>). Queue stats appear when the broker's management plugin is up.</p>
    }
    else
    {
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:1rem; margin-bottom:1rem;">
            @KpiCard("Queues", _bus.Queues.ToString(), "#4f46e5")
            @KpiCard("Consumers", _bus.Consumers.ToString(), "#0891b2")
            @KpiCard("Ready", _bus.Ready.ToString(), _bus.Ready > 0 ? "#b45309" : "#059669")
            @KpiCard("Unacked", _bus.Unacked.ToString(), "#059669")
            @KpiCard("Dead-lettered", _bus.DeadLettered.ToString(), _bus.DeadLettered > 0 ? "#dc2626" : "#059669")
        </div>
        @if (_bus.DeadLetterQueues.Count > 0)
        {
            <p style="color:#b91c1c; font-weight:600;">⚠ Dead-letter queues holding messages — these consumers are failing:</p>
            <table style="width:100%; border-collapse:collapse; font-size:.85rem; margin-bottom:1rem;">
                <thead><tr><th style="text-align:left;">Queue</th><th>Ready</th><th>Unacked</th></tr></thead>
                <tbody>
                @foreach (var q in _bus.DeadLetterQueues)
                {
                    <tr style="border-top:1px solid #fee2e2;"><td><code style="font-size:.78rem;">@q.Name</code></td><td style="text-align:center;">@q.Ready</td><td style="text-align:center;">@q.Unacked</td></tr>
                }
                </tbody>
            </table>
        }
        <details>
            <summary style="cursor:pointer; color:#6b7280;">Busiest queues (top 10 by depth, then publish rate)</summary>
            <table style="width:100%; border-collapse:collapse; font-size:.85rem; margin-top:.5rem;">
                <thead><tr><th style="text-align:left;">Queue</th><th>Ready</th><th>Unacked</th><th>Consumers</th><th>Publish/s</th></tr></thead>
                <tbody>
                @foreach (var q in _bus.TopQueues)
                {
                    <tr style="border-top:1px solid #f3f4f6;">
                        <td><code style="font-size:.78rem;">@q.Name</code></td>
                        <td style="text-align:center;">@q.Ready</td>
                        <td style="text-align:center;">@q.Unacked</td>
                        <td style="text-align:center;">@q.Consumers</td>
                        <td style="text-align:center;">@q.PublishRate.ToString("0.0")</td>
                    </tr>
                }
                </tbody>
            </table>
        </details>
    }
</section>

<section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; margin-top:1.2rem;">
    <h2 style="margin-top:0;">Consoles</h2>
    <div style="display:flex; gap:1.5rem; flex-wrap:wrap;">
        <a href="@GrafanaUrl" target="_blank" rel="noopener">📊 Grafana — Services (RED metrics)</a>
        <NavLink href="/rbac">🔐 Roles &amp; permissions</NavLink>
        <NavLink href="/entities">🏢 Entities &amp; suppliers</NavLink>
        <NavLink href="/ledger">📒 Ledger</NavLink>
        <NavLink href="/orders">🧾 Orders</NavLink>
    </div>
</section>

@code {
    private List<AuditDto> _audit = [];
    private List<RunDto> _runs = [];
    private BusStatsService.BusSnapshot? _bus;
    private string _tenant = "00000000-0000-0000-0000-000000000001";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _audit = await Gateway.GetListAsync<AuditDto>($"/api/audit/admin/audit?tenantId={_tenant}");
        _runs = await Gateway.GetListAsync<RunDto>("/api/workflow/admin/workflow/runs");
        _bus = await BusStats.GetSnapshotAsync();
    }

    private string GrafanaUrl => Config["Observability:GrafanaUrl"] ?? "http://localhost:3001";

    private RenderFragment KpiCard(string label, string value, string color) => builder =>
    {
        builder.AddMarkupContent(0,
            $"<div style=\"border:1px solid #e5e7eb; border-left:4px solid {color}; border-radius:10px; padding:.8rem 1rem;\">" +
            $"<div style=\"font-size:.75rem; color:#6b7280; text-transform:uppercase;\">{label}</div>" +
            $"<div style=\"font-size:1.5rem; font-weight:700;\">{value}</div></div>");
    };

    private record AuditDto(Guid Id, long Sequence, DateTimeOffset OccurredAt, Guid? ActorId, string? ActorRole, string Action, string ResourceType, string ResourceId, string Outcome, string? Summary);
    private record RunDto(Guid Id, string JobName, string Status, DateTimeOffset StartedAt, DateTimeOffset? CompletedAt, string? Error);
}
