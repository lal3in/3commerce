@page "/mission-control"
@attribute [Authorize(Roles = "admin")]
@inject IConfiguration Config
@inject GatewayClient Gateway
@inject BusStatsService BusStats
@inject ObservabilityStatsService ObsStats
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<div style="display:flex; align-items:baseline; gap:1rem;">
    <h1 style="margin:0;">@L["Mc.Title"]</h1>
    <span style="color:#6b7280; font-size:.85rem;">@L["Mc.Subtitle"]</span>
    <span style="flex:1;"></span>
    <button @onclick="LoadAsync" title="@L["Common.Refresh.Tip"]" style="padding:.35rem .8rem;">↻ @L["Common.Refresh"]</button>
</div>
<p style="color:#6b7280;">@L["Mc.Intro"]</p>

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(170px,1fr)); gap:1rem; margin:1rem 0;">
    @KpiCard(L["Mc.Kpi.Activity"], _audit.Count(a => a.OccurredAt > DateTimeOffset.UtcNow.AddDays(-1)).ToString(), "#4f46e5", L["Mc.Kpi.Activity.Tip"])
    @KpiCard(L["Mc.Kpi.AuditEvents"], _audit.Count.ToString(), "#0891b2", L["Mc.Kpi.AuditEvents.Tip"])
    @KpiCard(L["Mc.Kpi.JobRuns"], _runs.Count.ToString(), "#059669", L["Mc.Kpi.JobRuns.Tip"])
    @KpiCard(L["Mc.Kpi.FailedJobs"], _runs.Count(r => r.Status is "Failed").ToString(), _runs.Any(r => r.Status is "Failed") ? "#dc2626" : "#059669", L["Mc.Kpi.FailedJobs.Tip"])
</div>

@* Live commerce activity (mc1): orders / revenue / refunds & returns, from the same admin read
   models the Orders and RMA pages use — a payment or refund shows here as soon as it lands. *@
<section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; margin-bottom:1.2rem;">
    <h2 style="margin-top:0;">@L["Mc.Commerce"] <span style="color:#6b7280; font-size:.75rem; font-weight:400;">@L["Mc.Commerce.Subtitle"]</span></h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:1rem;">
        @KpiCard(L["Mc.Kpi.Orders"], _orders.Count.ToString(), "#4f46e5", L["Mc.Kpi.Orders.Tip"])
        @KpiCard(L["Mc.Kpi.Confirmed"], OrdersWith("Confirmed").ToString(), "#059669", L["Mc.Kpi.Confirmed.Tip"])
        @* Revenue is per-currency — summing minor units across currencies is meaningless, so one
           tile per currency present (code-prefixed, e.g. "EUR 59.05"). *@
        @if (RevenueByCurrency.Count == 0)
        {
            @KpiCard(L["Mc.Kpi.Revenue"], "0.00", "#0891b2", L["Mc.Kpi.Revenue.Tip"])
        }
        else
        {
            @foreach (var (currency, minor) in RevenueByCurrency)
            {
                @KpiCard(L["Mc.Kpi.Revenue"], $"{currency} {minor / 100m:0.00}", "#0891b2", L["Mc.Kpi.Revenue.Tip"])
            }
        }
        @KpiCard(L["Mc.Kpi.Refunded"], OrdersWith("Refunded").ToString(), _orders.Any(o => o.Status == "Refunded") ? "#b45309" : "#059669", L["Mc.Kpi.Refunded.Tip"])
        @KpiCard(L["Mc.Kpi.Cancelled"], OrdersWith("Cancelled").ToString(), "#6b7280", L["Mc.Kpi.Cancelled.Tip"])
        @KpiCard(L["Mc.Kpi.RmasOpen"], RmasWith("Requested", "AwaitingReturn", "RefundPending").ToString(), RmasWith("Requested", "AwaitingReturn", "RefundPending") > 0 ? "#b45309" : "#059669", L["Mc.Kpi.RmasOpen.Tip"])
        @KpiCard(L["Mc.Kpi.RmasIssued"], RmasWith("RefundIssued").ToString(), "#059669", L["Mc.Kpi.RmasIssued.Tip"])
    </div>
</section>

@* Per-process monitors (mc_proc): checkout saga in-flight, subscription renewals, dropship
   forwarding — each from the owning service's admin read endpoint, so the whole pipeline is visible. *@
<section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; margin-bottom:1.2rem;">
    <h2 style="margin-top:0;">@L["Mc.Process"] <span style="color:#6b7280; font-size:.75rem; font-weight:400;">@L["Mc.Process.Subtitle"]</span></h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:1rem;">
        @KpiCard(L["Mc.Kpi.CheckoutsInFlight"], CheckoutsInState("AwaitingPayment").ToString(), CheckoutsInState("AwaitingPayment") > 0 ? "#b45309" : "#059669", L["Mc.Kpi.CheckoutsInFlight.Tip"])
        @KpiCard(L["Mc.Kpi.SubsActive"], SubsWith("Active", "Trialing").ToString(), "#059669", L["Mc.Kpi.SubsActive.Tip"])
        @KpiCard(L["Mc.Kpi.SubsPastDue"], SubsWith("PastDue").ToString(), SubsWith("PastDue") > 0 ? "#dc2626" : "#059669", L["Mc.Kpi.SubsPastDue.Tip"])
        @KpiCard(L["Mc.Kpi.DropshipOpen"], DropshipWith("Requested", "Accepted").ToString(), DropshipWith("Requested", "Accepted") > 0 ? "#b45309" : "#059669", L["Mc.Kpi.DropshipOpen.Tip"])
        @KpiCard(L["Mc.Kpi.DropshipTracking"], DropshipWith("TrackingReceived").ToString(), "#0891b2", L["Mc.Kpi.DropshipTracking.Tip"])
        @KpiCard(L["Mc.Kpi.DropshipFailed"], DropshipWith("Failed").ToString(), DropshipWith("Failed") > 0 ? "#dc2626" : "#059669", L["Mc.Kpi.DropshipFailed.Tip"])
        @KpiCard(L["Mc.Kpi.NotifSent"], (_notif?.Sent24h ?? 0).ToString(), "#059669", L["Mc.Kpi.NotifSent.Tip"])
        @KpiCard(L["Mc.Kpi.NotifFailed"], (_notif?.Failed ?? 0).ToString(), (_notif?.Failed ?? 0) > 0 ? "#dc2626" : "#059669", L["Mc.Kpi.NotifFailed.Tip"])
    </div>
</section>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.2rem;">
    <section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem;">
        <h2 style="margin-top:0;">@L["Mc.Timeline"]</h2>
        @if (_audit.Count == 0)
        {
            <p style="color:#9ca3af;">@L["Mc.NoAudit"]</p>
        }
        else
        {
            @* Timeline can be long; keep it inside a fixed-height, vertically scrollable pane so the
               card doesn't push the rest of the dashboard down. sticky header stays visible while scrolling. *@
            <div style="max-height:22rem; overflow-y:auto;">
                <table style="width:100%; border-collapse:collapse; font-size:.85rem;">
                    <thead><tr style="position:sticky; top:0; background:#fff;"><th style="text-align:left;">@L["Mc.Col.When"]</th><th style="text-align:left;">@L["Mc.Col.Actor"]</th><th style="text-align:left;">@L["Mc.Col.Action"]</th><th>@L["Mc.Col.Outcome"]</th></tr></thead>
                    <tbody>
                    @foreach (var a in _audit.Take(100))
                    {
                        <tr style="border-top:1px solid #f3f4f6;">
                            <td>@a.OccurredAt.LocalDateTime.ToString("dd MMM HH:mm")</td>
                            <td>@(a.ActorRole ?? "—")</td>
                            <td><code style="font-size:.78rem;">@a.Action</code> <span style="color:#9ca3af;">@a.ResourceType</span></td>
                            <td style="text-align:center; @(a.Outcome == "Success" ? "color:#047857;" : "color:#b45309;")">@a.Outcome</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem;">
        <h2 style="margin-top:0;">@L["Mc.Jobs"]</h2>
        @if (_runs.Count == 0)
        {
            <p style="color:#9ca3af;">@L["Mc.NoJobs"]</p>
        }
        else
        {
            <table style="width:100%; border-collapse:collapse; font-size:.85rem;">
                <thead><tr><th style="text-align:left;">@L["Mc.Col.Job"]</th><th style="text-align:left;">@L["Common.Status"]</th><th style="text-align:left;">@L["Mc.Col.Started"]</th></tr></thead>
                <tbody>
                @foreach (var r in _runs.Take(12))
                {
                    <tr style="border-top:1px solid #f3f4f6;">
                        <td><code style="font-size:.78rem;">@r.JobName</code></td>
                        <td style="@(r.Status == "Failed" ? "color:#b91c1c;" : r.Status == "Succeeded" ? "color:#047857;" : "")">@r.Status @if (r.Error is not null) { <span title="@r.Error">⚠</span> }</td>
                        <td>@r.StartedAt.LocalDateTime.ToString("dd MMM HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
</div>

<section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; margin-top:1.2rem;">
    <h2 style="margin-top:0;">@L["Mc.Bus"] <span style="color:#6b7280; font-size:.75rem; font-weight:400;">@L["Mc.Bus.Subtitle"]</span></h2>
    @if (_bus is null)
    {
        <p style="color:#9ca3af;">@((MarkupString)L["Mc.Bus.Unreachable"].Value)</p>
    }
    else
    {
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:1rem; margin-bottom:1rem;">
            @KpiCard(L["Mc.Bus.Queues"], _bus.Queues.ToString(), "#4f46e5", L["Mc.Bus.Queues.Tip"])
            @KpiCard(L["Mc.Bus.Consumers"], _bus.Consumers.ToString(), "#0891b2", L["Mc.Bus.Consumers.Tip"])
            @KpiCard(L["Mc.Bus.Ready"], _bus.Ready.ToString(), _bus.Ready > 0 ? "#b45309" : "#059669", L["Mc.Bus.Ready.Tip"])
            @KpiCard(L["Mc.Bus.Unacked"], _bus.Unacked.ToString(), "#059669", L["Mc.Bus.Unacked.Tip"])
            @KpiCard(L["Mc.Bus.DeadLettered"], _bus.DeadLettered.ToString(), _bus.DeadLettered > 0 ? "#dc2626" : "#059669", L["Mc.Bus.DeadLettered.Tip"])
        </div>
        @if (_bus.DeadLetterQueues.Count > 0)
        {
            <p style="color:#b91c1c; font-weight:600;">@L["Mc.Bus.DlqWarning"]</p>
            <table style="width:100%; border-collapse:collapse; font-size:.85rem; margin-bottom:1rem;">
                <thead><tr><th style="text-align:left;">@L["Mc.Col.Queue"]</th><th>@L["Mc.Bus.Ready"]</th><th>@L["Mc.Bus.Unacked"]</th></tr></thead>
                <tbody>
                @foreach (var q in _bus.DeadLetterQueues)
                {
                    <tr style="border-top:1px solid #fee2e2;"><td><code style="font-size:.78rem;">@q.Name</code></td><td style="text-align:center;">@q.Ready</td><td style="text-align:center;">@q.Unacked</td></tr>
                }
                </tbody>
            </table>
        }
        <details>
            <summary style="cursor:pointer; color:#6b7280;" title="@L["Mc.Bus.Busiest.Tip"]">@L["Mc.Bus.Busiest"]</summary>
            <table style="width:100%; border-collapse:collapse; font-size:.85rem; margin-top:.5rem;">
                <thead><tr><th style="text-align:left;">@L["Mc.Col.Queue"]</th><th>@L["Mc.Bus.Ready"]</th><th>@L["Mc.Bus.Unacked"]</th><th>@L["Mc.Bus.Consumers"]</th><th>@L["Mc.Col.PublishRate"]</th></tr></thead>
                <tbody>
                @foreach (var q in _bus.TopQueues)
                {
                    <tr style="border-top:1px solid #f3f4f6;">
                        <td><code style="font-size:.78rem;">@q.Name</code></td>
                        <td style="text-align:center;">@q.Ready</td>
                        <td style="text-align:center;">@q.Unacked</td>
                        <td style="text-align:center;">@q.Consumers</td>
                        <td style="text-align:center;">@q.PublishRate.ToString("0.0")</td>
                    </tr>
                }
                </tbody>
            </table>
        </details>
    }
</section>

@* Observability backends (LGTM): up/down per backend plus signal-volume KPIs, read straight from
   the Loki/Tempo/Mimir HTTP APIs — same best-effort philosophy as the bus section above. *@
<section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; margin-top:1.2rem;">
    <h2 style="margin-top:0;">@L["Mc.Obs"] <span style="color:#6b7280; font-size:.75rem; font-weight:400;">@L["Mc.Obs.Subtitle"]</span></h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:1rem;">
        @KpiCard(L["Mc.Obs.Loki"], (_obs?.LokiUp == true ? L["Mc.Obs.Up"] : L["Mc.Obs.Down"]).Value, _obs?.LokiUp == true ? "#059669" : "#dc2626", L["Mc.Obs.Loki.Tip"])
        @KpiCard(L["Mc.Obs.Tempo"], (_obs?.TempoUp == true ? L["Mc.Obs.Up"] : L["Mc.Obs.Down"]).Value, _obs?.TempoUp == true ? "#059669" : "#dc2626", L["Mc.Obs.Tempo.Tip"])
        @KpiCard(L["Mc.Obs.Mimir"], (_obs?.MimirUp == true ? L["Mc.Obs.Up"] : L["Mc.Obs.Down"]).Value, _obs?.MimirUp == true ? "#059669" : "#dc2626", L["Mc.Obs.Mimir.Tip"])
        @KpiCard(L["Mc.Obs.LogLines"], (_obs?.LogLines1h ?? 0).ToString(), "#0891b2", L["Mc.Obs.LogLines.Tip"])
        @KpiCard(L["Mc.Obs.ErrorLogs"], (_obs?.ErrorLogs1h ?? 0).ToString(), (_obs?.ErrorLogs1h ?? 0) > 0 ? "#b45309" : "#059669", L["Mc.Obs.ErrorLogs.Tip"])
        @KpiCard(L["Mc.Obs.Traces"], (_obs?.Traces1h ?? 0).ToString(), "#4f46e5", L["Mc.Obs.Traces.Tip"])
        @KpiCard(L["Mc.Obs.Services"], (_obs?.ServicesReporting ?? 0).ToString(), "#0891b2", L["Mc.Obs.Services.Tip"])
    </div>
</section>

<section style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; margin-top:1.2rem;">
    <h2 style="margin-top:0;">@L["Mc.Consoles"]</h2>
    <div style="display:flex; gap:1.5rem; flex-wrap:wrap;">
        <a href="@GrafanaUrl" target="_blank" rel="noopener" title="@L["Mc.Link.Grafana.Tip"]">📊 @L["Mc.Link.Grafana"]</a>
        <a href="@ExploreUrl("loki")" target="_blank" rel="noopener" title="@L["Mc.Link.Loki.Tip"]">📜 @L["Mc.Link.Loki"]</a>
        <a href="@ExploreUrl("tempo")" target="_blank" rel="noopener" title="@L["Mc.Link.Tempo.Tip"]">🧵 @L["Mc.Link.Tempo"]</a>
        <a href="@ExploreUrl("mimir")" target="_blank" rel="noopener" title="@L["Mc.Link.Mimir.Tip"]">📈 @L["Mc.Link.Mimir"]</a>
        <NavLink href="/rbac" title="@L["Nav.Rbac.Tip"]">🔐 @L["Nav.Rbac"]</NavLink>
        <NavLink href="/entities" title="@L["Nav.Entities.Tip"]">🏢 @L["Nav.Entities"]</NavLink>
        <NavLink href="/ledger" title="@L["Nav.Ledger.Tip"]">📒 @L["Nav.Ledger"]</NavLink>
        <NavLink href="/orders" title="@L["Nav.Orders.Tip"]">🧾 @L["Nav.Orders"]</NavLink>
    </div>
</section>

@code {
    private List<AuditDto> _audit = [];
    private List<RunDto> _runs = [];
    private List<OrderKpiDto> _orders = [];
    private List<RmaKpiDto> _rmas = [];
    private List<CheckoutCountDto> _checkouts = [];
    private List<SubKpiDto> _subs = [];
    private List<DropshipKpiDto> _dropship = [];
    private NotifSummaryDto? _notif;
    private BusStatsService.BusSnapshot? _bus;
    private ObservabilityStatsService.ObsSnapshot? _obs;
    private string _tenant = "00000000-0000-0000-0000-000000000001";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _audit = await Gateway.GetListAsync<AuditDto>($"/api/audit/admin/audit?tenantId={_tenant}");
        _runs = await Gateway.GetListAsync<RunDto>("/api/workflow/admin/workflow/runs");
        // Live commerce activity — the same admin read models the Orders and RMA pages use, so a
        // payment/refund/return shows here the moment it lands (mc1: Mission Control as full monitor).
        _orders = await SafeList<OrderKpiDto>("/api/ordering/admin/orders");
        _rmas = await SafeList<RmaKpiDto>("/api/support/admin/rmas");
        // Per-process monitors (mc_proc): checkout saga, subscription renewals, dropship forwarding.
        _checkouts = await SafeList<CheckoutCountDto>("/api/ordering/admin/checkouts");
        _subs = await SafeList<SubKpiDto>("/api/payments/admin/subscriptions");
        _dropship = await SafeList<DropshipKpiDto>("/api/fulfillment/admin/dropship/orders");
        _notif = await SafeGet<NotifSummaryDto>("/api/notifications/admin/notifications");
        _bus = await BusStats.GetSnapshotAsync();
        _obs = await ObsStats.GetSnapshotAsync();
    }

    // A single failing read model must not blank the whole monitor — degrade that tile to 0/empty.
    private async Task<List<T>> SafeList<T>(string path)
    {
        try { return await Gateway.GetListAsync<T>(path); }
        catch { return []; }
    }

    private async Task<T?> SafeGet<T>(string path) where T : class
    {
        try { return await Gateway.GetAsync<T>(path); }
        catch { return null; }
    }

    private int OrdersWith(params string[] statuses) => _orders.Count(o => statuses.Contains(o.Status));
    private int RmasWith(params string[] states) => _rmas.Count(r => states.Contains(r.State));
    // Gross of confirmed/refunded orders grouped by currency — never summed across currencies.
    private List<(string Currency, long Minor)> RevenueByCurrency => _orders
        .Where(o => o.Status is "Confirmed" or "Refunded")
        .GroupBy(o => o.Currency)
        .OrderBy(g => g.Key, StringComparer.Ordinal)
        .Select(g => (g.Key, g.Sum(o => o.GrossMinor)))
        .ToList();
    private int CheckoutsInState(params string[] states) => _checkouts.Where(c => states.Contains(c.State)).Sum(c => c.Count);
    private int SubsWith(params string[] statuses) => _subs.Count(s => statuses.Contains(s.Status));
    private int DropshipWith(params string[] statuses) => _dropship.Count(d => statuses.Contains(d.Status));

    private string GrafanaUrl => Config["Observability:GrafanaUrl"] ?? "http://localhost:3001";

    // Grafana Explore deep link preselecting a provisioned datasource over the last hour. The uids
    // are pinned in deploy/observability/grafana/provisioning/datasources/lgtm.yml (loki/tempo/mimir);
    // Grafana migrates this legacy `left` shape to the current panes format on load.
    private string ExploreUrl(string datasourceUid) =>
        $"{GrafanaUrl}/explore?left=" + Uri.EscapeDataString(
            $"{{\"datasource\":\"{datasourceUid}\",\"queries\":[{{\"refId\":\"A\"}}],\"range\":{{\"from\":\"now-1h\",\"to\":\"now\"}}}}");

    // label/tip come from the resx (trusted); value is our own ToString of a count — nothing user-supplied.
    private RenderFragment KpiCard(string label, string value, string color, string tip) => builder =>
    {
        builder.AddMarkupContent(0,
            $"<div title=\"{tip}\" style=\"border:1px solid #e5e7eb; border-left:4px solid {color}; border-radius:10px; padding:.8rem 1rem;\">" +
            $"<div style=\"font-size:.75rem; color:#6b7280; text-transform:uppercase;\">{label}</div>" +
            $"<div style=\"font-size:1.5rem; font-weight:700;\">{value}</div></div>");
    };

    private record AuditDto(Guid Id, long Sequence, DateTimeOffset OccurredAt, Guid? ActorId, string? ActorRole, string Action, string ResourceType, string ResourceId, string Outcome, string? Summary);
    private record RunDto(Guid Id, string JobName, string Status, DateTimeOffset StartedAt, DateTimeOffset? CompletedAt, string? Error);
    private record OrderKpiDto(Guid Id, string Status, long GrossMinor, string Currency, DateTimeOffset CreatedAt, string? PaymentOption = null);
    private record RmaKpiDto(Guid Id, Guid OrderId, string? Email, long AmountMinor, string? Reason, string State, DateTimeOffset CreatedAt);
    private record CheckoutCountDto(string State, int Count);
    private record SubKpiDto(Guid Id, Guid OrderId, string CustomerEmail, Guid ProductId, Guid? VariantId, string BillingPeriod, long PriceMinor, string Currency, string Status, DateTimeOffset CurrentPeriodStart, DateTimeOffset CurrentPeriodEnd);
    private record DropshipKpiDto(Guid Id, Guid OrderId, Guid SupplierId, string Status, string? ExternalReference, string? TrackingNumber, string? Carrier, string? FailureReason);
    private record NotifSummaryDto(int Total, int Sent24h, int Failed);
}
