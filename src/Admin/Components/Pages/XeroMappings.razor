@page "/xero-mappings"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["XeroMap.Title"]</h1>
<p style="color:#6b7280;">@L["XeroMap.Intro"]</p>

<div style="display:flex; gap:.6rem; align-items:end; margin:1rem 0;">
    <label>@L["Common.TenantId"]
        <input @bind="_tenantId" title="@L["XeroMap.TenantId.Tip"]" style="width:23rem; display:block;" />
    </label>
    <button @onclick="LoadAsync" title="@L["Common.Load.Tip"]" style="padding:.45rem .8rem;">@L["Common.Load"]</button>
</div>

@if (_error is not null) { <p style="color:#b91c1c; white-space:pre-wrap;">@_error</p> }
@if (_status is not null) { <p style="color:#047857;">@_status</p> }

@if (_mappings is not null)
{
    <table style="width:100%; border-collapse:collapse; font-size:.9rem;">
        <thead><tr style="text-align:left; border-bottom:2px solid #e5e7eb;"><th style="padding:.4rem;">@L["XeroMap.Col.Ledger"]</th><th>@L["XeroMap.Col.Xero"]</th><th>@L["XeroMap.Col.Scope"]</th><th>@L["XeroMap.Col.Target"]</th><th>@L["Common.Active"]</th><th>@L["Common.Actions"]</th></tr></thead>
        <tbody>
        @foreach (var mapping in _mappings)
        {
            <tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:.4rem;"><code>@mapping.LedgerAccountCode</code></td><td><code>@mapping.XeroAccountCode</code></td><td>@ScopeLabel(mapping.Scope)</td><td>@Target(mapping)</td><td>@(mapping.Active ? L["Common.Yes"] : L["Common.No"])</td><td><button @onclick="() => Edit(mapping)" title="@L["XeroMap.Edit.Tip"]">@L["Common.Edit"]</button> <button @onclick="() => Delete(mapping.Id)" title="@L["XeroMap.Delete.Tip"]" style="color:#b91c1c;">@L["Common.Delete"]</button></td></tr>
        }
        </tbody>
    </table>
    @if (_mappings.Count == 0) { <p style="color:#9ca3af;">@L["XeroMap.Empty"]</p> }

    <section style="margin-top:1.5rem; border:1px solid #e5e7eb; border-radius:8px; padding:1rem; max-width:680px; background:#fff;">
        <h2 style="margin-top:0; font-size:1.1rem;">@(_editingId is null ? L["XeroMap.New"] : L["XeroMap.EditHeading"])</h2>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:.5rem;">
            <label>@L["XeroMap.Field.Ledger"] <input @bind="_form.LedgerAccountCode" title="@L["XeroMap.Field.Ledger.Tip"]" style="width:100%;" /></label>
            <label>@L["XeroMap.Field.Xero"] <input @bind="_form.XeroAccountCode" title="@L["XeroMap.Field.Xero.Tip"]" style="width:100%;" /></label>
            <label>@L["XeroMap.Field.Scope"]
                <select @bind="_form.Scope" @bind:after="LoadTargetOptionsAsync" title="@L["XeroMap.Field.Scope.Tip"]" style="width:100%;">
                    <option value="1">@L["XeroMap.Scope.TenantDefault"]</option><option value="2">@L["XeroMap.Scope.Storefront"]</option><option value="3">@L["XeroMap.Scope.Category"]</option><option value="4">@L["XeroMap.Scope.Supplier"]</option><option value="5">@L["XeroMap.Scope.Product"]</option>
                </select>
            </label>
            @* Tenant-default mappings have no target. For every other scope the target is picked from a
               dropdown of the REAL options for that scope (fetched live) — no GUID to remember or mistype. *@
            @if (_form.Scope != TenantDefaultScope)
            {
                <label>@L["XeroMap.Field.Target"]
                    <select @bind="_form.TargetId" title="@L["XeroMap.Field.Target.Tip"]" style="width:100%;">
                        <option value="">@L["XeroMap.Field.Target.Choose"]</option>
                        @foreach (var opt in _targetOptions)
                        {
                            <option value="@opt.Id">@opt.Label</option>
                        }
                    </select>
                </label>
            }
            else
            {
                <span style="color:#9ca3af; font-size:.82rem; align-self:end;">@L["XeroMap.Field.Target.NotApplicable"]</span>
            }
            <label style="display:flex; gap:.4rem; align-items:center;"><input type="checkbox" @bind="_form.Active" title="@L["XeroMap.Field.Active.Tip"]" /> @L["Common.Active"]</label>
        </div>
        <div style="margin-top:.8rem; display:flex; gap:.5rem;">
            <button @onclick="Save" title="@L["XeroMap.Save.Tip"]" style="padding:.45rem .9rem; background:#111827; color:#fff; border:0; border-radius:5px;">@L["XeroMap.Save"]</button>
            <button @onclick="ResetForm" title="@L["Common.Clear.Tip"]">@L["Common.Clear"]</button>
        </div>
    </section>
}

@code {
    private string _tenantId = "00000000-0000-0000-0000-000000000001";
    private List<XeroAccountMappingDto>? _mappings;
    private string? _status;
    private string? _error;
    private Guid? _editingId;
    private readonly MappingForm _form = new();
    private List<TargetOption> _targetOptions = [];

    // Load the real options for the selected scope, so the operator picks a storefront/category/supplier/
    // product from a list instead of pasting a GUID. Runs whenever the scope changes (and on Edit).
    private async Task LoadTargetOptionsAsync()
    {
        _targetOptions = [];
        if (_form.Scope == TenantDefaultScope) { _form.TargetId = string.Empty; return; }
        var tenant = Uri.EscapeDataString(_tenantId);
        try
        {
            _targetOptions = _form.Scope switch
            {
                StorefrontScope => [.. (await Gateway.GetListAsync<StorefrontOption>($"/api/catalog/admin/storefronts?tenantId={tenant}")).Select(s => new TargetOption(s.Id.ToString(), s.Name))],
                CategoryScope => [.. (await Gateway.GetListAsync<CategoryOption>("/api/catalog/categories")).Select(c => new TargetOption(c.Id.ToString(), c.Name))],
                SupplierScope => [.. (await Gateway.GetListAsync<EntityOption>($"/api/entity/entities?tenantId={tenant}")).Where(e => e.Status == 1).Select(e => new TargetOption(e.Id.ToString(), e.DisplayName))],
                ProductScope => [.. (await Gateway.GetListAsync<ProductOption>("/api/catalog/admin/products")).Select(p => new TargetOption(p.Id.ToString(), p.Title))],
                _ => [],
            };
        }
        catch { _targetOptions = []; }

        // Editing a mapping whose target no longer appears in the list (renamed/removed) still shows it,
        // so the operator sees what it points at rather than a silently-blank dropdown.
        if (!string.IsNullOrEmpty(_form.TargetId) && _targetOptions.All(o => o.Id != _form.TargetId))
        {
            _targetOptions.Insert(0, new TargetOption(_form.TargetId, _form.TargetId));
        }
    }

    private async Task LoadAsync()
    {
        _error = _status = null;
        try { _mappings = await Gateway.GetListAsync<XeroAccountMappingDto>($"/api/payments/admin/xero/mappings?tenantId={Uri.EscapeDataString(_tenantId)}"); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task Save()
    {
        _error = _status = null;
        if (!Guid.TryParse(_tenantId, out var tenant)) { _error = L["XeroMap.Error.TenantGuid"]; return; }
        Guid? target = Guid.TryParse(_form.TargetId, out var parsed) ? parsed : null;
        // Every scope except tenant-default keys the mapping to a target id; without it the mapping would
        // save against the wrong (null) field and never round-trip back into this form on Edit.
        if (_form.Scope != TenantDefaultScope && target is null) { _error = L["XeroMap.Error.TargetRequired"]; return; }
        // Enums cross HTTP as NUMBERS (platform invariant): send the numeric XeroMappingScope value,
        // and route the target GUID to the field the scope selects.
        var body = new { tenantId = tenant, scope = _form.Scope, storefrontId = _form.Scope == StorefrontScope ? target : null, categoryId = _form.Scope == CategoryScope ? target : null, supplierEntityId = _form.Scope == SupplierScope ? target : null, productId = _form.Scope == ProductScope ? target : null, ledgerAccountCode = _form.LedgerAccountCode, xeroAccountCode = _form.XeroAccountCode, active = _form.Active };
        var response = _editingId is null
            ? await Gateway.PostAsync("/api/payments/admin/xero/mappings", body)
            : await Gateway.PutAsync($"/api/payments/admin/xero/mappings/{_editingId}", body);
        if (response.IsSuccessStatusCode) { ResetForm(); await LoadAsync(); _status = L["XeroMap.Status.Saved"]; } // LoadAsync clears _status/_error, so set the confirmation AFTER the reload
        else { _error = await GatewayError.ReadAsync(response); }
    }

    private async Task Delete(Guid id)
    {
        _error = _status = null;
        var response = await Gateway.DeleteAsync($"/api/payments/admin/xero/mappings/{id}");
        if (response.IsSuccessStatusCode) { await LoadAsync(); _status = L["XeroMap.Status.Deleted"]; }
        else { _error = await GatewayError.ReadAsync(response); }
    }

    // XeroMappingScope numeric values (Payments domain enum) — enums are numeric on the wire.
    private const int TenantDefaultScope = 1;
    private const int StorefrontScope = 2;
    private const int CategoryScope = 3;
    private const int SupplierScope = 4;
    private const int ProductScope = 5;

    private async Task Edit(XeroAccountMappingDto mapping)
    {
        _editingId = mapping.Id;
        _form.Scope = ScopeValue(mapping.Scope);
        _form.LedgerAccountCode = mapping.LedgerAccountCode;
        _form.XeroAccountCode = mapping.XeroAccountCode;
        _form.Active = mapping.Active;
        _form.TargetId = (mapping.StorefrontId ?? mapping.CategoryId ?? mapping.SupplierEntityId ?? mapping.ProductId)?.ToString() ?? string.Empty;
        await LoadTargetOptionsAsync(); // populate the scope's dropdown so the saved target shows selected
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.Scope = TenantDefaultScope; _form.TargetId = string.Empty; _form.LedgerAccountCode = string.Empty; _form.XeroAccountCode = string.Empty; _form.Active = true;
        _targetOptions = [];
    }

    private static string Target(XeroAccountMappingDto m) => (m.StorefrontId ?? m.CategoryId ?? m.SupplierEntityId ?? m.ProductId)?.ToString() ?? "—";

    // The response DTO carries the scope's enum NAME (e.g. "Storefront"); map it back to the numeric form value.
    private static int ScopeValue(string scope) => scope switch
    {
        "Storefront" => StorefrontScope,
        "Category" => CategoryScope,
        "Supplier" => SupplierScope,
        "Product" => ProductScope,
        _ => TenantDefaultScope,
    };

    // …and to a localized label for the table.
    private string ScopeLabel(string scope) => scope switch
    {
        "Storefront" => L["XeroMap.Scope.Storefront"],
        "Category" => L["XeroMap.Scope.Category"],
        "Supplier" => L["XeroMap.Scope.Supplier"],
        "Product" => L["XeroMap.Scope.Product"],
        _ => L["XeroMap.Scope.TenantDefault"],
    };

    private sealed class MappingForm { public int Scope { get; set; } = TenantDefaultScope; public string TargetId { get; set; } = string.Empty; public string LedgerAccountCode { get; set; } = string.Empty; public string XeroAccountCode { get; set; } = string.Empty; public bool Active { get; set; } = true; }
    private sealed record TargetOption(string Id, string Label);
    private sealed record StorefrontOption(Guid Id, string Name);
    private sealed record CategoryOption(Guid Id, string Name);
    private sealed record EntityOption(Guid Id, string DisplayName, int Status);
    private sealed record ProductOption(Guid Id, string Title);
    private record XeroAccountMappingDto(Guid Id, Guid TenantId, string Scope, Guid? StorefrontId, Guid? CategoryId, Guid? SupplierEntityId, Guid? ProductId, string LedgerAccountCode, string XeroAccountCode, bool Active);
}
