@page "/commerce-ops"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["Ops.Title"]</h1>
<p style="color:#4b5563; max-width:900px;">
    @L["Ops.Intro"]
</p>

<section style="border:1px solid #e5e7eb; border-radius:8px; padding:1rem; margin:1rem 0; background:white;">
    <h2>@L["Ops.TenantContext"]</h2>
    <div style="display:flex; gap:.5rem; align-items:end; flex-wrap:wrap;">
        <label>@L["Common.TenantId"]<br /><input @bind="_tenantId" style="width:24rem; padding:.4rem;" title="@L["Ops.TenantId.Tip"]" /></label>
        <button @onclick="LoadStorefronts" title="@L["Ops.LoadStorefronts.Tip"]" style="padding:.45rem .8rem;">@L["Ops.LoadStorefronts"]</button>
    </div>
</section>

@if (_status is not null)
{
    <p style="color:#047857;">@_status</p>
}
@if (_error is not null)
{
    <p style="color:#b91c1c;">@_error</p>
    @if (_transitionReadiness is not null && !_transitionReadiness.IsReady)
    {
        <p style="color:#b91c1c; margin:.1rem 0;">@L["Ops.NotReadyIntro"]</p>
        <ul style="color:#b91c1c; margin:.1rem 0;">
            @foreach (var missing in _transitionReadiness.MissingRequirements)
            {
                <li>@missing</li>
            }
        </ul>
    }
}

<section style="border:1px solid #e5e7eb; border-radius:8px; padding:1rem; margin:1rem 0; background:white;">
    <h2>@L["Ops.Storefronts"]</h2>
    <div style="display:flex; gap:.5rem; align-items:end; flex-wrap:wrap; margin-bottom:1rem;">
        <label>@L["Ops.Field.Name"]<br /><input @bind="_newStorefrontName" style="padding:.4rem;" title="@L["Ops.Field.Name.Tip"]" /></label>
        <label>@L["Ops.Field.PublicUrl"]<br /><input @bind="_newPublicUrl" placeholder="http://localhost:3000/au" style="padding:.4rem;" title="@L["Ops.Field.PublicUrl.Tip"]" /></label>
        <label>@L["Ops.Field.Currency"]<br /><CurrencySelect @bind-Value="_newCurrency" style="padding:.4rem;" title="@L["Ops.Field.Currency.Tip"]" /></label>
        <label>@L["Ops.Field.TaxRegime"]<br />
            <select @bind="_newTaxRegime" style="padding:.4rem;" title="@L["Ops.Field.TaxRegime.Tip"]">
                <option value="0">@L["Ops.TaxRegime.None"]</option>
                <option value="1">@L["Ops.TaxRegime.AuGst"]</option>
                <option value="2">@L["Ops.TaxRegime.EuVat"]</option>
                <option value="3">@L["Ops.TaxRegime.UsSalesTax"]</option>
                <option value="99">@L["Ops.TaxRegime.Other"]</option>
            </select>
        </label>
        <label>@L["Ops.Field.TaxBps"]<br /><input type="number" @bind="_newTaxRateBasisPoints" style="width:6rem; padding:.4rem;" title="@L["Ops.Field.TaxBps.Tip"]" /></label>
        <label>@L["Ops.Field.Visibility"]<br />
            <select @bind="_newVisibility" style="padding:.4rem;" title="@L["Ops.Field.Visibility.Tip"]">
                <option value="1">@L["Ops.Visibility.Private"]</option>
                <option value="2">@L["Ops.Visibility.Password"]</option>
                <option value="3">@L["Ops.Visibility.InviteOnly"]</option>
                <option value="4">@L["Ops.Visibility.Public"]</option>
            </select>
        </label>
        <button @onclick="CreateStorefront" title="@L["Ops.CreateStorefront.Tip"]" style="padding:.45rem .8rem; background:#111827; color:#fff; border:0; border-radius:4px;">@L["Ops.CreateStorefront"]</button>
    </div>

    @if (_storefronts is null)
    {
        <p>@L["Ops.LoadPrompt"]</p>
    }
    else if (_storefronts.Count == 0)
    {
        <p>@L["Ops.NoStorefronts"]</p>
    }
    else
    {
        <table style="border-collapse:collapse;width:100%;">
            <thead><tr><th style="text-align:left;">@L["Ops.Field.Name"]</th><th>@L["Ops.Col.Url"]</th><th>@L["Ops.Col.Currency"]</th><th>@L["Ops.Col.Tax"]</th><th>@L["Ops.Col.State"]</th><th>@L["Ops.Col.Visibility"]</th><th>@L["Ops.Col.Domains"]</th><th></th></tr></thead>
            <tbody>
            @foreach (var s in _storefronts)
            {
                <tr style="border-top:1px solid #e5e7eb;">
                    <td>@s.Name<br /><span style="color:#6b7280; font-size:.8rem;">@s.Id</span></td>
                    <td>@(string.IsNullOrWhiteSpace(s.PublicUrl) ? "—" : s.PublicUrl)</td>
                    <td style="text-align:center;">@s.Currency</td>
                    <td style="text-align:center;">@TaxLabel(s)</td>
                    <td style="text-align:center;">@StateName(s.State)</td>
                    <td style="text-align:center;">@s.Visibility</td>
                    <td>@string.Join(", ", s.Domains.Select(d => d.Canonical ? $"{d.Host} (canonical)" : d.Host))</td>
                    <td style="text-align:right; white-space:nowrap;">
                        @* Only offer the transitions VALID from the current state — otherwise clicking e.g.
                           Preview on an already-Preview/Active storefront 400s ("state Preview cannot
                           perform this transition"). Draft→preview/pause · Preview→activate/pause ·
                           Active→pause · Paused→preview/activate · Archived→(none). *@
                        <button @onclick="() => SelectStorefront(s)" title="@L["Ops.Manage.Tip"]">@L["Ops.Manage"]</button>
                        @if (s.State is DraftState or PausedState)
                        {
                            <button @onclick='() => Transition(s.Id, "preview")' title="@L["Ops.Preview.Tip"]">@L["Ops.Preview"]</button>
                        }
                        @if (s.State is PreviewState or PausedState)
                        {
                            <button @onclick='() => Transition(s.Id, "activate")' title="@L["Ops.Activate.Tip"]">@L["Ops.Activate"]</button>
                        }
                        @if (s.State is DraftState or PreviewState or ActiveState)
                        {
                            <button @onclick='() => Transition(s.Id, "pause")' title="@L["Ops.Pause.Tip"]">@L["Ops.Pause"]</button>
                        }
                        @if (s.State != ArchivedState)
                        {
                            <button @onclick='() => Transition(s.Id, "archive")' title="@L["Ops.Archive.Tip"]" style="color:#b91c1c;">@L["Ops.Archive"]</button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

@if (_selectedStorefront is not null)
{
    <section style="border:1px solid #e5e7eb; border-radius:8px; padding:1rem; margin:1rem 0; background:white;">
        <h2>@L["Ops.ManageHeading", _selectedStorefront.Name]</h2>
        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:.5rem; align-items:end; margin-bottom:1rem;">
            <label>@L["Ops.Field.Name"]<br /><input @bind="_editName" style="padding:.4rem;" title="@L["Ops.Field.Name.Tip"]" /></label>
            <label>@L["Ops.Field.PublicUrl"]<br /><input @bind="_editPublicUrl" style="padding:.4rem;" title="@L["Ops.Field.PublicUrl.Tip"]" /></label>
            <label>@L["Ops.Field.Currency"]<br /><CurrencySelect @bind-Value="_editCurrency" style="padding:.4rem;" title="@L["Ops.Field.Currency.Tip"]" /></label>
            <label>@L["Ops.Field.TaxRegime"]<br />
                <select @bind="_editTaxRegime" style="padding:.4rem;" title="@L["Ops.Field.TaxRegime.Tip"]">
                    <option value="0">@L["Ops.TaxRegime.None"]</option>
                    <option value="1">@L["Ops.TaxRegime.AuGst"]</option>
                    <option value="2">@L["Ops.TaxRegime.EuVat"]</option>
                    <option value="3">@L["Ops.TaxRegime.UsSalesTax"]</option>
                    <option value="99">@L["Ops.TaxRegime.Other"]</option>
                </select>
            </label>
            <label>@L["Ops.Field.TaxBps"]<br /><input type="number" @bind="_editTaxRateBasisPoints" style="padding:.4rem;" title="@L["Ops.Field.TaxBps.Tip"]" /></label>
            <label>@L["Ops.Field.Visibility"]<br /><select @bind="_editVisibility" style="padding:.4rem;" title="@L["Ops.Field.Visibility.Tip"]"><option value="1">@L["Ops.Visibility.Private"]</option><option value="2">@L["Ops.Visibility.Password"]</option><option value="3">@L["Ops.Visibility.InviteOnly"]</option><option value="4">@L["Ops.Visibility.Public"]</option></select></label>
            <button @onclick="UpdateStorefront" title="@L["Ops.SaveSettings.Tip"]">@L["Ops.SaveSettings"]</button>
        </div>
        <div style="margin-bottom:1rem;">
            <label style="font-weight:600;">@L["Ops.Field.ShipTo"]
                <span style="font-weight:400; color:#6b7280;">— @L["Ops.ShipTo.Hint"]</span>
            </label>
            <select multiple @bind="_editShipTo" size="7" style="width:100%; padding:.4rem; margin-top:.25rem;" title="@L["Ops.Field.ShipTo.Tip"]">
                @foreach (var c in Countries.Common)
                {
                    <option value="@c">@(Countries.NameOf(c)) (@c)</option>
                }
                <option disabled>──────────</option>
                @foreach (var c in Countries.All.Where(x => !Countries.Common.Contains(x.Code)))
                {
                    <option value="@c.Code">@c.Name (@c.Code)</option>
                }
            </select>
            @if (_editShipTo.Length > 0)
            {
                <p style="margin:.25rem 0 0; font-size:.85rem; color:#374151;">@L["Ops.ShipTo.Selected"] <strong>@string.Join(", ", _editShipTo)</strong></p>
            }
        </div>
        <div style="display:flex; gap:.5rem; align-items:end; flex-wrap:wrap;">
            <label>@L["Ops.DomainHost"]<br /><input @bind="_domainHost" placeholder="@L["Ops.DomainHost.Placeholder"]" style="padding:.4rem;" title="@L["Ops.DomainHost.Tip"]" /></label>
            <label><input type="checkbox" @bind="_domainCanonical" title="@L["Ops.Canonical.Tip"]" /> @L["Ops.Canonical"]</label>
            <button @onclick="AddDomain" title="@L["Ops.AddDomain.Tip"]">@L["Ops.AddDomain"]</button>
            <button @onclick="CheckReadiness" title="@L["Ops.CheckReadiness.Tip"]">@L["Ops.CheckReadiness"]</button>
        </div>
        @if (_readiness is not null)
        {
            <p>@L["Ops.Readiness"] <strong>@(_readiness.IsReady ? L["Ops.Ready"] : L["Ops.NotReady"])</strong></p>
            @if (!_readiness.IsReady)
            {
                <ul>
                    @foreach (var missing in _readiness.MissingRequirements)
                    {
                        <li>@missing</li>
                    }
                </ul>
            }
        }

        <h3>@L["Ops.Publication"]</h3>
        <div style="display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:.5rem; align-items:end;">
            <label>@L["Ops.Field.ProductId"]<br /><input @bind="_assignProductId" style="width:100%; padding:.4rem;" title="@L["Ops.Field.ProductId.Tip"]" /></label>
            <label>@L["Ops.Field.SeoTitle"]<br /><input @bind="_seoTitle" style="width:100%; padding:.4rem;" title="@L["Ops.Field.SeoTitle.Tip"]" /></label>
            <label>@L["Ops.Field.Fulfillment"]<br />
                <select @bind="_fulfillmentSource" style="width:100%; padding:.4rem;" title="@L["Ops.Field.Fulfillment.Tip"]">
                    <option value="0">@L["Ops.Fulfillment.Unassigned"]</option>
                    <option value="1">@L["Ops.Fulfillment.Dropship"]</option>
                    <option value="2">@L["Ops.Fulfillment.OwnWarehouse"]</option>
                </select>
            </label>
        </div>
        <div style="display:flex; gap:.5rem; margin-top:.5rem;">
            <button @onclick="AssignProduct" title="@L["Ops.AssignProduct.Tip"]">@L["Ops.AssignProduct"]</button>
            <button @onclick="CheckProductReadiness" title="@L["Ops.ProductReadiness.Tip"]">@L["Ops.ProductReadiness"]</button>
            <button @onclick="PublishProduct" title="@L["Ops.Publish.Tip"]">@L["Ops.Publish"]</button>
            <button @onclick="UnpublishProduct" title="@L["Ops.Unpublish.Tip"]">@L["Ops.Unpublish"]</button>
        </div>
        @if (_publicationReadiness is not null)
        {
            <p>@L["Ops.PublicationReadiness"] <strong>@(_publicationReadiness.IsReady ? L["Ops.Ready"] : L["Ops.NotReady"])</strong></p>
            @if (!_publicationReadiness.IsReady)
            {
                <ul>
                    @foreach (var missing in _publicationReadiness.MissingRequirements)
                    {
                        <li>@missing</li>
                    }
                </ul>
            }
        }
    </section>
}

<section style="border:1px solid #e5e7eb; border-radius:8px; padding:1rem; margin:1rem 0; background:white;">
    <h2>@L["Ops.Policies"]</h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:1rem;">
        <PolicyCard Title="@L["Ops.Card.Pricing.Title"]" Body="@L["Ops.Card.Pricing.Body"]" Link="/offers" LinkText="@L["Ops.Card.Pricing.Link"]" LinkTitle="@L["Ops.Card.Link.Tip"]" />
        <PolicyCard Title="@L["Ops.Card.Payments.Title"]" Body="@L["Ops.Card.Payments.Body"]" Link="/payment-accounts" LinkText="@L["Ops.Card.Payments.Link"]" LinkTitle="@L["Ops.Card.Link.Tip"]" />
        <PolicyCard Title="@L["Ops.Card.Payouts.Title"]" Body="@L["Ops.Card.Payouts.Body"]" Link="/supplier-payouts" LinkText="@L["Ops.Card.Payouts.Link"]" LinkTitle="@L["Ops.Card.Link.Tip"]" />
        <PolicyCard Title="@L["Ops.Card.Xero.Title"]" Body="@L["Ops.Card.Xero.Body"]" Link="/xero-mappings" LinkText="@L["Ops.Card.Xero.Link"]" LinkTitle="@L["Ops.Card.Link.Tip"]" />
    </div>
</section>

@code {
    // StorefrontState (Catalog domain) numeric values — enums cross HTTP as numbers.
    private const int DraftState = 1, PreviewState = 2, ActiveState = 3, PausedState = 4, ArchivedState = 5;
    private static string StateName(int s) => s switch
    {
        DraftState => "Draft", PreviewState => "Preview", ActiveState => "Active",
        PausedState => "Paused", ArchivedState => "Archived", _ => s.ToString(),
    };

    private string _tenantId = "00000000-0000-0000-0000-000000000001";
    private string _newStorefrontName = string.Empty;
    private int _newVisibility = 1;
    private string _newPublicUrl = "http://localhost:3000/au";
    private string _newCurrency = "AUD";
    private int _newTaxRegime = 1;
    private int _newTaxRateBasisPoints = 1000;
    private List<StorefrontDto>? _storefronts;
    private StorefrontDto? _selectedStorefront;
    private string? _status;
    private string? _error;
    private string _domainHost = string.Empty;
    private bool _domainCanonical = true;
    private ReadinessDto? _readiness;

    // Readiness checklist shown under the error banner when a preview/activate transition is
    // refused — the ProblemDetails title alone ("One or more validation errors occurred.")
    // doesn't tell the operator WHAT the storefront is missing.
    private ReadinessDto? _transitionReadiness;
    private string _assignProductId = string.Empty;
    private string? _seoTitle;
    private int _fulfillmentSource;
    private ReadinessDto? _publicationReadiness;
    private string _editName = string.Empty;
    private string _editPublicUrl = string.Empty;
    private string _editCurrency = "EUR";
    private int _editTaxRegime;
    private int _editTaxRateBasisPoints;
    private int _editVisibility = 1;
    private string[] _editShipTo = [];

    private async Task LoadStorefronts()
    {
        _error = null;
        _transitionReadiness = null;
        _storefronts = await Gateway.GetListAsync<StorefrontDto>($"/api/catalog/admin/storefronts?tenantId={Uri.EscapeDataString(_tenantId)}");
    }

    private async Task CreateStorefront()
    {
        _error = null;
        var response = await Gateway.PostAsync("/api/catalog/admin/storefronts", new { tenantId = Guid.Parse(_tenantId), name = _newStorefrontName, visibility = _newVisibility, publicUrl = _newPublicUrl, currency = _newCurrency, taxRegime = _newTaxRegime, taxRateBasisPoints = _newTaxRateBasisPoints });
        // LoadStorefronts clears _error, so refresh FIRST then report the outcome (D3: errors were being wiped).
        await LoadStorefronts();
        if (await HandleMutation(response, L["Ops.Status.StorefrontCreated"]))
        {
            ResetCreateStorefrontForm();
        }
    }

    private void SelectStorefront(StorefrontDto storefront)
    {
        _selectedStorefront = storefront;
        _readiness = null;
        _publicationReadiness = null;
        _editName = storefront.Name;
        _editPublicUrl = storefront.PublicUrl;
        _editCurrency = storefront.Currency;
        _editTaxRegime = storefront.TaxRegime;
        _editTaxRateBasisPoints = storefront.TaxRateBasisPoints;
        _editVisibility = storefront.Visibility;
        _editShipTo = storefront.ShipToCountries?.ToArray() ?? [];
    }

    private async Task UpdateStorefront()
    {
        if (_selectedStorefront is null) return;
        var selectedId = _selectedStorefront.Id;
        // Enums cross HTTP as numbers (platform invariant); the <select>s bind to int fields, so
        // visibility/taxRegime already serialize as numeric enum values here.
        var response = await Gateway.PutAsync($"/api/catalog/admin/storefronts/{selectedId}", new { name = _editName, visibility = _editVisibility, publicUrl = _editPublicUrl, currency = _editCurrency, taxRegime = _editTaxRegime, taxRateBasisPoints = _editTaxRateBasisPoints, shipToCountries = _editShipTo });
        await LoadStorefronts();
        if (await HandleMutation(response, L["Ops.Status.SettingsUpdated"]))
        {
            // On success, close the manage form. Leaving it open re-showed the saved storefront and
            // could later display THIS storefront's values when managing a different one (stale form).
            CloseManageForm();
        }
        else
        {
            // Keep the form open on failure so the operator can correct and retry.
            _selectedStorefront = _storefronts?.FirstOrDefault(s => s.Id == selectedId);
        }
    }

    private void CloseManageForm()
    {
        _selectedStorefront = null;
        _readiness = null;
        _publicationReadiness = null;
    }

    private async Task Transition(Guid id, string transition)
    {
        var response = await Gateway.PostAsync($"/api/catalog/admin/storefronts/{id}/{transition}");
        // Refresh FIRST — LoadStorefronts clears _error, so a failed transition (e.g. Activate on a
        // not-ready storefront) must set its feedback AFTER the reload or it would be swallowed (D3).
        await LoadStorefronts();
        if (_selectedStorefront?.Id == id)
        {
            _selectedStorefront = _storefronts?.FirstOrDefault(s => s.Id == id);
        }

        if (!await HandleMutation(response, L["Ops.Status.Transition", transition])
            && transition is "preview" or "activate")
        {
            // Show the concrete readiness blockers (e.g. "one canonical domain") next to the error.
            _transitionReadiness = await Gateway.GetAsync<ReadinessDto>($"/api/catalog/admin/storefronts/{id}/readiness");
        }
    }

    private async Task AddDomain()
    {
        if (_selectedStorefront is null) return;
        var response = await Gateway.PostAsync($"/api/catalog/admin/storefronts/{_selectedStorefront.Id}/domains", new { host = _domainHost, canonical = _domainCanonical });
        // Refresh FIRST — LoadStorefronts clears _error, so a failed add (server error) is set AFTER (D3).
        await LoadStorefronts();
        await HandleMutation(response, L["Ops.Status.DomainAdded"]);
    }

    private async Task CheckReadiness()
    {
        if (_selectedStorefront is null) return;
        _readiness = await Gateway.GetAsync<ReadinessDto>($"/api/catalog/admin/storefronts/{_selectedStorefront.Id}/readiness");
    }

    private async Task AssignProduct()
    {
        if (_selectedStorefront is null || !Guid.TryParse(_assignProductId, out var productId)) return;
        var response = await Gateway.PostAsync($"/api/catalog/admin/storefronts/{_selectedStorefront.Id}/products", new
        {
            productId,
            seoTitle = _seoTitle,
            fulfillmentSource = _fulfillmentSource,
            countryOfOrigin = "AU",
        });
        await HandleMutation(response, L["Ops.Status.ProductAssigned"]);
    }

    private async Task CheckProductReadiness()
    {
        if (_selectedStorefront is null || !Guid.TryParse(_assignProductId, out var productId)) return;
        _publicationReadiness = await Gateway.GetAsync<ReadinessDto>($"/api/catalog/admin/storefronts/{_selectedStorefront.Id}/products/{productId}/readiness");
    }

    private Task PublishProduct() => ProductTransition("publish", L["Ops.Status.ProductPublish"]);
    private Task UnpublishProduct() => ProductTransition("unpublish", L["Ops.Status.ProductUnpublish"]);

    private async Task ProductTransition(string transition, string message)
    {
        if (_selectedStorefront is null || !Guid.TryParse(_assignProductId, out var productId)) return;
        var response = await Gateway.PostAsync($"/api/catalog/admin/storefronts/{_selectedStorefront.Id}/products/{productId}/{transition}");
        await HandleMutation(response, message);
    }

    private async Task<bool> HandleMutation(HttpResponseMessage response, string success)
    {
        _transitionReadiness = null; // only a failed preview/activate re-populates it (right after this call)
        if (response.IsSuccessStatusCode)
        {
            _status = success;
            _error = null;
            return true;
        }

        _status = null;
        _error = L["Ops.Error.RequestFailed", (int)response.StatusCode, await GatewayError.ReadAsync(response)];
        return false;
    }

    private void ResetCreateStorefrontForm()
    {
        _newStorefrontName = string.Empty;
        _newPublicUrl = string.Empty;
        _newCurrency = "AUD";
        _newTaxRegime = 1;
        _newTaxRateBasisPoints = 1000;
        _newVisibility = 1;
    }

    private string TaxLabel(StorefrontDto s) => s.TaxRegime == 0 ? L["Ops.TaxRegime.None"] : $"{s.TaxRegime} · {s.TaxRateBasisPoints / 100m:0.##}%";

    public sealed record StorefrontDto(Guid Id, Guid TenantId, string Name, int State, int Visibility, string PublicUrl, string Currency, int TaxRegime, int TaxRateBasisPoints, List<StorefrontDomainDto> Domains, List<string>? ShipToCountries = null);
    public sealed record StorefrontDomainDto(Guid Id, string Host, bool Canonical);
    public sealed record ReadinessDto(bool IsReady, List<string> MissingRequirements);
}
