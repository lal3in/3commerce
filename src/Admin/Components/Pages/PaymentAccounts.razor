@page "/payment-accounts"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender
@using System.Net.Http.Json

<div style="display:flex; align-items:baseline; gap:1rem;">
    <h1 style="margin:0;">@L["Pay.Title"]</h1>
    <span style="color:#6b7280; font-size:.85rem;">@L["Pay.Subtitle"]</span>
</div>
<p style="color:#6b7280;">@L["Pay.Intro"]</p>

<div style="display:flex; gap:.6rem; align-items:end; margin:1rem 0;">
    <label>@L["Common.TenantId"]
        <input @bind="_tenantId" title="@L["Pay.TenantId.Tip"]" style="width:23rem; display:block;" />
    </label>
    <button @onclick="LoadAsync" title="@L["Common.Load.Tip"]" style="padding:.45rem .8rem;">@L["Common.Load"]</button>
</div>

@if (_error is not null)
{
    <p style="color:#b91c1c;">@_error</p>
}
@if (_status is not null)
{
    <p style="color:#047857;">@_status</p>
}

@if (_accounts is not null)
{
    <table style="width:100%; border-collapse:collapse; font-size:.9rem;">
        <thead>
            <tr style="text-align:left; border-bottom:2px solid #e5e7eb;">
                <th style="padding:.4rem;">@L["Pay.Field.Name"]</th><th>@L["Pay.Col.Provider"]</th><th>@L["Pay.Col.Mode"]</th><th>@L["Pay.Col.State"]</th><th>@L["Pay.Col.Default"]</th><th>@L["Pay.Col.ExtRef"]</th><th>@L["Common.Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var a in _accounts)
        {
            <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:.4rem;">@a.Name</td>
                <td>@a.Provider</td>
                <td>@a.Mode</td>
                <td>@StateBadge(a.State)</td>
                <td style="text-align:center;">@(a.IsDefaultForTenant ? "★" : "")</td>
                <td><code style="font-size:.78rem;">@(a.ExternalAccountRef ?? "—")</code></td>
                <td style="white-space:nowrap;">
                    @if (a.State != "Archived")
                    {
                        <button @onclick="() => StartEdit(a)" title="@L["Pay.Edit.Tip"]">@L["Common.Edit"]</button>
                    }
                    @if (a.State != "Archived" && !a.IsDefaultForTenant)
                    {
                        <button @onclick="() => MakeDefault(a.Id)" title="@L["Pay.MakeDefault.Tip"]">@L["Pay.MakeDefault"]</button>
                    }
                    @if (a.State == "Draft")
                    {
                        <button @onclick='() => Act(a.Id, "submit")' title="@L["Pay.Submit.Tip"]">@L["Pay.Submit"]</button>
                    }
                    @if (a.State is "PendingApproval" or "Suspended")
                    {
                        <button @onclick='() => Act(a.Id, "activate")' title="@L["Pay.Activate.Tip"]">@L["Pay.Activate"]</button>
                    }
                    @if (a.State == "Active")
                    {
                        <button @onclick='() => Act(a.Id, "suspend")' title="@L["Pay.Suspend.Tip"]">@L["Pay.Suspend"]</button>
                    }
                    @if (a.State != "Archived")
                    {
                        <button @onclick='() => Act(a.Id, "archive")' title="@L["Pay.Archive.Tip"]" style="color:#b91c1c;">@L["Pay.Archive"]</button>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
    @if (_accounts.Count == 0)
    {
        <p style="color:#9ca3af;">@L["Pay.Empty"]</p>
    }

    @if (_edit is not null)
    {
        <section style="margin-top:1.5rem; border:1px solid #e5e7eb; border-radius:8px; padding:1rem; max-width:560px;">
            <h2 style="margin-top:0; font-size:1.1rem;">@L["Pay.EditHeading"]</h2>
            <div style="display:flex; flex-direction:column; gap:.5rem;">
                <label>@L["Pay.Field.Name"] <input @bind="_edit.Name" title="@L["Pay.Field.Name.Tip"]" style="width:100%;" /></label>
                <label>@L["Pay.Field.Provider"] <input @bind="_edit.Provider" disabled="@_edit.IsActive" title="@(_edit.IsActive ? L["Pay.Field.Provider.LockedTip"] : L["Pay.Field.Provider.Tip"])" style="width:100%;" /></label>
                <label>@L["Pay.Field.Mode"]
                    <select @bind="_edit.Mode" disabled="@_edit.IsActive" title="@(_edit.IsActive ? L["Pay.Field.Mode.LockedTip"] : L["Pay.Field.Mode.Tip"])" style="width:100%;">
                        <option value="1">@L["Pay.Mode.Test"]</option>
                        <option value="2">@L["Pay.Mode.Live"]</option>
                    </select>
                </label>
                <label>@L["Pay.Field.ExtRef"] <input @bind="_edit.ExternalAccountRef" title="@L["Pay.Field.ExtRef.Tip"]" style="width:100%;" /></label>
                <div style="display:flex; gap:.5rem;">
                    <button @onclick="SaveEdit" title="@L["Common.Save.Tip"]" style="padding:.45rem .9rem; background:#111827; color:#fff; border:0; border-radius:5px;">@L["Common.Save"]</button>
                    <button @onclick="() => _edit = null" title="@L["Common.Cancel.Tip"]" style="padding:.45rem .9rem;">@L["Common.Cancel"]</button>
                </div>
            </div>
        </section>
    }

    <section style="margin-top:1.5rem; border:1px solid #e5e7eb; border-radius:8px; padding:1rem; max-width:560px;">
        <h2 style="margin-top:0; font-size:1.1rem;">@L["Pay.NewHeading"]</h2>
        <div style="display:flex; flex-direction:column; gap:.5rem;">
            <label>@L["Pay.Field.Name"] <input @bind="_new.Name" title="@L["Pay.Field.Name.Tip"]" style="width:100%;" /></label>
            <label>@L["Pay.Field.Provider"] <input @bind="_new.Provider" title="@L["Pay.Field.Provider.Tip"]" style="width:100%;" /></label>
            <label>@L["Pay.Field.Mode"]
                <select @bind="_new.Mode" title="@L["Pay.Field.Mode.Tip"]" style="width:100%;">
                    <option value="1">@L["Pay.Mode.Test"]</option>
                    <option value="2">@L["Pay.Mode.Live"]</option>
                </select>
            </label>
            <label>@L["Pay.Field.ExtRef"] <input @bind="_new.ExternalAccountRef" title="@L["Pay.Field.ExtRef.Tip"]" style="width:100%;" /></label>
            <label style="display:flex; gap:.4rem; align-items:center;">
                <input type="checkbox" @bind="_new.IsDefaultForTenant" title="@L["Pay.Field.Default.Tip"]" /> @L["Pay.Field.Default"]
            </label>
            <button @onclick="Create" title="@L["Pay.Create.Tip"]" style="padding:.45rem .9rem; background:#111827; color:#fff; border:0; border-radius:5px; align-self:flex-start;">@L["Pay.Create"]</button>
        </div>
    </section>
}

@code {
    private string _tenantId = "00000000-0000-0000-0000-000000000001";
    private List<PaymentAccountDto>? _accounts;
    private string? _status;
    private string? _error;
    private readonly NewAccount _new = new();
    private EditAccount? _edit;

    private async Task LoadAsync()
    {
        _error = _status = null;
        try
        {
            _accounts = await Gateway.GetListAsync<PaymentAccountDto>($"/api/payments/admin/payment-accounts?tenantId={Uri.EscapeDataString(_tenantId)}");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task Create()
    {
        _error = _status = null;
        var body = new { tenantId = Guid.Parse(_tenantId), name = _new.Name, provider = _new.Provider, mode = _new.Mode, isDefaultForTenant = _new.IsDefaultForTenant, externalAccountRef = string.IsNullOrWhiteSpace(_new.ExternalAccountRef) ? null : _new.ExternalAccountRef };
        var response = await Gateway.PostAsync("/api/payments/admin/payment-accounts", body);
        if (response.IsSuccessStatusCode)
        {
            _new.Reset();
            await LoadAsync(); // clears _status/_error, so set the confirmation AFTER the reload
            _status = L["Pay.Status.Created"];
        }
        else { _error = await ErrorText(response); }
    }

    private void StartEdit(PaymentAccountDto a) => _edit = new EditAccount
    {
        Id = a.Id,
        Name = a.Name,
        Provider = a.Provider,
        Mode = a.Mode == "Live" ? 2 : 1,
        ExternalAccountRef = a.ExternalAccountRef,
        IsActive = a.State == "Active",
    };

    private async Task SaveEdit()
    {
        if (_edit is null) { return; }
        _error = _status = null;
        var body = new { name = _edit.Name, provider = _edit.Provider, mode = _edit.Mode, externalAccountRef = string.IsNullOrWhiteSpace(_edit.ExternalAccountRef) ? null : _edit.ExternalAccountRef };
        var response = await Gateway.PutAsync($"/api/payments/admin/payment-accounts/{_edit.Id}", body);
        if (response.IsSuccessStatusCode)
        {
            _edit = null;
            await LoadAsync(); // clears _status/_error, so set the confirmation AFTER the reload
            _status = L["Pay.Status.Updated"];
        }
        else { _error = await ErrorText(response); }
    }

    private async Task MakeDefault(Guid id)
    {
        _error = _status = null;
        var response = await Gateway.PostAsync($"/api/payments/admin/payment-accounts/{id}/make-default");
        if (response.IsSuccessStatusCode)
        {
            await LoadAsync();
            _status = L["Pay.Status.Default"];
        }
        else { _error = await ErrorText(response); }
    }

    private async Task Act(Guid id, string action)
    {
        _error = _status = null;
        var response = await Gateway.PostAsync($"/api/payments/admin/payment-accounts/{id}/{action}");
        if (response.IsSuccessStatusCode)
        {
            await LoadAsync();
            _status = action switch
            {
                "submit" => L["Pay.Status.Submitted"],
                "activate" => L["Pay.Status.Activated"],
                "suspend" => L["Pay.Status.Suspended"],
                "archive" => L["Pay.Status.Archived"],
                _ => L["Pay.Status.Updated"],
            };
        }
        else { _error = await ErrorText(response); }
    }

    // Empty failure bodies (e.g. a bare 404) used to render as an invisible error; always include the status code.
    private async Task<string> ErrorText(HttpResponseMessage response)
    {
        var body = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(body)
            ? L["Pay.Error.RequestFailed", (int)response.StatusCode, response.StatusCode]
            : $"({(int)response.StatusCode}) {body}";
    }

    private static string StateBadge(string state) => state;

    private sealed class NewAccount
    {
        public string Name { get; set; } = string.Empty;
        public string Provider { get; set; } = "stripe";
        // PaymentProviderMode enum binds as a number over JSON (Test=1, Live=2).
        public int Mode { get; set; } = 1;
        public string? ExternalAccountRef { get; set; }
        public bool IsDefaultForTenant { get; set; }
        public void Reset() { Name = string.Empty; Provider = "stripe"; Mode = 1; ExternalAccountRef = null; IsDefaultForTenant = false; }
    }

    private sealed class EditAccount
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Provider { get; set; } = string.Empty;
        // PaymentProviderMode enum binds as a number over JSON (Test=1, Live=2).
        public int Mode { get; set; } = 1;
        public string? ExternalAccountRef { get; set; }
        public bool IsActive { get; set; }
    }

    private record PaymentAccountDto(Guid Id, Guid TenantId, Guid? StorefrontId, string Name, string Provider, string Mode, string State, bool IsDefaultForTenant, string? ExternalAccountRef, DateTimeOffset CreatedAt);
}
