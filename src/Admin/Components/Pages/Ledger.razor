@page "/ledger"
@attribute [Authorize(Roles = "admin")]
@rendermode AdminRenderModes.InteractiveServerNoPrerender
@inject GatewayClient Gateway

<h1>@L["Ledger.Title"]</h1>
@if (_entries is null) { <p>@L["Common.Loading"]</p> }
else
{
    <table style="border-collapse:collapse;width:100%;">
        <thead><tr><th style="text-align:left;">@L["Ledger.Col.When"]</th><th style="text-align:left;">@L["Ledger.Col.Description"]</th><th>@L["Ledger.Col.Reference"]</th><th>@L["Ledger.Col.Currency"]</th><th>@L["Ledger.Col.Lines"]</th></tr></thead>
        <tbody>
        @foreach (var e in _entries)
        {
            <tr style="border-top:1px solid #e5e7eb;"><td>@e.CreatedAt.LocalDateTime.ToString("dd MMM HH:mm")</td><td>@e.Description</td><td>@e.Reference</td><td style="text-align:center;">@e.Currency</td>
                <td>@string.Join(", ", e.Lines.Select(l => $"{l.AccountCode} {(l.DebitMinor>0?"D":"C")}{(l.DebitMinor>0?l.DebitMinor:l.CreditMinor)/100m:0.00}"))</td></tr>
        }
        </tbody>
    </table>
}
@code {
    private List<EntryDto>? _entries;
    protected override async Task OnInitializedAsync() => _entries = await Gateway.GetListAsync<EntryDto>("/api/payments/admin/ledger/entries");
    public record LineDto(string AccountCode, long DebitMinor, long CreditMinor);
    public record EntryDto(Guid Id, string Description, string Reference, string Currency, DateTimeOffset CreatedAt, List<LineDto> Lines);
}
