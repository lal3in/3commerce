@page "/catalog"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["Catalog.Title"]</h1>

@if (_editing is null)
{
    <div style="margin-bottom:1rem; display:flex; gap:.5rem;">
        <input @bind="_search" @bind:event="oninput" placeholder="@L["Catalog.Search.Placeholder"]" style="flex:1; padding:.4rem;" title="@L["Catalog.Search.Tip"]" />
        <button @onclick="LoadList" title="@L["Catalog.Search.Button.Tip"]" style="padding:.4rem .8rem;">@L["Common.Search"]</button>
        <button @onclick="NewProduct" title="@L["Catalog.New.Tip"]" style="padding:.4rem .8rem; background:#111827; color:#fff; border:0; border-radius:4px;">@L["Catalog.New"]</button>
    </div>

    <div style="margin-bottom:1rem; padding:.5rem .6rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:4px; display:flex; align-items:center; gap:.6rem;">
        <label style="display:flex; align-items:center; gap:.4rem;" title="@L["Catalog.Settings.RequireShipRules.Tip"]">
            <input type="checkbox" @bind="_requireShipRules" />
            <span>@L["Catalog.Settings.RequireShipRules"]</span>
        </label>
        <button @onclick="SaveSettings" disabled="@_savingSettings" title="@L["Catalog.Settings.Save.Tip"]" style="padding:.3rem .7rem;">@L["Catalog.Settings.Save"]</button>
    </div>

    @if (_status is not null)
    {
        <p style="color:#047857;">@_status</p>
    }

    @if (_list is null)
    {
        <p>@L["Common.Loading"]</p>
    }
    else if (_list.Count == 0)
    {
        <p>@L["Catalog.Empty"]</p>
    }
    else
    {
        <table style="border-collapse:collapse;width:100%;">
            <thead><tr><th style="width:3rem;"></th><th style="text-align:left;">@L["Catalog.Col.Title"]</th><th>@L["Catalog.Col.Brand"]</th><th>@L["Catalog.Col.Type"]</th><th>@L["Catalog.Col.Variants"]</th><th>@L["Catalog.Col.From"]</th><th>@L["Catalog.Col.Stock"]</th><th></th></tr></thead>
            <tbody>
            @foreach (var p in _list)
            {
                <tr style="border-top:1px solid #e5e7eb;">
                    <td>@if (!string.IsNullOrWhiteSpace(p.ImageUrl)) { <img src="@p.ImageUrl" alt="" style="width:2.6rem; height:2.6rem; object-fit:cover; border-radius:4px; border:1px solid #e5e7eb;" /> } else { <span style="color:#d1d5db;">—</span> }</td>
                    <td>@p.Title<br /><span style="color:#6b7280; font-size:.8rem;">@p.Slug</span></td>
                    <td>@p.Brand</td>
                    <td style="text-align:center;"><span style="background:#f3f4f6; border-radius:4px; padding:.1rem .4rem; font-size:.78rem;">@ProductTypeLabel(p.ProductType)</span></td>
                    <td style="text-align:center;">@p.VariantCount</td>
                    <td style="text-align:right;">@($"{p.MinPriceMinor / 100m:0.00}")</td>
                    <td style="text-align:center;">@p.TotalStock</td>
                    <td style="text-align:right; white-space:nowrap;">
                        <button @onclick="() => EditProduct(p.Id)" title="@L["Catalog.Edit.Tip"]" style="padding:.2rem .6rem;">@L["Common.Edit"]</button>
                        <button @onclick="() => DeleteProduct(p.Id)" title="@L["Catalog.Delete.Tip"]" style="padding:.2rem .6rem; color:#b91c1c;">@L["Common.Delete"]</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}
else
{
    <h2>@(_isNew ? L["Catalog.New"] : L["Catalog.EditProduct"])</h2>
    @if (_error is not null)
    {
        <p style="color:#b91c1c;">@_error</p>
    }

    <div style="max-width:720px; display:flex; flex-direction:column; gap:.6rem;">
        <label>@L["Catalog.Field.Title"] <input @bind="_editing.Title" style="width:100%; padding:.4rem;" title="@L["Catalog.Field.Title.Tip"]" /></label>
        <label>@L["Catalog.Field.Slug"] <input @bind="_editing.Slug" style="width:100%; padding:.4rem;" title="@L["Catalog.Field.Slug.Tip"]" /></label>
        <label>@L["Catalog.Field.Brand"] <input @bind="_editing.Brand" style="width:100%; padding:.4rem;" title="@L["Catalog.Field.Brand.Tip"]" /></label>
        <label>@L["Catalog.Field.Description"] <textarea @bind="_editing.Description" rows="3" style="width:100%; padding:.4rem;" title="@L["Catalog.Field.Description.Tip"]"></textarea></label>
        <label>@L["Catalog.Field.Category"] <span style="color:#6b7280; font-size:.8rem;">@L["Catalog.Field.Category.Hint"]</span>
            <select @bind="_editing.CategoryId" style="width:100%; padding:.4rem;" title="@L["Catalog.Field.Category.Tip"]">
                @foreach (var c in _categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </label>
        <label>@L["Catalog.Field.ProductType"] <span style="color:#6b7280; font-size:.8rem;">@L["Catalog.Field.ProductType.Hint"]</span>
            <select @bind="_editing.ProductType" style="width:100%; padding:.4rem;" title="@L["Catalog.Field.ProductType.Tip"]">
                <option value="1">@L["Catalog.Type.Physical"]</option>
                <option value="2">@L["Catalog.Type.Digital"]</option>
                <option value="3">@L["Catalog.Type.Service"]</option>
                <option value="4">@L["Catalog.Type.Bundle"]</option>
                <option value="5">@L["Catalog.Type.Subscription"]</option>
                <option value="6">@L["Catalog.Type.Usage"]</option>
            </select>
        </label>

        <fieldset style="border:1px solid #e5e7eb; padding:.6rem;">
            <legend>@L["Catalog.Variants"]</legend>
            <table style="width:100%; border-collapse:collapse;">
                <thead><tr><th style="text-align:left;">@L["Catalog.Variant.Sku"]</th><th>@L["Catalog.Variant.Price"]</th><th>@L["Catalog.Variant.Currency"]</th><th>@L["Catalog.Variant.Stock"]</th><th></th></tr></thead>
                <tbody>
                @foreach (var v in _editing.Variants)
                {
                    <tr>
                        <td><input @bind="v.Sku" style="width:100%;" title="@L["Catalog.Variant.Sku.Tip"]" /></td>
                        <td><input type="number" @bind="v.PriceMinor" style="width:6rem;" title="@L["Catalog.Variant.Price.Tip"]" /></td>
                        <td><CurrencySelect @bind-Value="v.Currency" style="width:11rem;padding:.2rem;" /></td>
                        <td><input type="number" @bind="v.StockQuantity" style="width:5rem;" title="@L["Catalog.Variant.Stock.Tip"]" /></td>
                        <td><button @onclick="() => _editing.Variants.Remove(v)" title="@L["Catalog.Variant.Remove.Tip"]" style="color:#b91c1c;">✕</button></td>
                    </tr>
                    <tr>
                        <td colspan="5" style="padding:.2rem .4rem .8rem 1.5rem; background:#f9fafb;">
                            <span style="font-size:.8rem; color:#6b7280;">@L["Catalog.Prices.Note"]</span>
                            @foreach (var pr in v.Prices)
                            {
                                <span style="display:inline-flex; gap:.2rem; align-items:center; margin-left:.5rem;">
                                    <CurrencySelect @bind-Value="pr.Currency" style="width:8rem;padding:.15rem;" />
                                    <input type="number" @bind="pr.PriceMinor" style="width:6rem;" title="@L["Catalog.Prices.Price.Tip"]" />
                                    <button @onclick="() => v.Prices.Remove(pr)" style="color:#b91c1c;" title="@L["Catalog.Prices.Remove.Tip"]">✕</button>
                                </span>
                            }
                            <button @onclick="() => v.Prices.Add(new CurrencyPrice())" title="@L["Catalog.Prices.Add.Tip"]" style="margin-left:.5rem;">@L["Catalog.Prices.Add"]</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            <button @onclick="AddVariant" title="@L["Catalog.Variant.Add.Tip"]" style="margin-top:.4rem;">@L["Catalog.Variant.Add"]</button>
        </fieldset>

        <fieldset style="border:1px solid #e5e7eb; padding:.6rem;">
            <legend>@L["Catalog.Images"]</legend>
            @for (var i = 0; i < _editing.ImageUrls.Count; i++)
            {
                var idx = i;
                <div style="display:flex; gap:.3rem; margin-bottom:.3rem; align-items:center;">
                    <div style="flex:1;"><ImageInput Value="@_editing.ImageUrls[idx]" ValueChanged="@(v => _editing.ImageUrls[idx] = v ?? string.Empty)" /></div>
                    <button @onclick="() => _editing.ImageUrls.RemoveAt(idx)" title="@L["Catalog.Image.Remove.Tip"]" style="color:#b91c1c;">✕</button>
                </div>
            }
            <button @onclick="() => _editing.ImageUrls.Add(string.Empty)" title="@L["Catalog.Image.Add.Tip"]">@L["Catalog.Image.Add"]</button>
        </fieldset>

        <fieldset style="border:1px solid #e5e7eb; padding:.6rem;">
            <legend>@L["Catalog.Attributes"]</legend>
            @foreach (var a in _attributes)
            {
                <div style="display:flex; gap:.3rem; margin-bottom:.3rem;">
                    <input @bind="a.Key" placeholder="@L["Catalog.Attr.Key"]" style="width:10rem;" title="@L["Catalog.Attr.Key.Tip"]" />
                    <input @bind="a.Value" placeholder="@L["Catalog.Attr.Value"]" style="flex:1;" title="@L["Catalog.Attr.Value.Tip"]" />
                    <button @onclick="() => _attributes.Remove(a)" title="@L["Catalog.Attr.Remove.Tip"]" style="color:#b91c1c;">✕</button>
                </div>
            }
            <button @onclick="() => _attributes.Add(new())" title="@L["Catalog.Attr.Add.Tip"]">@L["Catalog.Attr.Add"]</button>
        </fieldset>

        <fieldset style="border:1px solid #e5e7eb; padding:.6rem;">
            <legend title="@L["Catalog.ShipRules.Tip"]">@L["Catalog.ShipRules"]</legend>
            <p style="margin:0 0 .4rem; font-size:.8rem; color:#6b7280;">@L["Catalog.ShipRules.Hint"]</p>
            @if (_requireShipRules)
            {
                <p style="margin:0 0 .4rem; font-size:.8rem; color:#b45309;" title="@L["Catalog.ShipRules.Required.Tip"]">@L["Catalog.ShipRules.Required"]</p>
            }
            <table style="width:100%; border-collapse:collapse;">
                <thead><tr><th style="text-align:left;">@L["Catalog.ShipRule.Country"]</th><th>@L["Catalog.ShipRule.ChargeTax"]</th><th>@L["Catalog.ShipRule.ShippingCovered"]</th><th></th></tr></thead>
                <tbody>
                @foreach (var r in _editing.ShipRules)
                {
                    <tr>
                        <td>
                            <select @bind="r.CountryCode" style="width:100%; padding:.3rem;" title="@L["Catalog.ShipRule.Country.Tip"]">
                                <option value="*">@L["Catalog.ShipRule.AllCountries"]</option>
                                @foreach (var c in Countries.Common)
                                {
                                    <option value="@c">@(Countries.NameOf(c)) (@c)</option>
                                }
                                @foreach (var c in Countries.All.Where(x => !Countries.Common.Contains(x.Code)))
                                {
                                    <option value="@c.Code">@c.Name (@c.Code)</option>
                                }
                            </select>
                        </td>
                        <td style="text-align:center;"><input type="checkbox" @bind="r.ChargeDestinationTax" title="@L["Catalog.ShipRule.ChargeTax.Tip"]" /></td>
                        <td style="text-align:center;"><input type="checkbox" @bind="r.ShippingCovered" title="@L["Catalog.ShipRule.ShippingCovered.Tip"]" /></td>
                        <td style="text-align:right;"><button @onclick="() => _editing.ShipRules.Remove(r)" title="@L["Catalog.ShipRule.Remove.Tip"]" style="color:#b91c1c;">✕</button></td>
                    </tr>
                }
                </tbody>
            </table>
            <button @onclick="AddShipRule" title="@L["Catalog.ShipRule.Add.Tip"]" style="margin-top:.4rem;">@L["Catalog.ShipRule.Add"]</button>
        </fieldset>

        <div style="display:flex; gap:.5rem;">
            <button @onclick="Save" disabled="@_saving" title="@L["Catalog.Save.Tip"]" style="padding:.4rem 1rem; background:#111827; color:#fff; border:0; border-radius:4px;">@(_saving ? L["Common.Saving"] : L["Common.Save"])</button>
            <button @onclick="Cancel" title="@L["Common.Cancel.Tip"]" style="padding:.4rem 1rem;">@L["Common.Cancel"]</button>
        </div>
    </div>
}

@code {
    private const string Base = "/api/catalog/admin/products";
    private List<ProductListItem>? _list;
    private List<CategoryDto> _categories = [];
    private string _search = string.Empty;
    private string? _status;
    private string? _error;
    private bool _saving;

    private ProductEditor? _editing;
    private bool _isNew;
    private readonly List<KeyValueRow> _attributes = [];

    private const string SettingsBase = "/api/catalog/admin/settings";
    private bool _requireShipRules;
    private bool _savingSettings;

    protected override async Task OnInitializedAsync()
    {
        _categories = await Gateway.GetListAsync<CategoryDto>("/api/catalog/categories");
        var settings = await Gateway.GetAsync<CatalogSettingsDto>(SettingsBase);
        _requireShipRules = settings?.RequireProductShipRules ?? false;
        await LoadList();
    }

    private async Task SaveSettings()
    {
        _savingSettings = true;
        var resp = await Gateway.PutAsync(SettingsBase, new { requireProductShipRules = _requireShipRules });
        _savingSettings = false;
        _status = resp.IsSuccessStatusCode ? L["Catalog.Settings.Saved"] : L["Catalog.Status.SaveFailed", (int)resp.StatusCode, string.Empty];
    }

    private void AddShipRule() => _editing!.ShipRules.Add(new ShipRuleEditor());

    private async Task LoadList()
    {
        var q = string.IsNullOrWhiteSpace(_search) ? string.Empty : $"?q={Uri.EscapeDataString(_search)}";
        _list = await Gateway.GetListAsync<ProductListItem>($"{Base}{q}");
    }

    private string ProductTypeLabel(int type) => type switch
    {
        2 => L["Catalog.Type.Digital"],
        3 => L["Catalog.Type.Service"],
        4 => L["Catalog.Type.Bundle"],
        5 => L["Catalog.Type.Subscription"],
        6 => L["Catalog.Type.Usage"],
        _ => L["Catalog.Type.Physical"],
    };

    private void NewProduct()
    {
        _error = null;
        _isNew = true;
        _editing = new ProductEditor
        {
            CategoryId = _categories.FirstOrDefault()?.Id ?? Guid.Empty,
            Variants = { new VariantEditor { Currency = "EUR" } },
        };
        _attributes.Clear();
    }

    private async Task EditProduct(Guid id)
    {
        _error = null;
        var dto = await Gateway.GetAsync<ProductEditor>($"{Base}/{id}");
        if (dto is null)
        {
            _status = L["Catalog.Status.NotFound"];
            return;
        }

        _isNew = false;
        _editing = dto;
        _attributes.Clear();
        foreach (var kv in dto.Attributes)
        {
            _attributes.Add(new KeyValueRow { Key = kv.Key, Value = kv.Value });
        }
    }

    private async Task DeleteProduct(Guid id)
    {
        var resp = await Gateway.DeleteAsync($"{Base}/{id}");
        _status = resp.IsSuccessStatusCode ? L["Catalog.Status.Deleted"] : L["Catalog.Status.DeleteFailed", (int)resp.StatusCode];
        await LoadList();
    }

    private void AddVariant() => _editing!.Variants.Add(new VariantEditor { Currency = "EUR" });

    private async Task Save()
    {
        if (_editing is null) return;
        if (_requireShipRules && _editing.ShipRules.Count == 0)
        {
            _error = L["Catalog.ShipRules.Required"];
            return;
        }

        _saving = true;
        _error = null;
        _editing.Attributes = _attributes
            .Where(a => !string.IsNullOrWhiteSpace(a.Key))
            .ToDictionary(a => a.Key.Trim(), a => a.Value ?? string.Empty);

        HttpResponseMessage resp;
        if (_isNew)
        {
            resp = await Gateway.PostAsync(Base, _editing);
        }
        else
        {
            resp = await Gateway.PutAsync($"{Base}/{_editing.Id}", _editing);
        }

        _saving = false;
        if (resp.IsSuccessStatusCode)
        {
            _status = _isNew ? L["Catalog.Status.Created"] : L["Catalog.Status.Updated"];
            _editing = null;
            await LoadList();
        }
        else
        {
            _error = L["Catalog.Status.SaveFailed", (int)resp.StatusCode, await resp.Content.ReadAsStringAsync()];
        }
    }

    private void Cancel()
    {
        _editing = null;
        _error = null;
    }

    public record ProductListItem(Guid Id, string Slug, string Title, string Brand, int VariantCount, long MinPriceMinor, int TotalStock, string? ImageUrl, int ProductType);
    public record CategoryDto(Guid Id, string Slug, string Name, Guid? ParentId);
    public record CatalogSettingsDto(Guid TenantId, bool RequireProductShipRules);

    public sealed class ProductEditor
    {
        public Guid Id { get; set; }
        public string Slug { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Brand { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public Guid CategoryId { get; set; }
        public int ProductType { get; set; } = 1; // Physical
        public Dictionary<string, string> Attributes { get; set; } = [];
        public List<string> ImageUrls { get; set; } = [];
        public List<VariantEditor> Variants { get; set; } = [];
        public List<ShipRuleEditor> ShipRules { get; set; } = [];
    }

    public sealed class ShipRuleEditor
    {
        public string CountryCode { get; set; } = "*";
        public bool ChargeDestinationTax { get; set; } = true;
        public bool ShippingCovered { get; set; }
    }

    public sealed class VariantEditor
    {
        public Guid? Id { get; set; }
        public string Sku { get; set; } = string.Empty;
        public long PriceMinor { get; set; }
        public string Currency { get; set; } = "EUR";
        public int StockQuantity { get; set; }
        public List<CurrencyPrice> Prices { get; set; } = [];
    }

    public sealed class CurrencyPrice
    {
        public string Currency { get; set; } = "EUR";
        public long PriceMinor { get; set; }
    }

    private sealed class KeyValueRow
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}
