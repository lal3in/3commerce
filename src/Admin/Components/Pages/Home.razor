@page "/"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<div style="display:flex; align-items:baseline; gap:1rem;">
    <h1 style="margin:0;">@L["Home.Title"]</h1>
    <span style="color:#6b7280; font-size:.85rem;">@L["Home.Subtitle"]</span>
    <span style="flex:1;"></span>
    <button @onclick="LoadAsync" title="@L["Common.Refresh.Tip"]" style="padding:.35rem .8rem;">↻ @L["Common.Refresh"]</button>
</div>

@if (_loading)
{
    <p style="margin-top:1rem;">@L["Home.Loading"]</p>
}
else
{
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-top:1.2rem;">
        @KpiCard(L["Home.Kpi.Revenue"], Money(_revenueMinor), "#4f46e5", L["Home.Kpi.Revenue.Sub", _orders.Count], L["Home.Kpi.Revenue.Tip"])
        @KpiCard(L["Home.Kpi.Refunds"], Money(_refundsMinor), _refundsMinor > 0 ? "#b45309" : "#059669", L["Home.Kpi.Refunds.Sub", _refundCount], L["Home.Kpi.Refunds.Tip"])
        @KpiCard(L["Home.Kpi.NetRevenue"], Money(_netRevenueMinor), "#0e7490", L["Home.Kpi.NetRevenue.Sub"], L["Home.Kpi.NetRevenue.Tip"])
        @KpiCard(L["Home.Kpi.Orders"], _orders.Count.ToString(), "#0891b2", L["Home.Kpi.Orders.Sub", _ordersToday], L["Home.Kpi.Orders.Tip"])
        @KpiCard(L["Home.Kpi.Products"], _productCount.ToString(), "#059669", L["Home.Kpi.Products.Sub"], L["Home.Kpi.Products.Tip"])
        @KpiCard(L["Home.Kpi.OpenRmas"], _openRmas.ToString(), _openRmas > 0 ? "#d97706" : "#059669", L["Home.Kpi.OpenRmas.Sub", _rmas.Count], L["Home.Kpi.OpenRmas.Tip"])
        @KpiCard(L["Home.Kpi.Ledger"], Money(_trialBalanceMinor), _trialBalanceMinor == 0 ? "#059669" : "#dc2626", _trialBalanceMinor == 0 ? L["Home.Kpi.Balanced"] : L["Home.Kpi.OutOfBalance"], L["Home.Kpi.Ledger.Tip"])
    </div>

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:1.2rem; margin-top:1.4rem;">
        <div style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; background:#fff;">
            <div style="display:flex; align-items:baseline; gap:1rem; margin:0 0 .6rem;">
                <h3 style="margin:0;">@L["Home.Revenue14"]</h3>
                <span style="flex:1;"></span>
                <span style="font-size:.75rem; color:#6b7280;"><span style="color:#6366f1;">■</span> @L["Home.Chart.Gross"] &nbsp; <span style="color:#f59e0b;">■</span> @L["Home.Chart.Refunds"]</span>
            </div>
            @if (_revByDay.Count == 0)
            {
                <p style="color:#9ca3af;">@L["Home.NoOrders"]</p>
            }
            else
            {
                <svg viewBox="0 0 580 170" style="width:100%; height:170px;">@ChartSvg()</svg>
            }
        </div>

        <div style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; background:#fff;">
            <h3 style="margin:0 0 .6rem;">@L["Home.OrdersByStatus"]</h3>
            @if (_byStatus.Count == 0)
            {
                <p style="color:#9ca3af;">—</p>
            }
            else
            {
                @foreach (var kv in _byStatus.OrderByDescending(s => s.Value))
                {
                    var pct = _orders.Count > 0 ? kv.Value * 100 / _orders.Count : 0;
                    <div style="margin-bottom:.5rem;">
                        <div style="display:flex; justify-content:space-between; font-size:.85rem;"><span>@kv.Key</span><span style="color:#6b7280;">@kv.Value</span></div>
                        <div style="background:#f3f4f6; border-radius:6px; height:8px; overflow:hidden;"><div style="width:@(pct)%; height:100%; background:#0891b2;"></div></div>
                    </div>
                }
            }
        </div>
    </div>

    <div style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; background:#fff; margin-top:1.2rem;">
        <h3 style="margin:0 0 .6rem;">@L["Home.RecentOrders"]</h3>
        @if (_orders.Count == 0)
        {
            <p style="color:#9ca3af;">@L["Home.NoOrders"]</p>
        }
        else
        {
            <table style="border-collapse:collapse; width:100%; font-size:.9rem;">
                <thead><tr><th style="text-align:left;">@L["Home.Col.When"]</th><th style="text-align:left;">@L["Home.Col.Order"]</th><th style="text-align:left;">@L["Home.Col.Status"]</th><th style="text-align:right;">@L["Home.Col.Amount"]</th></tr></thead>
                <tbody>
                @foreach (var o in _orders.OrderByDescending(o => o.CreatedAt).Take(8))
                {
                    <tr style="border-top:1px solid #f3f4f6;">
                        <td>@o.CreatedAt.LocalDateTime.ToString("dd MMM HH:mm")</td>
                        <td><code style="font-size:.8rem;">@o.Id.ToString()[..8]</code></td>
                        <td>@o.Status</td>
                        <td style="text-align:right;">@($"{o.GrossMinor / 100m:0.00} {o.Currency}")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    <div style="border:1px solid #e5e7eb; border-radius:10px; padding:1rem 1.2rem; background:#fff; margin-top:1.2rem;">
        <div style="display:flex; align-items:baseline; gap:1rem;">
            <h3 style="margin:0 0 .6rem;">@L["Home.LedgerFeed"]</h3>
            <span style="flex:1;"></span>
            <a href="/ledger" style="font-size:.8rem;" title="@L["Nav.Ledger.Tip"]">@L["Home.LedgerFeed.All"]</a>
        </div>
        @if (_ledger.Count == 0)
        {
            <p style="color:#9ca3af;">@L["Home.NoLedger"]</p>
        }
        else
        {
            <table style="border-collapse:collapse; width:100%; font-size:.9rem;">
                <thead><tr><th style="text-align:left;">@L["Home.Col.When"]</th><th style="text-align:left;">@L["Home.Col.Entry"]</th><th style="text-align:right;">@L["Home.Col.Amount"]</th></tr></thead>
                <tbody>
                @foreach (var e in _ledger.OrderByDescending(e => e.CreatedAt).Take(8))
                {
                    var isRefund = e.Lines.Any(l => l.AccountCode == "revenue.refunds");
                    var total = e.Lines.Sum(l => l.DebitMinor);
                    <tr style="border-top:1px solid #f3f4f6;">
                        <td>@e.CreatedAt.LocalDateTime.ToString("dd MMM HH:mm")</td>
                        <td>@e.Description</td>
                        <td style="text-align:right; @(isRefund ? "color:#b45309;" : "color:#047857;")">@(isRefund ? "−" : "")@($"{total / 100m:0.00} {e.Currency}")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<OrderDto> _orders = [];
    private List<RmaDto> _rmas = [];
    private List<EntryDto> _ledger = [];
    private int _productCount;
    private long _revenueMinor;
    private long _refundsMinor;
    private long _netRevenueMinor;
    private long _trialBalanceMinor;
    private int _refundCount;
    private int _openRmas;
    private int _ordersToday;
    private string _currency = "EUR";
    private Dictionary<string, int> _byStatus = [];
    private Dictionary<DateTime, long> _revByDay = [];
    private Dictionary<DateTime, long> _refByDay = [];

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var ordersTask = Gateway.GetListAsync<OrderDto>("/api/ordering/admin/orders");
        var rmasTask = Gateway.GetListAsync<RmaDto>("/api/support/admin/rmas");
        var ledgerTask = Gateway.GetListAsync<EntryDto>("/api/payments/admin/ledger/entries");
        var productsTask = Gateway.GetListAsync<ProductDto>("/api/catalog/admin/products?pageSize=200");
        await Task.WhenAll(ordersTask, rmasTask, ledgerTask, productsTask);

        _orders = await ordersTask;
        _rmas = await rmasTask;
        _ledger = await ledgerTask;
        _productCount = (await productsTask).Count;

        _revenueMinor = _orders.Sum(o => o.GrossMinor);
        _currency = _orders.Select(o => o.Currency).FirstOrDefault() ?? "EUR";
        _ordersToday = _orders.Count(o => o.CreatedAt.LocalDateTime.Date == DateTime.Now.Date);
        _openRmas = _rmas.Count(r => r.State is "Requested" or "Pending" or "Open");
        _trialBalanceMinor = _ledger.SelectMany(e => e.Lines).Sum(l => l.DebitMinor) - _ledger.SelectMany(e => e.Lines).Sum(l => l.CreditMinor);
        _byStatus = _orders.GroupBy(o => o.Status).ToDictionary(g => g.Key, g => g.Count());

        // Refunds come off the ledger (the single source of truth): revenue.refunds is debited for the
        // net refunded, so it reflects every refund path — admin instant, RMA-return, or storefront —
        // and nets against gross revenue. Refunded-order count is a friendlier companion figure.
        _refundsMinor = _ledger.SelectMany(e => e.Lines).Where(l => l.AccountCode == "revenue.refunds").Sum(l => l.DebitMinor);
        _netRevenueMinor = _revenueMinor - _refundsMinor;
        _refundCount = _orders.Count(o => o.Status == "Refunded");

        _revByDay = [];
        _refByDay = [];
        for (var d = 13; d >= 0; d--)
        {
            var day = DateTime.Now.Date.AddDays(-d);
            _revByDay[day] = _orders.Where(o => o.CreatedAt.LocalDateTime.Date == day).Sum(o => o.GrossMinor);
            _refByDay[day] = _ledger.Where(e => e.CreatedAt.LocalDateTime.Date == day)
                .SelectMany(e => e.Lines).Where(l => l.AccountCode == "revenue.refunds").Sum(l => l.DebitMinor);
        }

        _loading = false;
    }

    private MarkupString ChartSvg()
    {
        if (_revByDay.Count == 0)
        {
            return default;
        }

        var max = Math.Max(1, Math.Max(_revByDay.Values.Max(), _refByDay.Values.DefaultIfEmpty(0).Max()));
        var parts = _revByDay.Select((kv, i) =>
        {
            var h = kv.Value * 130.0 / max;
            var x = (i * 40) + 14;
            var refund = _refByDay.TryGetValue(kv.Key, out var r) ? r : 0;
            var rh = refund * 130.0 / max;
            // Gross bar (indigo) with the day's refunds overlaid as a narrower amber bar on the same scale,
            // so a refund shows against the sale it reverses even on a day with no new orders.
            var bars = $"<rect x=\"{x}\" y=\"{140 - h:0.#}\" width=\"26\" height=\"{h:0.#}\" rx=\"3\" fill=\"#6366f1\"><title>{kv.Key:dd MMM}: {Money(kv.Value)}</title></rect>";
            if (rh > 0)
            {
                bars += $"<rect x=\"{x + 7}\" y=\"{140 - rh:0.#}\" width=\"12\" height=\"{rh:0.#}\" rx=\"2\" fill=\"#f59e0b\"><title>{kv.Key:dd MMM} · {Money(refund)} refunded</title></rect>";
            }

            return bars + $"<text x=\"{x + 13}\" y=\"158\" font-size=\"9\" text-anchor=\"middle\" fill=\"#9ca3af\">{kv.Key:dd}</text>";
        });
        return (MarkupString)string.Concat(parts);
    }

    private string Money(long minor) => $"{minor / 100m:N2} {_currency}";

    // label/sub/tip come from the resx (trusted, developer-authored), value from our own formatting — nothing
    // user-supplied reaches this markup.
    private RenderFragment KpiCard(string label, string value, string color, string sub, string tip) => builder =>
    {
        builder.AddMarkupContent(0,
            $"<div title=\"{tip}\" style=\"border:1px solid #e5e7eb; border-left:4px solid {color}; border-radius:10px; padding:1rem 1.1rem; background:#fff;\">" +
            $"<div style=\"font-size:.8rem; color:#6b7280; text-transform:uppercase; letter-spacing:.03em;\">{label}</div>" +
            $"<div style=\"font-size:1.7rem; font-weight:700; color:#111827; margin:.2rem 0;\">{value}</div>" +
            $"<div style=\"font-size:.8rem; color:#9ca3af;\">{sub}</div></div>");
    };

    public record OrderDto(Guid Id, string Status, long GrossMinor, string Currency, DateTimeOffset CreatedAt);
    public record RmaDto(Guid Id, Guid OrderId, string? Email, long AmountMinor, string? Reason, string State, DateTimeOffset CreatedAt);
    public record LineDto(string AccountCode, long DebitMinor, long CreditMinor);
    public record EntryDto(Guid Id, string Description, string Reference, string Currency, DateTimeOffset CreatedAt, List<LineDto> Lines);
    public record ProductDto(Guid Id);
}
