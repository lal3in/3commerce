@page "/rbac"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["Rbac.Title"]</h1>
<p style="color:#6b7280;">@((MarkupString)L["Rbac.Intro"].Value)</p>

<div style="display:flex; gap:.5rem; align-items:center; margin:.5rem 0 1rem;">
    <label style="font-size:.85rem; color:#374151;">@L["Rbac.Tenant"]
        <input @bind="_tenantId" style="width:24rem; padding:.3rem; margin-left:.3rem;" title="@L["Rbac.Tenant.Tip"]" />
    </label>
    <button @onclick="LoadAsync" title="@L["Common.Load.Tip"]" style="padding:.35rem .8rem;">@L["Common.Load"]</button>
</div>

@if (_error is not null)
{
    <p style="color:#b91c1c;">@_error</p>
}
@if (_status is not null)
{
    <p style="color:#047857;">@_status</p>
}

@if (_editing is null)
{
    <button @onclick="NewRole" title="@L["Rbac.NewRole.Tip"]" style="padding:.4rem .9rem; background:#111827; color:#fff; border:0; border-radius:5px;">@L["Rbac.NewRole"]</button>

    @if (_roles.Count == 0)
    {
        <p style="margin-top:1rem;">@L["Rbac.NoRoles"]</p>
    }
    else
    {
        <table style="border-collapse:collapse; width:100%; margin-top:1rem;">
            <thead><tr>
                <th style="text-align:left;">@L["Rbac.Col.Role"]</th><th style="text-align:left;">@L["Rbac.Col.Key"]</th>
                <th>@L["Common.Type"]</th><th>@L["Rbac.Col.Permissions"]</th><th></th>
            </tr></thead>
            <tbody>
            @foreach (var r in _roles)
            {
                <tr style="border-top:1px solid #e5e7eb;">
                    <td>@r.Name@if (!string.IsNullOrWhiteSpace(r.Description)) { <br /><span style="color:#6b7280; font-size:.8rem;">@r.Description</span> }</td>
                    <td><code>@r.Key</code></td>
                    <td style="text-align:center;">
                        @if (r.IsSystem) { <span style="font-size:.75rem; background:#fee2e2; color:#b91c1c; padding:.1rem .4rem; border-radius:9px;">@L["Rbac.Badge.System"]</span> }
                        else if (r.IsBuiltIn) { <span style="font-size:.75rem; background:#e0e7ff; color:#3730a3; padding:.1rem .4rem; border-radius:9px;">@L["Rbac.Badge.BuiltIn"]</span> }
                        else { <span style="font-size:.75rem; color:#6b7280;">@L["Rbac.Badge.Custom"]</span> }
                    </td>
                    <td style="text-align:center;">@r.PermissionKeys.Count</td>
                    <td style="text-align:right; white-space:nowrap;">
                        <button @onclick="() => EditRole(r)" disabled="@r.IsSystem" title="@(r.IsSystem ? L["Rbac.Edit.SystemTip"] : L["Rbac.Edit.Tip"])" style="padding:.2rem .6rem;">@L["Common.Edit"]</button>
                        <button @onclick="() => DuplicateRole(r)" style="padding:.2rem .6rem;" title="@L["Rbac.Duplicate.Tip"]">@L["Rbac.Duplicate"]</button>
                        <button @onclick="() => DeleteRole(r)" disabled="@(r.IsBuiltIn || r.IsSystem)" title="@(r.IsBuiltIn || r.IsSystem ? L["Rbac.Delete.LockedTip"] : L["Rbac.Delete.Tip"])" style="padding:.2rem .6rem; color:#b91c1c;">@(_confirmingDelete == r.Id ? L["Common.Confirm"] : L["Common.Delete"])</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}
else
{
    <h2>@_editing.HeadingFor(L)</h2>
    <div style="display:flex; flex-direction:column; gap:.6rem; max-width:880px;">
        <label>@L["Rbac.Field.Name"] <input @bind="_editing.Name" style="width:100%; padding:.4rem;" title="@L["Rbac.Field.Name.Tip"]" /></label>
        <label>@L["Rbac.Field.Key"]
            <input @bind="_editing.Key" disabled="@(!_editing.IsNew)" style="width:100%; padding:.4rem;"
                   title="@L["Rbac.Field.Key.Tip"]" />
            <span style="color:#6b7280; font-size:.8rem;">@(_editing.IsNew ? L["Rbac.Field.Key.HintNew"] : L["Rbac.Field.Key.HintFixed"])</span>
        </label>
        <label>@L["Rbac.Field.Description"] <input @bind="_editing.Description" style="width:100%; padding:.4rem;" title="@L["Rbac.Field.Description.Tip"]" /></label>

        <div style="display:flex; justify-content:space-between; align-items:center;">
            <h3 style="margin:.5rem 0;">@L["Rbac.Permissions"] <span style="color:#6b7280; font-size:.85rem;">@L["Rbac.Permissions.Selected", _editing.Selected.Count]</span></h3>
            <span style="font-size:.8rem; color:#6b7280;">@L["Rbac.Permissions.Hint"]</span>
        </div>

        @foreach (var group in _grouped)
        {
            <fieldset style="border:1px solid #e5e7eb; border-radius:6px; padding:.5rem .7rem;">
                <legend style="font-weight:600; text-transform:capitalize;">@group.Key.Replace('_', ' ')</legend>
                @foreach (var p in group)
                {
                    <label style="display:flex; gap:.5rem; align-items:flex-start; padding:.25rem 0; cursor:pointer;" title="@L["Rbac.Permission.Tip"]">
                        <input type="checkbox" checked="@_editing.Selected.Contains(p.Key)" @onchange="e => Toggle(p.Key, e)" style="margin-top:.2rem;" />
                        <span>
                            <code>@p.Key</code>
                            <span style="@RiskStyle(p.RiskLevel); font-size:.7rem; padding:.05rem .35rem; border-radius:9px; margin-left:.3rem;">@RiskLabel(p.RiskLevel)</span>
                            <br /><span style="color:#4b5563; font-size:.85rem;">@p.Description</span>
                        </span>
                    </label>
                }
            </fieldset>
        }

        <div style="display:flex; gap:.5rem; margin-top:.5rem;">
            <button @onclick="Save" disabled="@_saving" title="@L["Rbac.Save.Tip"]" style="padding:.4rem 1.1rem; background:#111827; color:#fff; border:0; border-radius:5px;">@(_saving ? L["Common.Saving"] : L["Rbac.Save"])</button>
            <button @onclick="() => _editing = null" title="@L["Common.Cancel.Tip"]" style="padding:.4rem 1.1rem;">@L["Common.Cancel"]</button>
        </div>
    </div>
}

@code {
    private string _tenantId = "00000000-0000-0000-0000-000000000001";
    private string? _error;
    private string? _status;
    private bool _saving;
    private List<RoleResponse> _roles = [];
    private List<PermissionResponse> _permissions = [];
    private List<IGrouping<string, PermissionResponse>> _grouped = [];
    private RoleEditor? _editing;
    private Guid? _confirmingDelete;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _error = _status = null;
        if (!Guid.TryParse(_tenantId, out _))
        {
            _error = L["Rbac.Error.TenantGuid"];
            return;
        }

        _permissions = await Gateway.GetListAsync<PermissionResponse>("/api/identity/admin/rbac/permissions");
        _grouped = _permissions.GroupBy(p => p.Key.Split('.')[0]).OrderBy(g => g.Key).ToList();
        _roles = await Gateway.GetListAsync<RoleResponse>($"/api/identity/admin/rbac/roles?tenantId={_tenantId}");
    }

    private void NewRole() => _editing = new RoleEditor { IsNew = true, Mode = "New" };

    private void EditRole(RoleResponse r) => _editing = new RoleEditor
    {
        IsNew = false,
        Mode = "Edit",
        Id = r.Id,
        Name = r.Name,
        Key = r.Key,
        Description = r.Description,
        Selected = new HashSet<string>(r.PermissionKeys),
    };

    private void DuplicateRole(RoleResponse r) => _editing = new RoleEditor
    {
        IsNew = true,
        Mode = "Duplicate",
        Name = L["Rbac.CopySuffix", r.Name],
        Key = $"{r.Key}-copy",
        Description = r.Description,
        Selected = new HashSet<string>(r.PermissionKeys),
    };

    private async Task DeleteRole(RoleResponse r)
    {
        _error = _status = null;
        if (_confirmingDelete != r.Id)
        {
            _confirmingDelete = r.Id; // first click arms the confirm
            return;
        }

        _confirmingDelete = null;
        var response = await Gateway.DeleteAsync($"/api/identity/admin/rbac/roles/{r.Id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadAsync(); // LoadAsync clears _status/_error, so set the confirmation AFTER the reload
            _status = L["Rbac.Status.Deleted", r.Name];
        }
        else
        {
            _error = await response.Content.ReadAsStringAsync();
        }
    }

    private void Toggle(string key, ChangeEventArgs e)
    {
        if (e.Value is true)
        {
            _editing!.Selected.Add(key);
        }
        else
        {
            _editing!.Selected.Remove(key);
        }
    }

    private async Task Save()
    {
        _error = _status = null;
        _saving = true;
        try
        {
            var perms = _editing!.Selected.ToList();
            HttpResponseMessage response;
            if (_editing.IsNew)
            {
                response = await Gateway.PostAsync("/api/identity/admin/rbac/roles",
                    new { tenantId = Guid.Parse(_tenantId), key = _editing.Key, name = _editing.Name, description = _editing.Description, permissionKeys = perms });
            }
            else
            {
                response = await Gateway.PutAsync($"/api/identity/admin/rbac/roles/{_editing.Id}/permissions", new { permissionKeys = perms });
            }

            if (response.IsSuccessStatusCode)
            {
                var savedName = _editing.Name;
                _editing = null;
                await LoadAsync(); // LoadAsync clears _status/_error, so set the confirmation AFTER the reload
                _status = L["Rbac.Status.Saved", savedName];
            }
            else
            {
                _error = L["Rbac.Error.SaveFailed", await response.Content.ReadAsStringAsync()];
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private string RiskLabel(int r) => r switch { 3 => L["Rbac.Risk.High"], 2 => L["Rbac.Risk.Medium"], _ => L["Rbac.Risk.Low"] };

    private static string RiskStyle(int r) => r switch
    {
        3 => "background:#fee2e2;color:#b91c1c;",
        2 => "background:#fef3c7;color:#b45309;",
        _ => "background:#dcfce7;color:#047857;",
    };

    private sealed record PermissionResponse(string Key, string Description, int RiskLevel);

    private sealed record RoleResponse(Guid Id, Guid? TenantId, string Key, string Name, string? Description, bool IsBuiltIn, bool IsSystem, IReadOnlyList<string> PermissionKeys);

    private sealed class RoleEditor
    {
        public bool IsNew { get; set; }
        public string Mode { get; set; } = "New";
        public Guid? Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Key { get; set; } = string.Empty;
        public string? Description { get; set; }
        public HashSet<string> Selected { get; set; } = [];
        public string HeadingFor(IStringLocalizer<SharedResource> l) => Mode switch
        {
            "Edit" => l["Rbac.Heading.Edit"],
            "Duplicate" => l["Rbac.Heading.Duplicate"],
            _ => l["Rbac.Heading.New"],
        };
    }
}
