@page "/login"
@layout EmptyLayout
@inject NavigationManager Nav

<div style="max-width:320px;margin:6rem auto;font-family:system-ui;">
    <h1 style="font-size:1.3rem;">Admin sign in</h1>
    @if (Nav.Uri.Contains("error=3"))
    {
        <p style="color:#b91c1c;">This account has MFA enabled — enter the 6-digit code from your authenticator app (or a recovery code).</p>
    }
    else if (Nav.Uri.Contains("error"))
    {
        <p style="color:#b91c1c;">Invalid credentials or not an admin account.</p>
    }
    <form action="/auth/login" method="post">
        <AntiforgeryToken />
        <label>Email<input name="email" type="email" required style="width:100%;padding:.5rem;margin:.25rem 0;" title="Your operator email. The admin console requires the 'admin' role." /></label>
        <label>Password<input name="password" type="password" required style="width:100%;padding:.5rem;margin:.25rem 0;" title="Your account password." /></label>
        <label>Authenticator code<input name="code" inputmode="numeric" autocomplete="one-time-code" style="width:100%;padding:.5rem;margin:.25rem 0;" title="Only needed when MFA is enabled on your account (Security page). Leave empty otherwise. Recovery codes work here too." /></label>
        <button type="submit" style="width:100%;padding:.6rem;background:#111827;color:#fff;border:0;border-radius:4px;margin-top:.5rem;">Sign in</button>
    </form>
</div>
