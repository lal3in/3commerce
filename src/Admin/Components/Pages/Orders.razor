@page "/orders"
@attribute [Authorize(Roles = "admin")]
@inject GatewayClient Gateway
@rendermode AdminRenderModes.InteractiveServerNoPrerender

<h1>@L["Orders.Title"]</h1>
<p style="color:#6b7280;">@L["Orders.Intro"]</p>

@if (_error is not null)
{
    <p style="color:#b91c1c;">@_error</p>
}
@if (_status is not null)
{
    <p style="color:#047857;">@_status</p>
}

@if (_orders is null)
{
    <p>@L["Common.Loading"]</p>
}
else if (_orders.Count == 0)
{
    <p>@L["Orders.Empty"]</p>
}
else
{
    <table style="border-collapse:collapse;width:100%;">
        <thead><tr><th style="text-align:left;">@L["Orders.Col.Order"]</th><th>@L["Common.Status"]</th><th>@L["Orders.Col.Total"]</th><th title="@L["Orders.Col.Payment.Tip"]">@L["Orders.Col.Payment"]</th><th>@L["Orders.Col.Placed"]</th><th>@L["Common.Actions"]</th></tr></thead>
        <tbody>
        @foreach (var o in _orders)
        {
            <tr style="border-top:1px solid #e5e7eb;">
                <td style="font-family:monospace;">@o.Id</td>
                <td>@o.Status</td>
                <td>@($"{o.GrossMinor / 100m:0.00} {o.Currency}")</td>
                <td>@PaymentLabel(o.PaymentOption)</td>
                <td>@o.CreatedAt.LocalDateTime.ToString("g")</td>
                <td>
                    @if (o.Status is "Pending" or "AwaitingPayment")
                    {
                        <button @onclick="() => Cancel(o.Id)" title="@L["Orders.Cancel.Tip"]">@(_confirm == $"{o.Id}:cancel" ? L["Common.Confirm"] : L["Orders.Cancel"])</button>
                    }
                    else if (o.Status == "Confirmed")
                    {
                        <button @onclick="() => Refund(o)" title="@L["Orders.Refund.Tip"]">@(_confirm == $"{o.Id}:refund" ? L["Common.Confirm"] : L["Orders.Refund"])</button>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<OrderDto>? _orders;
    private string? _status;
    private string? _error;
    private string? _confirm;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _error = _status = null;
        _confirm = null;
        _orders = await Gateway.GetListAsync<OrderDto>("/api/ordering/admin/orders");
    }

    private async Task Cancel(Guid id)
    {
        if (_confirm != $"{id}:cancel") { _confirm = $"{id}:cancel"; return; }
        _confirm = null;
        var response = await Gateway.PostAsync($"/api/ordering/admin/orders/{id}/cancel", new { reason = "cancelled by admin" });
        if (response.IsSuccessStatusCode)
        {
            await LoadAsync();
            _status = L["Orders.Status.Cancelled"]; // after LoadAsync — it clears _status on refresh
        }
        else
        {
            _error = await response.Content.ReadAsStringAsync();
        }
    }

    private async Task Refund(OrderDto o)
    {
        if (_confirm != $"{o.Id}:refund") { _confirm = $"{o.Id}:refund"; return; }
        _confirm = null;
        // Refund through the RMA path (auto-approved, no-return) so it shows in the RMA queue and drives
        // the single refund flow; when the payment is fully refunded the order transitions to Refunded.
        var response = await Gateway.PostAsync("/api/support/admin/rmas", new { orderId = o.Id, reason = "refunded by admin" }, idempotencyKey: $"refund-{o.Id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadAsync();
            _status = L["Orders.Status.Refunded"]; // after LoadAsync — it clears _status on refresh
        }
        else
        {
            _error = await response.Content.ReadAsStringAsync();
        }
    }

    // Localized label for the checkout payment option; unknown/legacy values fall back sensibly.
    private string PaymentLabel(string? option) => option switch
    {
        "Stripe" => L["Payment.Method.Stripe"],
        "ApplePay" => L["Payment.Method.ApplePay"],
        "GooglePay" => L["Payment.Method.GooglePay"],
        "PayPal" => L["Payment.Method.PayPal"],
        null or "" or "CreditCard" => L["Payment.Method.CreditCard"],
        _ => option, // future/unknown option — show the raw value rather than hiding it
    };

    public record OrderDto(Guid Id, string Status, long GrossMinor, string Currency, DateTimeOffset CreatedAt, string? PaymentOption = null);
}
