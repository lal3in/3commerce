            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/admin/rmas/{id}/return-received": {
      "post": {
        "tags": [
          "RMA"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApproveRequest": {
        "required": [
          "requireReturn"
        ],
        "type": "object",
        "properties": {
          "requireReturn": {
            "type": "boolean"
          }
        }
      },
      "MessageDto": {
        "required": [
          "author",
          "body",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "author": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MessageRequest": {
        "required": [
          "body"
        ],
        "type": "object",
        "properties": {
          "body": {
            "type": "string"
          }
        }
      },
      "OpenTicketRequest": {
        "required": [
          "orderId",
          "email",
          "reason",
          "message"
        ],
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "reason": {
            "$ref": "#/components/schemas/TicketReason"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "RmaCreatedDto": {
        "required": [
          "rmaId"
        ],
        "type": "object",
        "properties": {
          "rmaId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "RmaDto": {
        "required": [
          "id",
          "orderId",
          "email",
          "amountMinor",
          "reason",
          "state",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": [
              "null",
              "string"
            ]
          },
          "amountMinor": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "reason": {
            "type": [
              "null",
              "string"
            ]
          },
          "state": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RmaRequest": {
        "required": [
          "orderId",
          "email",
          "amountMinor",
          "reason"
        ],
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "amountMinor": {
            "maximum": 9223372036854776000,
            "minimum": 1,
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "TicketDto": {
        "required": [
          "id",
          "orderId",
          "email",
          "reason",
          "status",
          "createdAt",
          "messages"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageDto"
            }
          }
        }
      },
      "TicketReason": {
        "type": "integer"
      }
    }
  },
  "tags": [
    {
      "name": "Support"
    },
    {
      "name": "RMA"
    }
  ]
}