  "components": {
    "schemas": {
      "AddressDto": {
        "required": [
          "name",
          "line1",
          "city",
          "postcode",
          "country"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "line1": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "postcode": {
            "type": "string"
          },
          "country": {
            "maxLength": 2,
            "minLength": 2,
            "type": "string"
          }
        }
      },
      "CarrierCode": {
        "type": "integer"
      },
      "CarrierDto": {
        "required": [
          "id",
          "tenantId",
          "storefrontId",
          "carrier",
          "status",
          "isDefault",
          "hasCredential"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "storefrontId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "carrier": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "isDefault": {
            "type": "boolean"
          },
          "hasCredential": {
            "type": "boolean"
          }
        }
      },
      "ConfigureCarrierRequest": {
        "required": [
          "tenantId",
          "storefrontId",
          "carrier",
          "credentialRef"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "storefrontId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "carrier": {
            "$ref": "#/components/schemas/CarrierCode"
          },
          "credentialRef": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateLocationRequest": {
        "required": [
          "tenantId",
          "entityId",
