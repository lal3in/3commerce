          "name",
          "kind"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "entityId": {
            "type": "string",
            "format": "uuid"
          },
          "addressId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "name": {
            "maxLength": 200,
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/LocationKind"
          }
        }
      },
      "GroupQuoteDto": {
        "required": [
          "sourceKey",
          "rates"
        ],
        "type": "object",
        "properties": {
          "sourceKey": {
            "type": "string"
          },
          "rates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateDto"
            }
          }
        }
      },
      "GroupQuoteRequest": {
        "required": [
          "tenantId",
          "storefrontId",
          "destination",
          "groups"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "storefrontId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "destination": {
            "$ref": "#/components/schemas/AddressDto"
          },
          "groups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GroupRequestDto"
            }
          }
        }
      },
      "GroupQuoteResponse": {
        "required": [
          "groups"
        ],
        "type": "object",
        "properties": {
          "groups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GroupQuoteDto"
            }
          }
        }
      },
      "GroupRequestDto": {
        "required": [
          "sourceKey",
          "origin",
          "parcel"
        ],
        "type": "object",
        "properties": {
          "sourceKey": {
            "type": "string"
          },
          "origin": {
            "$ref": "#/components/schemas/AddressDto"
          },
          "parcel": {
            "$ref": "#/components/schemas/ParcelDto"
          }
        }
      },
      "LocationDto": {
        "required": [
          "id",
          "tenantId",
          "entityId",
          "addressId",
          "name",
          "kind",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "entityId": {
            "type": "string",
            "format": "uuid"
          },
          "addressId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "LocationKind": {
        "type": "integer"
      },
      "ParcelDto": {
        "required": [
          "weightGrams",
          "lengthMm",
          "widthMm",
          "heightMm"
        ],
        "type": "object",
        "properties": {
          "weightGrams": {
            "maximum": 2147483647,
            "minimum": 0,
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "lengthMm": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "widthMm": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "heightMm": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "QuoteRequest": {
        "required": [
          "tenantId",
          "storefrontId",
          "origin",
          "destination",
          "parcel",
          "service"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "storefrontId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "origin": {
            "$ref": "#/components/schemas/AddressDto"
          },
          "destination": {
            "$ref": "#/components/schemas/AddressDto"
          },
          "parcel": {
            "$ref": "#/components/schemas/ParcelDto"
          },
          "service": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "QuoteResponse": {
        "required": [
          "rates"
        ],
        "type": "object",
        "properties": {
          "rates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateDto"
            }
          }
        }
      },
      "RateDto": {
        "required": [
          "carrier",
          "service",
          "serviceName",
          "amountMinor",
          "currency",
          "estimatedDays"
        ],
        "type": "object",
        "properties": {
          "carrier": {
            "type": "string"
          },
          "service": {
            "type": "string"
          },
          "serviceName": {
            "type": "string"
          },
          "amountMinor": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "currency": {
            "type": "string"
          },
          "estimatedDays": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "SetCredentialRequest": {
        "required": [
          "credentialRef"
        ],
        "type": "object",
        "properties": {
          "credentialRef": {
            "maxLength": 200,
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SetStockRequest": {
        "required": [
          "tenantId",
          "locationId",
          "productId",
          "variantId",
          "onHand"
        ],
