  "components": {
    "schemas": {
      "AddStorefrontDomainRequest": {
        "required": [
          "host",
          "canonical"
        ],
        "type": "object",
        "properties": {
          "host": {
            "maxLength": 253,
            "minLength": 3,
            "type": "string"
          },
          "canonical": {
            "type": "boolean"
          }
        }
      },
      "AssignProductRequest": {
        "required": [
          "productId",
          "slugOverride",
          "titleOverride",
          "descriptionOverride",
          "seoTitle",
          "seoDescription",
          "fulfillmentSource",
          "countryOfOrigin",
          "harmonizedSystemCode"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "slugOverride": {
            "type": [
              "null",
              "string"
            ]
          },
          "titleOverride": {
            "type": [
              "null",
              "string"
            ]
          },
          "descriptionOverride": {
            "type": [
              "null",
              "string"
            ]
          },
          "seoTitle": {
            "type": [
              "null",
              "string"
            ]
          },
          "seoDescription": {
            "type": [
              "null",
              "string"
            ]
          },
          "fulfillmentSource": {
            "$ref": "#/components/schemas/CatalogFulfillmentSource"
          },
          "countryOfOrigin": {
            "type": [
              "null",
              "string"
            ]
          },
          "harmonizedSystemCode": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CatalogFulfillmentSource": {
        "type": "integer"
      },
      "CategoryResponse": {
        "required": [
          "id",
          "slug",
          "name",
          "parentId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "parentId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "CreateStorefrontRequest": {
        "required": [
          "tenantId",
          "name",
          "visibility",
          "accessPasswordHash"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "maxLength": 120,
            "minLength": 2,
            "type": "string"
          },
          "visibility": {
            "$ref": "#/components/schemas/StorefrontVisibility"
          },
          "accessPasswordHash": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "HttpValidationProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "ImportRunResponse": {
        "required": [
          "id",
          "importer",
          "startedAt",
          "completedAt",
          "rowsRead",
          "accepted",
          "rejected",
          "sampleRejections"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "importer": {
            "type": "string"
          },
          "startedAt": {
            "type": "string",
