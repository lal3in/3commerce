                    "email": {
                        "type": "string"
                    },
                    "netMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "shippingMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "discountMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "taxMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "grossMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "lines": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/OrderLineResponse"
                        }
                    }
                }
            },
            "OrderLineResponse": {
                "required": [
                    "productId",
                    "variantId",
                    "variantSku",
                    "title",
                    "unitPriceMinor",
                    "discountMinor",
                    "quantity",
                    "fulfilmentType",
                    "billingMode"
                ],
                "type": "object",
                "properties": {
                    "productId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "variantId": {
                        "type": [
                            "null",
                            "string"
                        ],
                        "format": "uuid"
                    },
                    "variantSku": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "title": {
                        "type": "string"
                    },
                    "unitPriceMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "discountMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "quantity": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int32"
                    },
                    "fulfilmentType": {
                        "type": "string"
                    },
                    "billingMode": {
                        "type": "string"
                    }
                }
            },
            "OrderStatusResponse": {
                "required": [
                    "id",
                    "status"
                ],
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "type": "string"
                    }
                }
            },
            "OrderSummary": {
                "required": [
                    "id",
                    "status",
                    "grossMinor",
                    "currency",
                    "createdAt"
                ],
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "type": "string"
                    },
                    "grossMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "UpdateItemRequest": {
                "required": [
                    "quantity"
                ],
                "type": "object",
                "properties": {
                    "quantity": {
                        "maximum": 99,
                        "minimum": 0,
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int32"
                    }
