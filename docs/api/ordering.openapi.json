    "components": {
        "schemas": {
            "AddItemRequest": {
                "required": [
                    "productId",
                    "variantId",
                    "quantity"
                ],
                "type": "object",
                "properties": {
                    "productId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "variantId": {
                        "type": [
                            "null",
                            "string"
                        ],
                        "format": "uuid"
                    },
                    "quantity": {
                        "maximum": 99,
                        "minimum": 1,
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int32"
                    },
                    "currency": {
                        "type": [
                            "null",
                            "string"
                        ]
                    }
                }
            },
            "AddressRequest": {
                "required": [
                    "name",
                    "line1",
                    "city",
                    "postcode",
                    "country"
                ],
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "line1": {
                        "type": "string"
                    },
                    "city": {
                        "type": "string"
                    },
                    "postcode": {
                        "type": "string"
                    },
                    "country": {
                        "maxLength": 2,
                        "minLength": 2,
                        "type": "string"
                    }
                }
            },
            "CancelOrderRequest": {
                "required": [
                    "reason"
                ],
                "type": "object",
                "properties": {
                    "reason": {
                        "type": [
                            "null",
                            "string"
                        ]
                    }
                }
            },
            "CartItemResponse": {
                "required": [
                    "productId",
                    "variantId",
                    "variantSku",
                    "slug",
                    "title",
                    "imageUrl",
                    "unitPriceMinor",
                    "currency",
                    "quantity"
                ],
                "type": "object",
                "properties": {
                    "productId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "variantId": {
                        "type": [
                            "null",
                            "string"
                        ],
                        "format": "uuid"
                    },
                    "variantSku": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "slug": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "imageUrl": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "unitPriceMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "quantity": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int32"
                    }
                }
            },
            "CartResponse": {
                "required": [
                    "cartId",
                    "items",
                    "subtotalMinor",
                    "currency"
                ],
                "type": "object",
                "properties": {
                    "cartId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CartItemResponse"
                        }
                    },
                    "subtotalMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "currency": {
                        "type": "string"
                    }
                }
            },
            "CheckoutRequest": {
                "required": [
                    "email",
                    "shippingAddress"
                ],
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string"
                    },
                    "shippingAddress": {
                        "$ref": "#/components/schemas/AddressRequest"
                    },
                    "campaignRef": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "savedPaymentMethodId": {
                        "type": [
                            "null",
                            "string"
                        ],
                        "format": "uuid"
                    },
                    "savePaymentMethod": {
                        "type": "boolean",
                        "default": false
                    },
                    "paymentOption": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "paymentInstrumentSummary": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "selectedShippingService": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "selectedShippingAmountMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "null",
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "selectedShippingExpiresAt": {
                        "type": [
                            "null",
                            "string"
                        ],
                        "format": "date-time"
                    }
                }
            },
            "CheckoutResponse": {
                "required": [
                    "orderId",
                    "clientSecret",
                    "netMinor",
                    "discountMinor",
                    "shippingMinor",
                    "taxMinor",
                    "grossMinor",
                    "currency",
                    "message"
                ],
                "type": "object",
                "properties": {
                    "orderId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "clientSecret": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "netMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "discountMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "shippingMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "taxMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "grossMinor": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                            "integer",
                            "string"
                        ],
                        "format": "int64"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "message": {
                        "type": [
                            "null",
                            "string"
                        ]
                    }
                }
            },
            "OrderDetail": {
                "required": [
                    "id",
                    "status",
                    "email",
                    "netMinor",
                    "shippingMinor",
                    "discountMinor",
                    "taxMinor",
                    "grossMinor",
                    "currency",
                    "createdAt",
                    "lines"
                ],
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "type": "string"
