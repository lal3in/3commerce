  "components": {
    "schemas": {
      "AddressPurpose": {
        "type": "integer"
      },
      "AddressRequest": {
        "required": [
          "purpose",
          "isDefault",
          "name",
          "line1",
          "line2",
          "city",
          "postcode",
          "country"
        ],
        "type": "object",
        "properties": {
          "purpose": {
            "$ref": "#/components/schemas/AddressPurpose"
          },
          "isDefault": {
            "type": "boolean"
          },
          "name": {
            "maxLength": 100,
            "type": "string"
          },
          "line1": {
            "maxLength": 200,
            "type": "string"
          },
          "line2": {
            "maxLength": 200,
            "type": [
              "null",
              "string"
            ]
          },
          "city": {
            "maxLength": 100,
            "type": "string"
          },
          "postcode": {
            "maxLength": 20,
            "type": "string"
          },
          "country": {
            "maxLength": 2,
            "minLength": 2,
            "type": "string"
          }
        }
      },
      "AddressResponse": {
        "required": [
          "id",
          "purpose",
          "isDefault",
          "name",
          "line1",
          "line2",
          "city",
          "postcode",
          "country"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "purpose": {
            "$ref": "#/components/schemas/AddressPurpose"
          },
          "isDefault": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          },
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": [
              "null",
              "string"
            ]
          },
          "city": {
            "type": "string"
          },
          "postcode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "AdminUserDto": {
        "required": [
          "id",
          "email",
          "role",
          "emailVerified",
          "givenName",
          "familyName",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "givenName": {
            "type": [
              "null",
              "string"
            ]
          },
          "familyName": {
            "type": [
              "null",
              "string"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ChangeEmailRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "CreateRoleRequest": {
        "required": [
          "tenantId",
          "key",
          "name",
          "description",
          "permissionKeys"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "key": {
            "pattern": "^[a-z0-9-]+$",
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "permissionKeys": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          }
